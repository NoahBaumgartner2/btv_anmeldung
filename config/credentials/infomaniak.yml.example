# Infomaniak Newsletter API – Beispielstruktur für Rails Credentials
#
# Diese Werte müssen via `bin/rails credentials:edit` (bzw. pro Environment
# `bin/rails credentials:edit --environment production`) unter dem Top-Level-Key
# `infomaniak` eingetragen werden:
#
#   bin/rails credentials:edit
#
# Dort dann einfügen:
#
#   infomaniak:
#     api_token: "DEIN_API_TOKEN_HIER"
#     mailing_list_id: "DEINE_MAILINGLIST_ID_HIER"
#     base_url: "https://api.infomaniak.com"
#
# api_token      → Bearer-Token aus dem Infomaniak Manager (Dashboard → API-Schlüssel)
# mailing_list_id → Numerische ID der Mailingliste (aus der Newsletter-URL oder API)
# base_url        → Basis-URL der REST API (normalerweise unveränderlich)

infomaniak:
  api_token: "DEIN_API_TOKEN_HIER"
  mailing_list_id: "DEINE_MAILINGLIST_ID_HIER"
  base_url: "https://api.infomaniak.com"
