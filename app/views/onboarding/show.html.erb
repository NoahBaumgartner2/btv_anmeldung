<% content_for :title, t("onboarding.title") %>

<%= form_with model: @user, url: onboarding_path, method: :post,
      class: "max-w-xl mx-auto px-4 mt-10 mb-16 space-y-6",
      data: { controller: "scroll-to-error" } do |f| %>

  <% if @user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl" data-error-scroll-target>
      <p class="font-semibold mb-1"><%= t("participants.form.error_count", count: @user.errors.count) %></p>
      <ul class="list-disc ml-5 text-sm space-y-0.5">
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="text-center mb-2">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-primary-50 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 21V12h6v9"/>
      </svg>
    </div>
    <h1 class="text-2xl font-extrabold text-gray-900"><%= t("onboarding.title") %></h1>
    <p class="text-gray-500 mt-2 text-sm"><%= t("onboarding.subtitle") %></p>
  </div>

  <%# Kontaktdaten %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("onboarding.section_contact") %></p>

    <div>
      <%= f.label :phone_number, t("onboarding.phone_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.telephone_field :phone_number,
            placeholder: "+41 79 123 45 67",
            autocomplete: "tel",
            class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                    @user.errors[:phone_number].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
      <% if @user.errors[:phone_number].any? %>
        <p class="mt-1 text-xs text-red-600"><%= @user.errors[:phone_number].first %></p>
      <% end %>
    </div>
  </div>

  <%# Adresse %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("onboarding.section_address") %></p>

    <div class="grid grid-cols-3 gap-3">
      <div class="col-span-2">
        <%= f.label :street, t("onboarding.street_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :street,
              placeholder: "Musterstrasse",
              autocomplete: "street-address",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      @user.errors[:street].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if @user.errors[:street].any? %>
          <p class="mt-1 text-xs text-red-600"><%= @user.errors[:street].first %></p>
        <% end %>
      </div>
      <div>
        <%= f.label :house_number, t("onboarding.house_number_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :house_number,
              placeholder: "12a",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :zip_code, t("onboarding.zip_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :zip_code,
              placeholder: "3000",
              autocomplete: "postal-code",
              inputmode: "numeric",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      @user.errors[:zip_code].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if @user.errors[:zip_code].any? %>
          <p class="mt-1 text-xs text-red-600"><%= @user.errors[:zip_code].first %></p>
        <% end %>
      </div>
      <div>
        <%= f.label :city, t("onboarding.city_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :city,
              placeholder: "Bern",
              autocomplete: "address-level2",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      @user.errors[:city].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if @user.errors[:city].any? %>
          <p class="mt-1 text-xs text-red-600"><%= @user.errors[:city].first %></p>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :country, t("onboarding.country_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :country,
            [["Schweiz (CH)", "CH"], ["Liechtenstein (LI)", "LI"], ["Deutschland (DE)", "DE"],
             ["Frankreich (FR)", "FR"], ["Italien (IT)", "IT"], ["Österreich (AT)", "AT"], ["Andere", "Andere"]],
            { selected: @user.country.presence || "CH" },
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :nationality, t("onboarding.nationality_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.select :nationality,
              Participant::NATIONALITIES.map { |n| [n, n] },
              { selected: @user.nationality.presence || "CH" },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
      <div>
        <%= f.label :mother_tongue, t("onboarding.mother_tongue_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.select :mother_tongue,
              Participant::MOTHER_TONGUES.map { |l| [l, l] },
              { selected: @user.mother_tongue.presence || "DE" },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>
  </div>

  <div>
    <%= f.submit t("onboarding.submit"),
          class: "w-full py-3 px-4 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold rounded-xl shadow-sm transition cursor-pointer min-h-11" %>
  </div>
<% end %>
