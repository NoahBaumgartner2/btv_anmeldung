<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-3xl text-gray-800">Trainer</h1>
    <%= link_to "Neuer Trainer", new_trainer_path, class: "rounded-lg py-2 px-4 bg-primary-600 hover:bg-primary-700 text-white font-medium transition shadow-sm" %>
  </div>

  <div class="overflow-x-auto bg-white shadow-sm ring-1 ring-gray-200 rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">E-Mail (Benutzerkonto)</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Telefon</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Zuständig für</th>
          <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktionen</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% @trainers.each do |trainer| %>
          <tr class="hover:bg-gray-50 transition duration-150">
            <td class="py-4 px-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= trainer.user.email %>
            </td>
            <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
              <%= trainer.phone.presence || "-" %>
            </td>
            <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
              <span class="px-2 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">
                <%= pluralize(trainer.courses.count, 'Kurs', 'Kurse') %>
              </span>
            </td>
            <td class="py-4 px-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
              <%= link_to "Anzeigen", trainer, class: "text-primary-600 hover:text-primary-900" %>
              <%= link_to "Bearbeiten", edit_trainer_path(trainer), class: "text-orange-500 hover:text-orange-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @trainers.empty? %>
    <p class="text-gray-500 text-center py-8">Noch keine Trainer vorhanden.</p>
  <% end %>
</div>
