<div class="w-full">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-3">
    <h1 class="font-bold text-xl sm:text-3xl text-gray-800">Trainer</h1>
    <%= link_to "Neuer Trainer", new_trainer_path, class: "w-full sm:w-auto text-center rounded-lg py-2.5 px-4 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-medium transition shadow-sm min-h-11" %>
  </div>

  <% if @trainers.any? %>
    <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-lg overflow-hidden">

      <%# Mobile: Cards %>
      <div class="sm:hidden divide-y divide-gray-100">
        <% @trainers.each do |trainer| %>
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <p class="font-medium text-gray-900 text-sm truncate"><%= trainer.user.email %></p>
              <span class="shrink-0 px-2 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">
                <%= pluralize(trainer.courses.count, 'Kurs', 'Kurse') %>
              </span>
            </div>
            <% if trainer.phone.present? %>
              <p class="text-xs text-gray-500 mb-3"><%= trainer.phone %></p>
            <% end %>
            <div class="flex gap-2 mt-2">
              <%= link_to "Anzeigen", trainer, class: "flex-1 text-center text-primary-600 font-medium bg-primary-50 active:bg-primary-100 py-2.5 rounded-lg text-sm min-h-11 leading-6 transition" %>
              <%= link_to "Bearbeiten", edit_trainer_path(trainer), class: "flex-1 text-center text-orange-500 font-medium bg-orange-50 active:bg-orange-100 py-2.5 rounded-lg text-sm min-h-11 leading-6 transition" %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Desktop: Tabelle %>
      <table class="hidden sm:table min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">E-Mail (Benutzerkonto)</th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Telefon</th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Zuständig für</th>
            <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktionen</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @trainers.each do |trainer| %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="py-4 px-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= trainer.user.email %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <%= trainer.phone.presence || "-" %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <span class="px-2 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">
                  <%= pluralize(trainer.courses.count, 'Kurs', 'Kurse') %>
                </span>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                <%= link_to "Anzeigen", trainer, class: "text-primary-600 hover:text-primary-900" %>
                <%= link_to "Bearbeiten", edit_trainer_path(trainer), class: "text-orange-500 hover:text-orange-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-500 text-center py-8">Noch keine Trainer vorhanden.</p>
  <% end %>
</div>
