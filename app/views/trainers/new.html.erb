<% content_for :title, "Trainer erfassen" %>

<div class="max-w-2xl mx-auto w-full px-4 mt-10 mb-16">

  <div class="mb-8">
    <%= link_to "← Zurück zur Trainerliste", trainers_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900 mt-3">Trainer erfassen</h1>
    <p class="text-gray-500 mt-1">Suche ein bestehendes Benutzerkonto und verknüpfe es als Trainer.</p>
  </div>

  <% if @selected_user %>
    <%# ── Schritt 2: Konto ausgewählt → Telefon eingeben & speichern ─── %>

    <div class="bg-green-50 border border-green-200 rounded-xl px-5 py-4 mb-6 flex items-center justify-between gap-4">
      <div>
        <p class="text-xs font-bold text-green-700 uppercase tracking-wider mb-0.5">Ausgewähltes Konto</p>
        <p class="font-bold text-green-900"><%= @selected_user.email %></p>
      </div>
      <%= link_to "Ändern", new_trainer_path,
            class: "shrink-0 text-xs font-bold text-green-700 hover:text-green-900 underline" %>
    </div>

    <%= form_with(model: @trainer, class: "contents") do |f| %>
      <% if @trainer.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
          <p class="font-semibold mb-1"><%= @trainer.errors.count == 1 ? "Es gibt einen Fehler:" : "Es gibt #{@trainer.errors.count} Fehler:" %></p>
          <ul class="list-disc ml-5 text-sm space-y-0.5">
            <% @trainer.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= f.hidden_field :user_id %>

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Trainer-Daten</p>
        <%= f.label :phone, "Telefonnummer", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.telephone_field :phone,
              placeholder: "+41 79 123 45 67",
              autocomplete: "tel",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2",
                      @trainer.errors[:phone].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if @trainer.errors[:phone].any? %>
          <p class="mt-1 text-xs text-red-600"><%= @trainer.errors[:phone].first %></p>
        <% end %>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-3">
        <%= f.submit "Trainer erfassen",
              class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
        <%= link_to "Abbrechen", trainers_path,
              class: "w-full sm:w-auto text-center rounded-lg px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition" %>
      </div>
    <% end %>

  <% else %>
    <%# ── Schritt 1: Suche ──────────────────────────────────────────────── %>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-4">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">Schritt 1 – Konto suchen</p>

      <%= form_with url: new_trainer_path, method: :get, class: "flex gap-2" do |f| %>
        <%= f.text_field :q,
              value: params[:q],
              placeholder: "E-Mail-Adresse eingeben…",
              autofocus: true,
              autocomplete: "off",
              class: "flex-1 rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
        <%= f.submit "Suchen",
              class: "shrink-0 rounded-lg px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
      <% end %>
    </div>

    <% if params[:q].present? %>
      <% if @search_results.any? %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
            <p class="text-sm font-bold text-gray-700">
              <%= @search_results.size == 25 ? "Erste 25 Treffer" : "#{@search_results.size} #{"Treffer".pluralize(@search_results.size)}" %>
              <span class="font-normal text-gray-400">für „<%= params[:q] %>"</span>
            </p>
          </div>
          <ul class="divide-y divide-gray-100">
            <% @search_results.each do |user| %>
              <li class="flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition">
                <span class="text-sm font-medium text-gray-900"><%= user.email %></span>
                <%= link_to "Auswählen", new_trainer_path(user_id: user.id, q: params[:q]),
                      class: "shrink-0 text-xs font-bold bg-primary-50 hover:bg-primary-100 text-primary-700 px-3 py-1.5 rounded-lg transition" %>
              </li>
            <% end %>
          </ul>
        </div>
        <% if @search_results.size == 25 %>
          <p class="mt-2 text-xs text-center text-gray-400">Zu viele Treffer – bitte Suche verfeinern.</p>
        <% end %>
      <% else %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-8 text-center">
          <p class="text-sm font-semibold text-gray-700">Kein Konto gefunden</p>
          <p class="text-xs text-gray-400 mt-1">Entweder existiert die E-Mail nicht oder ist bereits als Trainer erfasst.</p>
        </div>
      <% end %>
    <% end %>

  <% end %>

</div>
