<%= form_with(model: trainer, class: "contents", data: { controller: "scroll-to-error" }) do |form| %>
  <% if trainer.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6" data-error-scroll-target>
      <p class="font-semibold mb-1"><%= trainer.errors.count == 1 ? "Es gibt einen Fehler:" : "Es gibt #{trainer.errors.count} Fehler:" %></p>
      <ul class="list-disc ml-5 text-sm space-y-0.5">
        <% trainer.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Trainer-Daten</p>

    <div class="mb-5">
      <p class="text-sm font-semibold text-gray-700 mb-1">Benutzerkonto</p>
      <p class="text-sm font-medium text-gray-900 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5">
        <%= trainer.user.email %>
      </p>
    </div>

    <div>
      <%= form.label :phone, "Telefonnummer *", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.telephone_field :phone,
            placeholder: "+41 79 123 45 67",
            autocomplete: "tel",
            class: ["block w-full rounded-lg border px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2",
                    trainer.errors[:phone].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
      <% if trainer.errors[:phone].any? %>
        <p class="mt-1 text-xs text-red-600"><%= trainer.errors[:phone].first %></p>
      <% end %>
      <p class="mt-1 text-xs text-gray-400">Pflichtfeld – z.B. +41 79 123 45 67</p>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row items-center gap-3">
    <%= form.submit "Änderungen speichern",
          class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
    <%= link_to "Abbrechen", trainers_path,
          class: "w-full sm:w-auto text-center rounded-lg px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition" %>
  </div>
<% end %>
