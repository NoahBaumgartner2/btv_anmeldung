<% content_for :title, "Trainer bearbeiten" %>

<div class="max-w-2xl mx-auto w-full px-4 mt-10 mb-16">
  <div class="mb-8">
    <%= link_to "← Zurück zur Trainerliste", trainers_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="font-extrabold text-3xl text-gray-900 mt-3">Trainer bearbeiten</h1>
    <p class="text-gray-500 mt-1"><%= @trainer.user.email %></p>
  </div>

  <%= render "form", trainer: @trainer %>
</div>
