<% content_for :title, @trainer.user.email %>

<div class="max-w-3xl mx-auto w-full px-4 mt-10 mb-16">

  <div class="mb-8">
    <%= link_to t('trainers.show.back'), trainers_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900 mt-3"><%= @trainer.user.email %></h1>
    <p class="text-gray-500 mt-1"><%= @trainer.phone.presence || t('trainers.show.no_phone') %></p>
  </div>

  <%# ── Persönliche Daten ───────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">Persönliche Daten</p>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div><dt class="text-gray-500">Name</dt><dd class="font-semibold text-gray-900"><%= @trainer.full_name %></dd></div>
      <div><dt class="text-gray-500">E-Mail</dt><dd class="font-semibold text-gray-900"><%= @trainer.user.email %></dd></div>
      <div><dt class="text-gray-500">Geburtsdatum</dt><dd class="font-semibold text-gray-900"><%= @trainer.date_of_birth&.strftime("%d.%m.%Y") || "–" %></dd></div>
      <div><dt class="text-gray-500">Geschlecht</dt><dd class="font-semibold text-gray-900"><%= @trainer.gender || "–" %></dd></div>
      <div><dt class="text-gray-500">Telefon</dt><dd class="font-semibold text-gray-900"><%= @trainer.phone || "–" %></dd></div>
      <div><dt class="text-gray-500">AHV-Nummer</dt><dd class="font-semibold font-mono text-gray-900"><%= @trainer.ahv_number || "–" %></dd></div>
    </dl>
  </div>

  <%# ── Adresse ─────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">Adresse</p>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div><dt class="text-gray-500">Strasse</dt><dd class="font-semibold text-gray-900"><%= [@trainer.street, @trainer.house_number].compact.join(" ").presence || "–" %></dd></div>
      <div><dt class="text-gray-500">PLZ / Ort</dt><dd class="font-semibold text-gray-900"><%= [@trainer.zip_code, @trainer.city].compact.join(" ").presence || "–" %></dd></div>
      <div><dt class="text-gray-500">Nationalität</dt><dd class="font-semibold text-gray-900"><%= @trainer.nationality || "–" %></dd></div>
      <div><dt class="text-gray-500">Muttersprache</dt><dd class="font-semibold text-gray-900"><%= @trainer.mother_tongue || "–" %></dd></div>
    </dl>
  </div>

  <%# ── J+S & Lohnangaben ───────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">J+S & Lohnangaben</p>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div><dt class="text-gray-500">J+S Personennummer</dt><dd class="font-semibold font-mono text-gray-900"><%= @trainer.js_person_number || "–" %></dd></div>
      <div><dt class="text-gray-500">J+S-Anerkennung</dt><dd class="font-semibold text-gray-900"><%= @trainer.js_anerkennung? ? "✓ Ja" : "Nein" %></dd></div>
      <div class="sm:col-span-2"><dt class="text-gray-500">IBAN</dt><dd class="font-semibold font-mono text-gray-900"><%= @trainer.iban || "–" %></dd></div>
    </dl>
  </div>

  <%# ── Zugewiesene Kurse (Übersicht) ──────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-bold text-gray-700"><%= t('trainers.show.assigned_courses') %></h2>
      <span class="text-xs font-semibold text-gray-400"><%= @trainer.courses.size %> <%= t('courses.index.title') %></span>
    </div>

    <% if @trainer.courses.any? %>
      <ul class="divide-y divide-gray-100">
        <% @trainer.courses.order(:title).each do |course| %>
          <li class="flex items-center justify-between px-5 py-3">
            <span class="text-sm font-medium text-gray-900"><%= course.title %></span>
            <span class="text-xs text-gray-400">
              <%= course.start_date&.strftime("%-d. %b %Y") %> – <%= course.end_date&.strftime("%-d. %b %Y") %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="px-5 py-6 text-sm text-gray-400 text-center"><%= t('trainers.show.no_courses') %></p>
    <% end %>
  </div>

  <%# ── Kurs-Zuweisung ──────────────────────────────────────────────────── %>
  <%= form_with model: @trainer, url: update_courses_trainer_path(@trainer), method: :post do |f| %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-4">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-bold text-gray-700"><%= t('trainers.show.assignment_title') %></h2>
        <p class="text-xs text-gray-400 mt-0.5"><%= t('trainers.show.assignment_hint') %></p>
      </div>

      <%# Sendet leeres Array wenn keine Checkboxen angekreuzt sind %>
      <input type="hidden" name="trainer[course_ids][]" value="">

      <div class="divide-y divide-gray-100">
        <% @courses_by_category.each do |category, courses| %>
          <div class="px-5 py-4">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3"><%= category %></p>
            <div class="space-y-2">
              <% courses.each do |course| %>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox"
                         name="trainer[course_ids][]"
                         value="<%= course.id %>"
                         <%= @trainer.course_ids.include?(course.id) ? "checked" : "" %>
                         class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer">
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-medium text-gray-900 group-hover:text-primary-700 transition"><%= course.title %></span>
                    <% if course.location.present? || course.start_date %>
                      <span class="ml-2 text-xs text-gray-400">
                        <%= course.location %>
                        <% if course.start_date && course.end_date %>
                          · <%= course.start_date.strftime("%-d. %b %Y") %> – <%= course.end_date.strftime("%-d. %b %Y") %>
                        <% end %>
                      </span>
                    <% end %>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center gap-3">
      <%= f.submit t('trainers.show.save_assignment'),
            class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
    </div>
  <% end %>

  <div class="flex flex-col sm:flex-row items-center gap-3 mt-3">
    <%= link_to t('trainers.show.edit_trainer'), edit_trainer_path(@trainer),
          class: "w-full sm:w-auto text-center rounded-lg px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition" %>
    <%= button_to t('trainers.show.delete_trainer'), @trainer, method: :delete,
          data: { turbo_confirm: t('trainers.show.delete_confirm', email: @trainer.user.email) },
          class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-white border border-red-200 text-red-600 hover:bg-red-50 text-sm font-medium cursor-pointer transition" %>
  </div>

</div>
