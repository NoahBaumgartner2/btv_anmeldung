<% content_for :title, t("pages.home.title") %>
<% content_for :full_width, true %>

<% cs = club_setting %>

<%# ══════════════════════════════════════════════════════════════════════════ %>
<%# Hero                                                                       %>
<%# ══════════════════════════════════════════════════════════════════════════ %>
<section class="bg-primary-600 text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">

    <% if cs.logo.attached? %>
      <%= image_tag cs.logo,
            class: "h-20 w-auto object-contain mx-auto mb-6 drop-shadow-md",
            alt: cs.club_name.presence || "Logo" %>
    <% end %>

    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 leading-tight">
      <%= cs.club_name.presence || t("pages.home.title") %>
    </h1>
    <p class="text-primary-100 text-lg sm:text-xl max-w-2xl mx-auto mb-10">
      <%= t("pages.home.hero.subtitle") %>
    </p>

    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <%= link_to t("pages.home.hero.register"), new_user_registration_path,
            class: "bg-white text-primary-700 font-bold px-7 py-3.5 rounded-xl shadow-md hover:bg-primary-50 transition text-base" %>
      <%= link_to t("nav.login"), new_user_session_path,
            class: "bg-primary-700 text-white font-bold px-7 py-3.5 rounded-xl border border-primary-400 hover:bg-primary-800 transition text-base" %>
    </div>
  </div>
</section>

<%# ══════════════════════════════════════════════════════════════════════════ %>
<%# So funktioniert's                                                           %>
<%# ══════════════════════════════════════════════════════════════════════════ %>
<section class="bg-white py-16 sm:py-20 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-2"><%= t("pages.home.how_it_works.title") %></h2>
      <p class="text-gray-500"><%= t("pages.home.how_it_works.subtitle") %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-4 gap-8">

      <%# Schritt 1 %>
      <div class="text-center">
        <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <div class="text-xs font-bold text-primary-600 uppercase tracking-wider mb-1"><%= t("pages.home.how_it_works.step1.label") %></div>
        <h3 class="font-bold text-gray-900 mb-2"><%= t("pages.home.how_it_works.step1.title") %></h3>
        <p class="text-sm text-gray-500 leading-relaxed"><%= t("pages.home.how_it_works.step1.body") %></p>
      </div>

      <%# Schritt 2 – Kursteilnehmer erfassen %>
      <div class="text-center">
        <div class="w-14 h-14 bg-secondary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
        </div>
        <div class="text-xs font-bold text-secondary-600 uppercase tracking-wider mb-1"><%= t("pages.home.how_it_works.step2.label") %></div>
        <h3 class="font-bold text-gray-900 mb-2"><%= t("pages.home.how_it_works.step2.title") %></h3>
        <p class="text-sm text-gray-500 leading-relaxed"><%= t("pages.home.how_it_works.step2.body") %></p>
      </div>

      <%# Schritt 3 %>
      <div class="text-center">
        <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <div class="text-xs font-bold text-primary-600 uppercase tracking-wider mb-1"><%= t("pages.home.how_it_works.step3.label") %></div>
        <h3 class="font-bold text-gray-900 mb-2"><%= t("pages.home.how_it_works.step3.title") %></h3>
        <p class="text-sm text-gray-500 leading-relaxed"><%= t("pages.home.how_it_works.step3.body") %></p>
      </div>

      <%# Schritt 4 %>
      <div class="text-center">
        <div class="w-14 h-14 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="text-xs font-bold text-green-600 uppercase tracking-wider mb-1"><%= t("pages.home.how_it_works.step4.label") %></div>
        <h3 class="font-bold text-gray-900 mb-2"><%= t("pages.home.how_it_works.step4.title") %></h3>
        <p class="text-sm text-gray-500 leading-relaxed"><%= t("pages.home.how_it_works.step4.body") %></p>
      </div>

    </div>

    <div class="text-center mt-12">
      <%= link_to t("pages.home.how_it_works.cta"), new_user_registration_path,
            class: "inline-block bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold px-8 py-3.5 rounded-xl shadow-sm transition text-sm min-h-11" %>
    </div>

  </div>
</section>

<%# ══════════════════════════════════════════════════════════════════════════ %>
<%# Kursübersicht                                                               %>
<%# ══════════════════════════════════════════════════════════════════════════ %>
<section class="bg-gray-50 py-16 sm:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-2"><%= t("pages.home.courses.title") %></h2>
      <p class="text-gray-500"><%= t("pages.home.courses.subtitle") %></p>
    </div>

    <% active_courses = @courses.select { |c| c.registration_mode == "single_session" || (c.end_date.nil? || c.end_date >= Date.today) } %>

    <% if active_courses.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% active_courses.each do |course| %>
          <%
            confirmed = course.course_registrations.count { |r| r.status == "bestätigt" }
            is_full   = course.max_participants.present? && confirmed >= course.max_participants
            is_single = course.registration_mode == "single_session"
            remaining = course.max_participants.present? ? (course.max_participants - confirmed) : nil
          %>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-200 flex flex-col overflow-hidden hover:shadow-md transition">

            <%# Farbstreifen oben %>
            <div class="h-1.5 bg-primary-600"></div>

            <div class="p-5 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-2 mb-3">
                <h3 class="font-bold text-gray-900 text-sm leading-snug"><%= course.title %></h3>
                <% if is_single %>
                  <span class="shrink-0 text-xs font-bold bg-secondary-100 text-secondary-700 px-2 py-0.5 rounded-full"><%= t("courses.index.status.drop_in") %></span>
                <% elsif is_full %>
                  <span class="shrink-0 text-xs font-bold bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full"><%= t("courses.index.status.full") %></span>
                <% end %>
              </div>

              <ul class="space-y-1.5 text-xs text-gray-500 mb-4 flex-1">
                <% if course.location.present? %>
                  <li class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <%= course.location %>
                  </li>
                <% end %>

                <% if is_single %>
                  <li class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= t("pages.home.courses.join_anytime") %>
                  </li>
                <% elsif course.start_date.present? %>
                  <li class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= course.start_date.strftime("%-d. %b %Y") %>
                    <% if course.end_date.present? %>– <%= course.end_date.strftime("%-d. %b %Y") %><% end %>
                  </li>
                <% end %>

                <li class="flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <%= course.price_display %>
                </li>

                <% if remaining.present? && !is_full %>
                  <li class="flex items-center gap-1.5 <%= remaining <= 3 ? 'text-orange-500 font-semibold' : '' %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 <%= remaining <= 3 ? 'text-orange-400' : 'text-gray-400' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <%= t("pages.home.courses.spots_free", count: remaining) %>
                  </li>
                <% end %>
              </ul>

              <%= link_to course_path(course),
                    class: "mt-auto block text-center text-xs font-bold py-2 px-4 rounded-lg transition
                            #{is_full ? 'bg-gray-100 text-gray-500 hover:bg-gray-200' : 'bg-primary-600 text-white hover:bg-primary-700'}" do %>
                <%= is_full ? t("pages.home.courses.view_full") : t("pages.home.courses.view_more") %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="text-center mt-8">
        <%= link_to t("pages.home.courses.view_all"), courses_path,
              class: "inline-block text-sm font-bold text-primary-600 hover:text-primary-800 transition" %>
      </div>

    <% else %>
      <div class="text-center py-16 bg-white rounded-2xl border border-gray-200">
        <p class="text-gray-500"><%= t("pages.home.courses.empty") %></p>
      </div>
    <% end %>

  </div>
</section>

<%# ══════════════════════════════════════════════════════════════════════════ %>
<%# Footer                                                                      %>
<%# ══════════════════════════════════════════════════════════════════════════ %>
<footer class="bg-gray-900 text-gray-400 py-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <% if cs.logo.attached? %>
      <%= image_tag cs.logo, class: "h-10 w-auto object-contain mx-auto mb-3 opacity-80", alt: cs.club_name.presence || "Logo" %>
    <% end %>
    <p class="font-bold text-white text-sm mb-1"><%= cs.club_name.presence || t("pages.home.footer.portal") %></p>
    <p class="text-xs mb-4"><%= t("pages.home.footer.tagline") %></p>
    <div class="flex justify-center gap-6 text-xs">
      <%= link_to t("nav.courses"), courses_path, class: "hover:text-white transition" %>
      <%= link_to t("nav.login"), new_user_session_path, class: "hover:text-white transition" %>
      <%= link_to t("nav.register"), new_user_registration_path, class: "hover:text-white transition" %>
    </div>
  </div>
</footer>
