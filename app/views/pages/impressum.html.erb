<% content_for :title, t("pages.impressum.title") %>
<% cs = club_setting %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8"><%= t("pages.impressum.title") %></h1>

  <% if user_signed_in? && current_user.admin? && cs.contact_email.blank? %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-800">
      <strong>Admin:</strong> <%= t("pages.impressum.admin_hint") %>
      <%= link_to t("pages.impressum.admin_hint_link"), edit_admin_club_setting_path, class: "underline font-semibold" %>
    </div>
  <% end %>

  <section class="mb-6">
    <h2 class="text-base font-semibold text-gray-700 mb-2"><%= t("pages.impressum.operator_title") %></h2>
    <div class="text-sm text-gray-700 space-y-1">
      <p class="font-semibold">
        <%= cs.club_name.presence || "—" %>
        <% if cs.legal_form.present? %><span class="font-normal text-gray-500">, <%= cs.legal_form %></span><% end %>
      </p>
      <% if cs.contact_street.present? %><p><%= cs.contact_street %></p><% end %>
      <% if cs.contact_zip.present? || cs.contact_city.present? %>
        <p><%= [cs.contact_zip, cs.contact_city].select(&:present?).join(" ") %>, Schweiz</p>
      <% end %>
    </div>
  </section>

  <% if cs.responsible_name.present? %>
    <section class="mb-6">
      <h2 class="text-base font-semibold text-gray-700 mb-2"><%= t("pages.impressum.responsible_title") %></h2>
      <div class="text-sm text-gray-700 space-y-1">
        <p><%= cs.responsible_name %></p>
        <% if cs.responsible_function.present? %>
          <p class="text-gray-500"><%= cs.responsible_function %></p>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="mb-6">
    <h2 class="text-base font-semibold text-gray-700 mb-2"><%= t("pages.impressum.contact_title") %></h2>
    <div class="text-sm text-gray-700 space-y-1">
      <% if cs.contact_email.present? %>
        <p>E-Mail: <a href="mailto:<%= cs.contact_email %>" class="text-primary-600 underline"><%= cs.contact_email %></a></p>
      <% end %>
      <% if cs.contact_phone.present? %><p><%= cs.contact_phone %></p><% end %>
      <% if cs.contact_website.present? %><p class="text-primary-600"><%= cs.contact_website %></p><% end %>
    </div>
  </section>

  <section class="mb-6">
    <h2 class="text-base font-semibold text-gray-700 mb-2"><%= t("pages.impressum.disclaimer_title") %></h2>
    <p class="text-sm text-gray-600"><%= t("pages.impressum.disclaimer_body") %></p>
  </section>

  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-2"><%= t("pages.impressum.privacy_section_title") %></h2>
    <p class="text-sm text-gray-600">
      <%= t("pages.impressum.privacy_body") %>
      <%= link_to t("pages.impressum.privacy_link"), privacy_path, class: "text-primary-600 underline" %>.
    </p>
  </section>
</div>
