<% content_for :title, t("course_registrations.edit.title") %>

<div class="max-w-2xl mx-auto w-full mt-10 px-4 mb-16">
  <div class="mb-6">
    <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900"><%= t("course_registrations.edit.title") %></h1>
    <p class="text-gray-500 mt-1"><%= t("course_registrations.edit.subtitle") %></p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= render "form",
          course_registration: @course_registration,
          selectable_courses: @selectable_courses,
          my_participants: @my_participants,
          course: @course %>
  </div>
</div>
