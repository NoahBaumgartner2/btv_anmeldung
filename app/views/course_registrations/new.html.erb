<% content_for :title, "Kursanmeldung" %>

<div class="max-w-2xl mx-auto w-full mt-10 px-4 mb-16">
  <div class="mb-6">
    <% if @course %>
      <%= link_to "← Zurück zum Kurs", course_path(@course),
            class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <% end %>
    <h1 class="font-extrabold text-3xl text-gray-900 mt-3">Kursanmeldung</h1>
    <% if @course %>
      <p class="text-gray-500 mt-1"><%= @course.registration_type %> – <%= @course.title %></p>
    <% end %>
  </div>

  <%# Termin-Info-Banner für Drop-In Anmeldungen %>
  <% if @training_session %>
    <div class="mb-5 bg-purple-50 border border-purple-200 rounded-2xl p-5 flex items-start gap-4">
      <div class="shrink-0 w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-2xl">📅</div>
      <div>
        <p class="text-xs font-bold text-purple-500 uppercase tracking-wider mb-1">Dein gewählter Termin</p>
        <p class="text-xl font-extrabold text-purple-900">
          <%= I18n.l(@training_session.start_time, format: "%A, %-d. %B %Y") %>
        </p>
        <p class="text-base font-semibold text-purple-700 mt-0.5">
          <%= @training_session.start_time.strftime("%H:%M") %> Uhr
          <% if @course&.location.present? %>
            <span class="text-purple-400 mx-1">·</span>
            <%= @course.location %>
          <% end %>
        </p>
      </div>
    </div>
  <% end %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= render "form",
          course_registration: @course_registration,
          selectable_courses: @selectable_courses,
          my_participants: @my_participants,
          course: @course,
          training_session: @training_session %>
  </div>
</div>
