<% primary = @_club&.effective_primary_color || "#dc2626" %>

<% badge_bg, badge_border, badge_text, badge_label = case @new_status
   when "bestätigt"  then ["#f0fdf4", "#bbf7d0", "#166534", "Anmeldung bestätigt"]
   when "storniert"  then ["#fef2f2", "#fecaca", "#991b1b", "Anmeldung storniert"]
   when "warteliste" then ["#fff7ed", "#fed7aa", "#9a3412", "Auf der Warteliste"]
   else                   ["#f9fafb", "#e5e7eb", "#374151", "Status aktualisiert"]
   end %>

<table width="100%" cellpadding="0" cellspacing="0" style="background:<%= badge_bg %>;border:1px solid <%= badge_border %>;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:<%= badge_text %>;font-family:Arial,Helvetica,sans-serif;"><%= badge_label %></p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= @recipient.email.split("@").first %>,<br><br>
  der Anmeldestatus von <strong><%= @participant.first_name %> <%= @participant.last_name %></strong> für den Kurs
  <strong><%= @course.title %></strong> wurde geändert.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:32px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Neuer Status</p>
      <p style="margin:0;font-size:16px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @new_status.capitalize %></p>
    </td>
  </tr>
</table>

<p style="margin:0 0 32px 0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Bei Fragen wende dich bitte direkt an uns.
</p>
