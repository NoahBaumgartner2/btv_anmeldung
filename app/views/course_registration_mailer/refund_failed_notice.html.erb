<table width="100%" cellpadding="0" cellspacing="0" style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:#991b1b;font-family:Arial,Helvetica,sans-serif;">Automatische Rückerstattung fehlgeschlagen</p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Die automatische Rückerstattung für <strong><%= @participant.first_name %> <%= @participant.last_name %></strong>
  (<%= @course.title %>) ist fehlgeschlagen. Bitte führe die Rückerstattung manuell im SumUp Dashboard durch.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Elternkontakt</p>
      <p style="margin:0 0 12px 0;font-size:16px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @parent&.email || "—" %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">SumUp Transaktions-ID</p>
      <p style="margin:0 0 12px 0;font-size:15px;font-family:monospace,Arial,Helvetica,sans-serif;color:#111827;"><%= @course_registration.sumup_transaction_id || "—" %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Fehlermeldung</p>
      <p style="margin:0;font-size:14px;color:#991b1b;font-family:Arial,Helvetica,sans-serif;white-space:pre-line;"><%= @error_message %></p>
    </td>
  </tr>
</table>

<p style="margin:0 0 32px 0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Melde dich bitte bei den Eltern (<%= @parent&.email || "—" %>) um die manuelle Rückerstattung zu koordinieren.
</p>
