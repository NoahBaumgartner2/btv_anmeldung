<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:#374151;font-family:Arial,Helvetica,sans-serif;">Abmeldung bestätigt</p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= @recipient.email.split("@").first %>,<br><br>
  Die Abmeldung von <strong><%= @participant.first_name %> <%= @participant.last_name %></strong> vom Kurs
  <strong><%= @course.title %></strong> wurde erfolgreich verarbeitet.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>
    </td>
  </tr>
</table>

<% if @course.has_payment? && @course_registration.payment_cleared? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:14px;color:#1e40af;font-family:Arial,Helvetica,sans-serif;">
          Du hast für diesen Kurs bereits bezahlt. Bei Fragen zu einer Rückerstattung wende dich bitte direkt an den Verein.
        </p>
      </td>
    </tr>
  </table>
<% end %>

<p style="margin:0 0 32px 0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Bei Fragen wende dich bitte direkt an uns.
</p>
