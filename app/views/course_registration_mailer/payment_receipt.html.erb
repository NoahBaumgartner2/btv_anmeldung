<% primary = @_club&.effective_primary_color || "#dc2626" %>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:#166534;font-family:Arial,Helvetica,sans-serif;">&#10003; Zahlung erfolgreich – Quittung</p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= @recipient.email.split("@").first %>,<br><br>
  die Zahlung für die Kursanmeldung von <strong><%= @participant.first_name %> <%= @participant.last_name %></strong>
  wurde erfolgreich verarbeitet. Diese E-Mail dient als Zahlungsbestätigung.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:20px;">

      <p style="margin:0 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 16px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0 0 16px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>

      <p style="margin:0 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kategorie</p>
      <p style="margin:0 0 16px 0;font-size:15px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.registration_type_label %></p>

      <% if @course.start_date.present? %>
        <p style="margin:0 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurszeitraum</p>
        <p style="margin:0 0 16px 0;font-size:15px;color:#111827;font-family:Arial,Helvetica,sans-serif;">
          <%= I18n.l(@course.start_date, format: :long) %><% if @course.end_date.present? %> – <%= I18n.l(@course.end_date, format: :long) %><% end %>
        </p>
      <% end %>

      <table width="100%" cellpadding="0" cellspacing="0" style="border-top:2px solid #e5e7eb;padding-top:16px;margin-top:4px;">
        <tr>
          <td style="font-size:14px;color:#6b7280;font-family:Arial,Helvetica,sans-serif;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:4px;">Bezahlter Betrag</td>
          <td style="text-align:right;">
            <span style="font-size:22px;font-weight:800;color:#166534;font-family:Arial,Helvetica,sans-serif;"><%= @course.price_display %></span>
          </td>
        </tr>
      </table>

      <p style="margin:12px 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Zahlungsdatum</p>
      <p style="margin:0 0 4px 0;font-size:15px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= I18n.l(@paid_at, format: :long) %></p>

      <% if @transaction_id.present? %>
        <p style="margin:12px 0 4px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Transaktions-ID</p>
        <p style="margin:0;font-size:13px;color:#6b7280;font-family:monospace;"><%= @transaction_id %></p>
      <% end %>

    </td>
  </tr>
</table>

<p style="margin:0 0 32px 0;font-size:13px;color:#6b7280;font-family:Arial,Helvetica,sans-serif;">
  Diese E-Mail dient als Zahlungsbestätigung und kann für Krankenkassen oder andere Stellen verwendet werden.
  Bei Fragen wende dich bitte direkt an uns.
</p>
