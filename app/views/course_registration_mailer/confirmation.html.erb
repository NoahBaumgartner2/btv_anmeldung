<% primary = @_club&.effective_primary_color || "#dc2626" %>

<% if @course_registration.status == "schnuppern" %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:15px;font-weight:600;color:#92400e;font-family:Arial,Helvetica,sans-serif;">Schnupperplatz gesichert!</p>
      </td>
    </tr>
  </table>
<% elsif @course_registration.status == "bestätigt" %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:15px;font-weight:600;color:#166534;font-family:Arial,Helvetica,sans-serif;">Anmeldung bestätigt!</p>
      </td>
    </tr>
  </table>
<% elsif @course_registration.status == "warteliste" %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:15px;font-weight:600;color:#9a3412;font-family:Arial,Helvetica,sans-serif;">Du stehst auf der Warteliste.</p>
      </td>
    </tr>
  </table>
<% else %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:15px;font-weight:600;color:#374151;font-family:Arial,Helvetica,sans-serif;">Anmeldung erhalten – wir bestätigen in Kürze.</p>
      </td>
    </tr>
  </table>
<% end %>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= greeting_name(@recipient) %>,<br><br>
  <% if @course_registration.status == "schnuppern" %>
    <%= @participant.first_name %> hat einen Schnupperplatz für 7 Tage gesichert. Danach ist eine reguläre Anmeldung nötig.
  <% elsif @course_registration.status == "bestätigt" %>
    die Anmeldung von <strong><%= @participant.first_name %> <%= @participant.last_name %></strong> wurde erfolgreich bestätigt.
  <% elsif @course_registration.status == "warteliste" %>
    der Kurs ist aktuell ausgebucht. Wir haben <strong><%= @participant.first_name %> <%= @participant.last_name %></strong> auf die Warteliste gesetzt und melden uns, sobald ein Platz frei wird.
  <% else %>
    wir haben die Anmeldung von <strong><%= @participant.first_name %> <%= @participant.last_name %></strong> erhalten und melden uns in Kürze.
  <% end %>
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:32px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>

      <% trainer_names = @course.trainers.map(&:full_name) %>
      <% if trainer_names.any? %>
        <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Leiter*in</p>
        <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= trainer_names.join(", ") %></p>
      <% end %>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Status</p>
      <p style="margin:0 <%= @course.has_payment? ? '0 12px 0' : '0' %>;font-size:16px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course_registration.status_label %></p>

      <% if @course.has_payment? && !%w[schnuppern warteliste].include?(@course_registration.status) %>
        <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Betrag</p>
        <p style="margin:0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.price_display %></p>
      <% end %>
    </td>
  </tr>
</table>

<p style="margin:0 0 24px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Bei einer Verhinderung bitten wir dich, dich von der Teilnahme am einzelnen Training auf der Plattform abzumelden.
  Für das Training sind Sportkleidung und ein Getränk mitzubringen. Das Training beginnt pünktlich zur angegebenen Zeit,
  bereits umgezogen am Kursort.
</p>

<% if @qr_code_base64.present? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
    <tr>
      <td style="text-align:center;padding:20px 0;">
        <p style="margin:0 0 12px 0;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">
          <%= @course_registration.status == "schnuppern" ? "Dein Schnupper-Ticket / QR-Code" : "Deine Eintrittskarte / QR-Code" %>
        </p>
        <img src="data:image/png;base64,<%= @qr_code_base64 %>"
             alt="QR-Code Ticket"
             width="200" height="200"
             style="display:inline-block;border:8px solid white;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.12);">
        <p style="margin:10px 0 0 0;font-size:12px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
          <%= @course_registration.status == "schnuppern" ? "Beim Einlass vorzeigen – gilt für deine Schnuppereinheit" : "Diesen QR-Code beim Einlass vorzeigen" %>
        </p>
      </td>
    </tr>
  </table>
<% end %>

<% if @course_registration.status == "schnuppern" && @trainer_contacts.present? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0 0 10px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kontakt zur Kursleitung</p>
        <% @trainer_contacts.each_with_index do |c, i| %>
          <% contact_links = [] %>
          <% contact_links << link_to(c[:email], "mailto:#{c[:email]}", style: "color:#{primary};text-decoration:underline;font-family:Arial,Helvetica,sans-serif;") if c[:email].present? %>
          <% contact_links << link_to(c[:phone], "tel:#{c[:phone]}", style: "color:#{primary};text-decoration:underline;font-family:Arial,Helvetica,sans-serif;") if c[:phone].present? %>
          <p style="margin:0 <%= i < @trainer_contacts.size - 1 ? '0 10px 0' : '0' %>;font-size:15px;color:#111827;font-family:Arial,Helvetica,sans-serif;">
            <strong><%= c[:name] %></strong>
            <% if contact_links.any? %>
              &nbsp;–&nbsp;<%= safe_join(contact_links, " &nbsp;·&nbsp; ".html_safe) %>
            <% end %>
          </p>
        <% end %>
      </td>
    </tr>
  </table>
<% end %>

<% if @course.email_note.present? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0 0 8px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Zusätzliche Informationen</p>
        <p style="margin:0;font-size:15px;color:#374151;white-space:pre-line;font-family:Arial,Helvetica,sans-serif;"><%= @course.email_note %></p>
      </td>
    </tr>
  </table>
<% end %>
