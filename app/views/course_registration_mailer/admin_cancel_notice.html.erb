<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:#374151;font-family:Arial,Helvetica,sans-serif;">Abmeldung erhalten</p>
    </td>
  </tr>
</table>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Teilnehmer</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @participant.first_name %> <%= @participant.last_name %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Kurs</p>
      <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>

      <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Eltern-E-Mail</p>
      <p style="margin:0 0 12px 0;font-size:16px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @parent&.email || "—" %></p>

      <% if @cancelled_by_trainer.present? %>
        <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-family:Arial,Helvetica,sans-serif;">Abgemeldet durch</p>
        <p style="margin:0;font-size:16px;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @cancelled_by_trainer %></p>
      <% end %>
    </td>
  </tr>
</table>

<% if @course_registration.payment_cleared? && @course.has_payment? %>
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;margin-bottom:24px;">
    <tr>
      <td style="padding:16px 20px;">
        <p style="margin:0;font-size:14px;color:#92400e;font-family:Arial,Helvetica,sans-serif;">
          Zahlung war erfolgt — eine allfällige Rückerstattung wird automatisch verarbeitet.
        </p>
      </td>
    </tr>
  </table>
<% end %>
