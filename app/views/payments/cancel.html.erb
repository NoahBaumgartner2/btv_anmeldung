<div class="max-w-md mx-auto mt-8 sm:mt-16 mb-16 text-center">

  <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-6">
    <svg class="w-10 h-10 sm:w-12 sm:h-12 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
    </svg>
  </div>

  <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-2 break-words"><%= t('payments.cancel.title') %></h1>
  <p class="text-gray-600 mb-8 text-sm sm:text-base px-2">
    <%= t('payments.cancel.subtitle') %>
  </p>

  <% if @registration %>
    <div class="flex flex-col gap-3">
      <%= link_to checkout_registration_path(@registration),
            class: "w-full inline-flex items-center justify-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-extrabold py-4 px-6 rounded-xl shadow-sm transition text-base min-h-[52px]" do %>
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
        <%= t('payments.cancel.retry') %>
      <% end %>
      <%= link_to course_registration_path(@registration),
            class: "w-full inline-flex items-center justify-center text-center text-gray-600 hover:text-gray-900 font-semibold text-sm py-3 min-h-[44px] transition" do %>
        <%= t('payments.cancel.back_to_registration') %>
      <% end %>
    </div>
  <% else %>
    <%= link_to root_path,
          class: "w-full inline-flex items-center justify-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-4 px-6 rounded-xl text-base transition min-h-[52px]" do %>
      <%= t('payments.cancel.to_home') %>
    <% end %>
  <% end %>

</div>
