<div class="max-w-md mx-auto mt-16 mb-16 px-4 text-center">

  <div class="w-16 h-16 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-6">
    <svg class="w-8 h-8 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </div>

  <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Zahlung abgebrochen</h1>
  <p class="text-gray-500 mb-8">
    Kein Problem — deine Anmeldung wurde gespeichert. Du kannst die Zahlung jederzeit nachholen.
  </p>

  <% if @registration %>
    <div class="flex flex-col gap-3 max-w-xs mx-auto">
      <%= link_to checkout_registration_path(@registration),
            class: "flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-xl shadow-sm transition text-sm" do %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
        Jetzt bezahlen
      <% end %>
      <%= link_to course_registration_path(@registration),
            class: "text-center text-gray-500 hover:text-gray-700 font-medium text-sm py-2 transition" do %>
        Später bezahlen
      <% end %>
    </div>
  <% else %>
    <%= link_to root_path,
          class: "inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-xl text-sm transition" do %>
      Zur Startseite
    <% end %>
  <% end %>

</div>
