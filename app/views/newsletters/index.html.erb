<div class="max-w-5xl mx-auto mt-8 mb-16 px-4">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-1">Admin</p>
      <h1 class="text-3xl font-extrabold text-gray-900">Mailing-Zentrale</h1>
    </div>
    <div class="flex gap-3 flex-wrap">
      <%= link_to "Empfängerliste", newsletter_subscribers_path,
            class: "bg-white border border-gray-300 text-gray-700 font-bold text-sm py-2.5 px-4 rounded-lg hover:bg-gray-50 transition" %>
      <%= link_to "+ Neuer Newsletter", new_newsletter_path,
            class: "bg-primary-600 hover:bg-primary-700 text-white font-bold text-sm py-2.5 px-5 rounded-lg transition" %>
    </div>
  </div>

  <%# ── Stats ────────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-gray-900"><%= Newsletter.count %></p>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mt-0.5">Total</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-amber-500"><%= Newsletter.drafts.count %></p>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mt-0.5">Entwürfe</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-green-600"><%= Newsletter.sent.count %></p>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mt-0.5">Versendet</p>
    </div>
  </div>

  <%# ── Entwürfe ──────────────────────────────────────────────────────────── %>
  <% if @drafts.any? %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden mb-6">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-bold text-gray-900">Entwürfe</h2>
      </div>
      <ul class="divide-y divide-gray-50">
        <% @drafts.each do |nl| %>
          <li class="px-5 py-4 flex items-center justify-between gap-4 hover:bg-gray-50 transition">
            <div class="min-w-0">
              <p class="font-bold text-gray-900 truncate"><%= nl.title %></p>
              <p class="text-sm text-gray-500 truncate">Betreff: <%= nl.subject %></p>
              <p class="text-xs text-gray-400 mt-0.5">Zuletzt bearbeitet: <%= nl.updated_at.strftime("%-d. %B %Y, %H:%M") %></p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-xs font-bold bg-amber-100 text-amber-700 px-2.5 py-1 rounded-full">Entwurf</span>
              <%= link_to "Bearbeiten", edit_newsletter_path(nl),
                    class: "text-sm font-bold text-primary-600 hover:text-primary-800 bg-primary-50 hover:bg-primary-100 px-3 py-1.5 rounded-lg transition" %>
              <%= button_to "Löschen", newsletter_path(nl), method: :delete,
                    data: { turbo_confirm: "\"#{nl.title}\" wirklich löschen?" },
                    class: "text-sm font-bold text-red-600 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition cursor-pointer" %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Versendete Newsletter ───────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="font-bold text-gray-900">Versendet</h2>
    </div>
    <% if @sent.any? %>
      <ul class="divide-y divide-gray-50">
        <% @sent.each do |nl| %>
          <li class="px-5 py-4 flex items-center justify-between gap-4 hover:bg-gray-50 transition">
            <div class="min-w-0">
              <p class="font-bold text-gray-900 truncate"><%= nl.title %></p>
              <p class="text-sm text-gray-500 truncate">Betreff: <%= nl.subject %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                Versendet: <%= nl.sent_at&.strftime("%-d. %B %Y, %H:%M") %>
                · <%= nl.recipients_count %> Empfänger
              </p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-xs font-bold bg-green-100 text-green-700 px-2.5 py-1 rounded-full">Versendet</span>
              <%= link_to "Vorschau", preview_newsletter_path(nl),
                    class: "text-sm font-bold text-gray-600 hover:text-gray-800 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-lg transition" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="py-12 text-center">
        <p class="text-gray-400 text-sm font-medium">Noch kein Newsletter versendet.</p>
      </div>
    <% end %>
  </div>

</div>
