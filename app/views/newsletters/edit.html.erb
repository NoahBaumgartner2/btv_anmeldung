<div class="max-w-6xl mx-auto mt-8 mb-16 px-4">
  <div class="mb-6 flex items-start justify-between flex-wrap gap-3">
    <div>
      <%= link_to t('newsletters.edit.back'), newsletters_path,
            class: "text-sm font-semibold text-gray-400 hover:text-gray-700 transition" %>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= @newsletter.title %></h1>
      <p class="text-sm text-gray-400 mt-0.5">
        <%= t('newsletters.edit.last_edited_prefix') %> <%= @newsletter.updated_at.strftime("%-d. %B %Y, %H:%M") %>
      </p>
    </div>
    <% if @newsletter.draft? %>
      <span class="mt-6 inline-block text-xs font-bold bg-amber-100 text-amber-700 px-3 py-1.5 rounded-full"><%= t('newsletters.edit.badge_draft') %></span>
    <% end %>
  </div>

  <%= render "form", newsletter: @newsletter %>

</div>
