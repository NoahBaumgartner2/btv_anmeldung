<% if newsletter.errors.any? %>
  <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-6 text-sm text-red-700">
    <%= newsletter.errors.full_messages.first %>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

  <%# ── Linke Spalte: Meta + Aktionen ──────────────────────────────────── %>
  <div class="lg:col-span-2 space-y-4">

    <%# Speichern-Formular (eigenständig, kein Nesting) %>
    <%= form_with model: newsletter do |f| %>
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="font-bold text-gray-900 border-b border-gray-100 pb-3"><%= t('newsletters.form.section_settings') %></h2>

        <div>
          <%= f.label :title, t('newsletters.form.label_title'), class: "block text-xs font-bold text-gray-600 mb-1" %>
          <%= f.text_field :title, placeholder: "z.B. Sommer-Newsletter 2026",
                autocomplete: "off",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-500 focus:outline-none" %>
          <p class="text-xs text-gray-400 mt-1"><%= t('newsletters.form.title_hint') %></p>
        </div>

        <div>
          <%= f.label :subject, t('newsletters.form.label_subject'), class: "block text-xs font-bold text-gray-600 mb-1" %>
          <%= f.text_field :subject, placeholder: "z.B. Neue Kurse im Herbst!",
                autocomplete: "off",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary-500 focus:outline-none" %>
        </div>

        <div class="pt-1">
          <%= f.hidden_field :body_html, id: "newsletter_body_html" %>
          <%= f.submit newsletter.new_record? ? t('newsletters.form.save_draft') : t('newsletters.form.save_changes'),
                id: "save-btn",
                class: "cursor-pointer w-full bg-gray-800 hover:bg-gray-900 text-white font-bold text-sm py-3 rounded-xl transition" %>
        </div>
      </div>
    <% end %>

    <%# Versenden (eigenständiges button_to — kein Nesting) %>
    <% if newsletter.persisted? && newsletter.draft? %>
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
        <h2 class="font-bold text-gray-900 mb-1"><%= t('newsletters.form.section_send') %></h2>
        <p class="text-xs text-gray-500 mb-4">
          <%= t('newsletters.form.send_description', count: NewsletterSubscriber.subscribed.count) %>
        </p>
        <%= button_to t('newsletters.form.send_btn'),
              send_newsletter_newsletter_path(newsletter),
              method: :post,
              data: { turbo_confirm: t('newsletters.form.send_confirm') },
              class: "cursor-pointer w-full bg-primary-600 hover:bg-primary-700 text-white font-bold text-sm py-3 rounded-xl transition" %>
      </div>
    <% end %>

    <%# Vorschau %>
    <% if newsletter.persisted? %>
      <a href="<%= preview_newsletter_path(newsletter) %>" target="_blank"
         class="flex items-center justify-center gap-2 w-full bg-white border border-gray-200 hover:bg-gray-50 text-gray-600 font-bold text-sm py-3 rounded-xl transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        <%= t('newsletters.form.preview_btn') %>
      </a>
    <% end %>

  </div>

  <%# ── Rechte Spalte: Editor ────────────────────────────────────────── %>
  <div class="lg:col-span-3">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">

      <%# Tab-Leiste %>
      <div class="flex border-b border-gray-200 bg-gray-50">
        <button type="button" id="tab-designer"
                class="tab-btn flex-1 py-3 text-sm font-bold text-primary-600 border-b-2 border-primary-600 bg-white transition">
          <%= t('newsletters.form.tab_designer') %>
        </button>
        <button type="button" id="tab-html"
                class="tab-btn flex-1 py-3 text-sm font-bold text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition">
          <%= t('newsletters.form.tab_html') %>
        </button>
      </div>

      <%# Designer-Tab %>
      <div id="panel-designer">

        <%# Formatierungs-Toolbar %>
        <div class="flex flex-wrap items-center gap-1 px-3 py-2 border-b border-gray-100 bg-gray-50">
          <% [
            ["B",  "bold",        "font-bold"],
            ["I",  "italic",      "italic"],
            ["U",  "underline",   "underline"],
          ].each do |label, cmd, cls| %>
            <button type="button" data-fmt="<%= cmd %>"
                    class="w-8 h-8 rounded-lg hover:bg-gray-200 text-gray-700 text-sm font-mono <%= cls %> transition flex items-center justify-center">
              <%= label %>
            </button>
          <% end %>
          <div class="w-px h-5 bg-gray-200 mx-1"></div>
          <% [["H1","h1"],["H2","h2"],["H3","h3"]].each do |label, tag| %>
            <button type="button" data-fmt-block="<%= tag %>"
                    class="px-2.5 h-8 rounded-lg hover:bg-gray-200 text-gray-600 text-xs font-bold transition">
              <%= label %>
            </button>
          <% end %>
          <div class="w-px h-5 bg-gray-200 mx-1"></div>
          <button type="button" data-fmt-block="p"
                  class="px-2.5 h-8 rounded-lg hover:bg-gray-200 text-gray-600 text-xs font-bold transition">
            P
          </button>
          <button type="button" id="btn-insert-link"
                  class="px-2.5 h-8 rounded-lg hover:bg-gray-200 text-gray-600 text-xs font-bold transition">
            Link
          </button>
          <div class="w-px h-5 bg-gray-200 mx-1"></div>
          <button type="button" data-fmt="insertUnorderedList"
                  class="px-2.5 h-8 rounded-lg hover:bg-gray-200 text-gray-600 text-xs font-bold transition">
            <%= t('newsletters.form.toolbar_list') %>
          </button>
          <div class="ml-auto flex items-center gap-1">
            <label class="text-xs text-gray-500 font-medium"><%= t('newsletters.form.toolbar_color') %></label>
            <input type="color" id="color-picker"
                   autocomplete="off"
                   class="w-7 h-7 rounded cursor-pointer border border-gray-200" value="#111827">
          </div>
        </div>

        <%# Editierbarer Bereich %>
        <div id="editor-area"
             contenteditable="true"
             class="min-h-96 p-5 text-sm text-gray-800 leading-relaxed focus:outline-none"
             style="font-family: Arial, sans-serif;">
          <%= newsletter.body_html.present? ? sanitize(newsletter.body_html) : sanitize("<p>#{t('newsletters.form.editor_placeholder')}</p>") %>
        </div>
      </div>

      <%# HTML-Import-Tab %>
      <div id="panel-html" class="hidden">
        <div class="px-5 py-3 bg-amber-50 border-b border-amber-100">
          <p class="text-xs text-amber-800 font-medium">
            Füge rohen HTML-Code ein. Der Inhalt wird direkt in der E-Mail verwendet.
          </p>
        </div>
        <textarea id="html-import-area"
                  rows="20"
                  placeholder="&lt;!-- HTML hier einfügen --&gt;&#10;&lt;h1&gt;Hallo!&lt;/h1&gt;&#10;&lt;p&gt;Willkommen zu unserem Newsletter.&lt;/p&gt;"
                  class="block w-full px-5 py-4 text-sm font-mono text-gray-800 focus:outline-none resize-none border-0"
        ><%= newsletter.body_html.present? ? newsletter.body_html : "" %></textarea>
      </div>

    </div>
  </div>

</div>

<script nonce="<%= content_security_policy_nonce %>">
  let activeTab = "designer";

  function switchTab(tab) {
    activeTab = tab;
    const isDesigner = tab === "designer";

    document.getElementById("panel-designer").classList.toggle("hidden", !isDesigner);
    document.getElementById("panel-html").classList.toggle("hidden", isDesigner);

    document.getElementById("tab-designer").className =
      isDesigner
        ? "tab-btn flex-1 py-3 text-sm font-bold text-primary-600 border-b-2 border-primary-600 bg-white transition"
        : "tab-btn flex-1 py-3 text-sm font-bold text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition";
    document.getElementById("tab-html").className =
      !isDesigner
        ? "tab-btn flex-1 py-3 text-sm font-bold text-primary-600 border-b-2 border-primary-600 bg-white transition"
        : "tab-btn flex-1 py-3 text-sm font-bold text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition";

    if (!isDesigner) {
      document.getElementById("html-import-area").value =
        document.getElementById("editor-area").innerHTML;
    } else {
      document.getElementById("editor-area").innerHTML =
        document.getElementById("html-import-area").value;
    }
  }

  function fmt(cmd, value) {
    document.getElementById("editor-area").focus();
    document.execCommand(cmd, false, value ?? null);
  }

  function fmtBlock(tag) {
    document.getElementById("editor-area").focus();
    document.execCommand("formatBlock", false, tag);
  }

  function insertLink() {
    const url = prompt("URL eingeben:");
    if (url) {
      document.getElementById("editor-area").focus();
      document.execCommand("createLink", false, url);
    }
  }

  // Tab-Buttons
  document.getElementById("tab-designer").addEventListener("click", () => switchTab("designer"));
  document.getElementById("tab-html").addEventListener("click", () => switchTab("html"));

  // Toolbar: fmt-Buttons (bold, italic, underline, insertUnorderedList)
  document.querySelectorAll("[data-fmt]").forEach(btn => {
    btn.addEventListener("click", () => fmt(btn.dataset.fmt));
  });

  // Toolbar: fmtBlock-Buttons (h1, h2, h3, p)
  document.querySelectorAll("[data-fmt-block]").forEach(btn => {
    btn.addEventListener("click", () => fmtBlock(btn.dataset.fmtBlock));
  });

  // Link-Button
  document.getElementById("btn-insert-link").addEventListener("click", insertLink);

  // Farbwähler
  document.getElementById("color-picker").addEventListener("change", function() {
    fmt("foreColor", this.value);
  });

  // Vor dem Absenden: aktuellen HTML-Inhalt in das hidden field schreiben
  document.getElementById("save-btn").closest("form").addEventListener("submit", function() {
    const html = activeTab === "designer"
      ? document.getElementById("editor-area").innerHTML
      : document.getElementById("html-import-area").value;
    document.getElementById("newsletter_body_html").value = html;
  });
</script>
