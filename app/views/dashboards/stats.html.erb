<%
  now = Time.current
  total_recorded = @present_count + @absent_count
  global_rate = total_recorded > 0 ? (@present_count * 100.0 / total_recorded).round(1) : nil

  # Hilfsmethode: Anwesenheitsrate für eine Liste von Attendances
  def attendance_rate(attendances)
    relevant = attendances.reject { |a| a.status == "abgemeldet" || a.status.nil? }
    return nil if relevant.empty?
    present = relevant.count { |a| a.status == "anwesend" }
    (present * 100.0 / relevant.size).round(1)
  end
%>

<div class="max-w-7xl mx-auto mt-6 sm:mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-6 sm:mb-8 gap-4">
    <div>
      <%= link_to t('dashboards.stats.back'), dashboards_admin_path,
            class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition min-h-11 inline-flex items-center" %>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-gray-900 mt-1 sm:mt-2"><%= t('dashboards.stats.title') %></h1>
      <p class="text-gray-500 mt-1 text-sm sm:text-base"><%= t('dashboards.stats.subtitle') %></p>
    </div>
  </div>

  <%# ── Globale Kennzahlen ─────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 sm:gap-4 mb-8 sm:mb-10">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_sessions_total') %></p>
      <p class="text-3xl font-extrabold text-gray-900"><%= @total_sessions %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_past') %></p>
      <p class="text-3xl font-extrabold text-gray-900"><%= @past_sessions %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_cancelled') %></p>
      <p class="text-3xl font-extrabold text-orange-500"><%= @canceled_sessions %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_present') %></p>
      <p class="text-3xl font-extrabold text-green-600"><%= @present_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_absent') %></p>
      <p class="text-3xl font-extrabold text-red-500"><%= @absent_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= t('dashboards.stats.metric_avg_attendance') %></p>
      <p class="text-3xl font-extrabold <%= global_rate && global_rate >= 75 ? "text-green-600" : global_rate ? "text-yellow-500" : "text-gray-400" %>">
        <%= global_rate ? "#{global_rate}%" : "—" %>
      </p>
    </div>
  </div>

  <%# ── Kurs-Filter ────────────────────────────────────────────────────────── %>
  <%
    selected_count = @selected_course_ids.size
    filter_label = selected_count == 0 ? t('dashboards.stats.all_courses') : t('dashboards.stats.courses_selected', count: selected_count)
  %>
  <%= form_with url: dashboards_stats_path, method: :get, class: "mb-6" do |f| %>
    <details id="course-filter-dropdown" class="relative group inline-block w-full sm:w-auto" <%= "open" if selected_count > 0 %>>
      <summary class="flex items-center justify-between gap-3 px-4 py-2.5 bg-white border border-gray-300 rounded-xl cursor-pointer select-none hover:border-primary-400 transition text-sm font-semibold text-gray-700 min-w-[220px] min-h-11 list-none [&::-webkit-details-marker]:hidden">
        <span class="flex items-center gap-2">
          <svg class="h-4 w-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
          </svg>
          <%= filter_label %>
        </span>
        <svg class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>

      <div class="absolute left-0 top-full mt-1.5 z-30 bg-white border border-gray-200 rounded-xl shadow-lg w-72 overflow-hidden">
        <%# Alle auswählen / keine %>
        <div class="px-4 py-2.5 border-b border-gray-100 flex items-center justify-between">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t('dashboards.stats.filter_title') %></p>
          <% if selected_count > 0 %>
            <%= link_to t('dashboards.stats.show_all'), dashboards_stats_path,
                  class: "text-xs font-semibold text-primary-600 hover:text-primary-800 transition" %>
          <% end %>
        </div>

        <div class="max-h-72 overflow-y-auto divide-y divide-gray-50 py-1">
          <% @courses.each do |course| %>
            <label class="flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer transition min-h-11">
              <%= f.check_box :course_ids,
                    { multiple: true,
                      checked: @selected_course_ids.include?(course.id),
                      id: "course_filter_#{course.id}" },
                    course.id.to_s, nil %>
              <span class="text-sm text-gray-700 leading-tight"><%= course.title %></span>
            </label>
          <% end %>
        </div>

        <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
          <%= f.submit t('dashboards.stats.apply'),
                class: "w-full bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2 px-4 rounded-lg text-sm transition cursor-pointer min-h-11" %>
        </div>
      </div>
    </details>
  <% end %>

  <%# ── Kurs-Sektionen ─────────────────────────────────────────────────────── %>
  <% filtered_courses = @selected_course_ids.any? ? @courses.select { |c| @selected_course_ids.include?(c.id) } : @courses %>

  <% if filtered_courses.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center text-gray-400 text-sm">
      <%= t('dashboards.stats.no_courses') %>
    </div>
  <% end %>

  <% filtered_courses.each do |course| %>
    <%
      sessions = course.training_sessions.sort_by(&:start_time)
      past_sessions = sessions.select { |s| s.start_time < now }
      upcoming_sessions = sessions.select { |s| s.start_time >= now }
      canceled = sessions.count(&:is_canceled?)
      all_course_attendances = sessions.flat_map(&:attendances)
      course_rate = attendance_rate(all_course_attendances)
      sessions_without_record = past_sessions.reject { |s| s.is_canceled? || s.attendances.reject { |a| a.status.nil? }.any? }
      registrations = course.course_registrations
    %>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-8 overflow-hidden">

      <%# Kurs-Header %>
      <div class="px-4 sm:px-6 py-4 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-extrabold text-gray-900"><%= course.title %></h2>
          <p class="text-xs text-gray-400 mt-0.5">
            <% if course.start_date && course.end_date %>
              <%= course.start_date.strftime("%-d. %b %Y") %> – <%= course.end_date.strftime("%-d. %b %Y") %>
            <% else %>
              <%= t('dashboards.stats.no_period') %>
            <% end %>
            <% if course.location.present? %>· <%= course.location %><% end %>
          </p>
          <% if course.trainers.any? %>
            <p class="text-xs text-gray-400 mt-1">
              <%= course.trainers.filter_map { |trainer| trainer.user&.email }.join(", ") %>
            </p>
          <% end %>
        </div>
        <%= link_to t('dashboards.stats.manage_link'), manage_course_path(course),
              class: "shrink-0 text-sm font-bold text-primary-600 hover:text-primary-800 bg-primary-50 px-3 py-1.5 rounded-lg transition" %>
      </div>

      <%# Kurs-Kennzahlen %>
      <div class="grid grid-cols-2 sm:grid-cols-5 divide-y sm:divide-y-0 divide-gray-100 border-b border-gray-100">
        <div class="px-3 sm:px-5 py-3 border-r border-gray-100">
          <p class="text-xs font-semibold text-gray-400 mb-0.5"><%= t('dashboards.stats.metric_sessions') %></p>
          <p class="text-lg sm:text-xl font-extrabold text-gray-900"><%= sessions.size %></p>
          <p class="text-xs text-gray-400"><%= past_sessions.size %> verg. &middot; <%= upcoming_sessions.size %> bev.</p>
        </div>
        <div class="px-3 sm:px-5 py-3">
          <p class="text-xs font-semibold text-gray-400 mb-0.5"><%= t('dashboards.stats.metric_cancelled') %></p>
          <p class="text-lg sm:text-xl font-extrabold <%= canceled > 0 ? "text-orange-500" : "text-gray-400" %>"><%= canceled %></p>
        </div>
        <div class="px-3 sm:px-5 py-3 border-r border-gray-100 sm:border-r-0">
          <p class="text-xs font-semibold text-gray-400 mb-0.5"><%= t('dashboards.stats.metric_registered') %></p>
          <p class="text-lg sm:text-xl font-extrabold text-gray-900"><%= registrations.size %></p>
        </div>
        <div class="px-3 sm:px-5 py-3">
          <p class="text-xs font-semibold text-gray-400 mb-0.5"><%= t('dashboards.stats.metric_avg_short') %></p>
          <p class="text-lg sm:text-xl font-extrabold <%= course_rate && course_rate >= 75 ? "text-green-600" : course_rate ? "text-yellow-500" : "text-gray-400" %>">
            <%= course_rate ? "#{course_rate}%" : "&mdash;".html_safe %>
          </p>
        </div>
        <div class="col-span-2 sm:col-span-1 px-3 sm:px-5 py-3">
          <p class="text-xs font-semibold text-gray-400 mb-0.5"><%= t('dashboards.stats.metric_not_recorded') %></p>
          <p class="text-lg sm:text-xl font-extrabold <%= sessions_without_record.any? ? "text-red-500" : "text-gray-400" %>">
            <%= sessions_without_record.size %>
          </p>
          <p class="text-xs text-gray-400"><%= t('dashboards.stats.metric_past_no_entry') %></p>
        </div>
      </div>

      <%# Session-Tabelle (auf-/zuklappbar) %>
      <details class="group">
        <summary class="flex items-center justify-between px-4 sm:px-6 py-3 cursor-pointer select-none border-t border-gray-100 hover:bg-gray-50 active:bg-gray-100 transition list-none min-h-11">
          <span class="text-sm font-bold text-gray-600">
            <%= t('dashboards.stats.sessions_header', count: sessions.size) %>
            <% if sessions_without_record.any? %>
              <span class="ml-2 text-xs font-bold text-red-500"><%= t('dashboards.stats.without_recording', count: sessions_without_record.size) %></span>
            <% end %>
          </span>
          <svg class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>

        <% if sessions.any? %>
          <div class="overflow-x-auto border-t border-gray-100">
            <table class="min-w-full divide-y divide-gray-100">
              <thead class="bg-gray-50">
                <tr>
                  <th class="py-2.5 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_date') %></th>
                  <th class="py-2.5 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_time') %></th>
                  <th class="py-2.5 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_status') %></th>
                  <th class="py-2.5 px-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_present') %></th>
                  <th class="py-2.5 px-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_absent') %></th>
                  <th class="py-2.5 px-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_excused') %></th>
                  <th class="py-2.5 px-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('dashboards.stats.col_recording') %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% sessions.each do |session| %>
                  <%
                    atts = session.attendances
                    s_present  = atts.count { |a| a.status == "anwesend" }
                    s_absent   = atts.count { |a| a.status == "abwesend" }
                    s_excused  = atts.count { |a| a.status == "abgemeldet" }
                    is_past    = session.start_time < now
                    recorded   = session.attendance_recorded?
                    s_rate     = attendance_rate(atts)
                  %>
                  <tr class="<%= session.is_canceled? ? "bg-orange-50" : is_past && !recorded ? "bg-red-50" : "hover:bg-gray-50" %> transition">
                    <td class="py-3 px-4 text-sm font-semibold text-gray-800">
                      <%= session.start_time.strftime("%a, %-d. %b %Y") %>
                    </td>
                    <td class="py-3 px-4 text-sm text-gray-600">
                      <%= session.start_time.strftime("%H:%M") %>
                      <% if session.end_time %>
                        – <%= session.end_time.strftime("%H:%M") %>
                      <% end %>
                    </td>
                    <td class="py-3 px-4 text-sm">
                      <% if session.is_canceled? %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-orange-100 text-orange-700"><%= t('dashboards.stats.status_cancelled') %></span>
                      <% elsif !is_past %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-primary-100 text-primary-700"><%= t('dashboards.stats.status_upcoming') %></span>
                      <% elsif recorded %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700"><%= t('dashboards.stats.status_recorded') %></span>
                      <% else %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-700"><%= t('dashboards.stats.status_missing') %></span>
                      <% end %>
                    </td>
                    <td class="py-3 px-4 text-center text-sm font-bold text-green-700">
                      <%= s_present > 0 ? s_present : (session.is_canceled? || !is_past ? "—" : "0") %>
                    </td>
                    <td class="py-3 px-4 text-center text-sm font-bold text-red-600">
                      <%= s_absent > 0 ? s_absent : (session.is_canceled? || !is_past ? "—" : "0") %>
                    </td>
                    <td class="py-3 px-4 text-center text-sm text-gray-500">
                      <%= s_excused > 0 ? s_excused : "—" %>
                    </td>
                    <td class="py-3 px-4 text-center text-sm">
                      <% if s_rate %>
                        <span class="font-bold <%= s_rate >= 75 ? "text-green-600" : "text-yellow-600" %>"><%= s_rate %>%</span>
                      <% else %>
                        <span class="text-gray-300">—</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center text-sm text-gray-400 border-t border-gray-100">
            <%= t('dashboards.stats.no_sessions') %>
          </div>
        <% end %>
      </details>
    </div>
  <% end %>

</div>
