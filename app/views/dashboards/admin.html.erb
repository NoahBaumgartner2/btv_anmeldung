<div class="max-w-7xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h1 class="text-4xl font-extrabold text-gray-900">Kommandozentrale</h1>
      <p class="text-gray-500 mt-2">Willkommen, Boss! Hier steuerst du den gesamten Verein.</p>
    </div>
    <%= link_to new_course_path,
          class: "shrink-0 inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Neuer Kurs
    <% end %>
  </div>

  <%# ── Schnellzugriff ──────────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">

    <%# Gruppe: Verwaltung %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Verwaltung</p>
      </div>
      <div class="divide-y divide-gray-50">
        <%= link_to trainers_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-blue-50 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-blue-100 group-hover:bg-blue-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5-3.87M9 20H4v-2a4 4 0 015-3.87m6-4.13a4 4 0 10-8 0 4 4 0 008 0z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-blue-700 transition">Trainer</p>
            <p class="text-xs text-gray-400 truncate">Trainer verwalten &amp; zuweisen</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-blue-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <%= link_to holidays_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-yellow-50 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-yellow-100 group-hover:bg-yellow-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-yellow-700 transition">Ferientage</p>
            <p class="text-xs text-gray-400 truncate">Sperrdaten konfigurieren</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-yellow-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <%# Gruppe: Kommunikation & Auswertung %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Kommunikation</p>
      </div>
      <div class="divide-y divide-gray-50">
        <%= link_to newsletters_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-purple-50 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-purple-100 group-hover:bg-purple-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-purple-700 transition">Mailing-Zentrale</p>
            <p class="text-xs text-gray-400 truncate">Newsletter erstellen &amp; versenden</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-purple-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <%= link_to dashboards_stats_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-green-50 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-green-100 group-hover:bg-green-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-green-700 transition">Statistiken</p>
            <p class="text-xs text-gray-400 truncate">Auswertungen &amp; Berichte</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-green-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <%# Gruppe: Konfiguration %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Konfiguration</p>
      </div>
      <div class="divide-y divide-gray-50">
        <%= link_to mail_setting_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-gray-100 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-gray-100 group-hover:bg-gray-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-gray-900 transition">E-Mail-Einstellungen</p>
            <p class="text-xs text-gray-400 truncate">SMTP &amp; Absender konfigurieren</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-gray-500 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <%= link_to admin_payment_setting_path,
              class: "group flex items-center gap-3.5 px-4 py-3.5 hover:bg-indigo-50 transition" do %>
          <div class="shrink-0 w-9 h-9 rounded-xl bg-indigo-100 group-hover:bg-indigo-200 flex items-center justify-center transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800 group-hover:text-indigo-700 transition">Zahlungen</p>
            <p class="text-xs text-gray-400 truncate">Stripe &amp; Payment-Setup</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-indigo-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

  </div>

  <%# ── Kurs-Tabelle ────────────────────────────────────────────────────── %>
  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-xl overflow-hidden mb-16">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase">Kurs</th>
          <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase">Kategorie</th>
          <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase">Anmeldungen</th>
          <th class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase">Aktion</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @courses.each do |course| %>
          <tr class="hover:bg-gray-50">
            <td class="py-4 px-4 font-bold text-gray-900 text-sm"><%= course.title %></td>
            <td class="py-4 px-4 text-sm text-gray-500"><%= course.registration_type %></td>
            <td class="py-4 px-4 text-sm font-medium text-blue-600"><%= course.course_registrations.size %> Teilnehmende</td>
            <td class="py-4 px-4 text-right">
              <%= link_to "Verwalten", manage_course_path(course), class: "text-red-600 font-bold hover:text-red-800 bg-red-50 px-3 py-1.5 rounded-md text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ── Teilnehmer-Suche ────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-5 gap-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Teilnehmer-Suche</h2>
      <p class="text-gray-500 mt-1 text-sm">Suche nach Name oder E-Mail-Adresse des verknüpften Kontos.</p>
    </div>
    <button disabled class="shrink-0 bg-gray-100 text-gray-400 py-2 px-4 rounded-lg shadow-sm font-bold border border-gray-200 cursor-not-allowed text-sm">
      Exportieren (bald verfügbar)
    </button>
  </div>

  <%= form_with url: dashboards_admin_path, method: :get, class: "flex gap-2 mb-4" do |f| %>
    <%= f.text_field :q,
          value: params[:q],
          placeholder: "Name oder E-Mail eingeben (min. 2 Zeichen)…",
          autofocus: params[:q].present?,
          autocomplete: "off",
          class: "flex-1 rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <%= f.submit "Suchen",
          class: "shrink-0 rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
  <% end %>

  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-xl overflow-hidden">
    <% if params[:q].to_s.strip.length >= 2 %>
      <% if @participants.any? %>
        <div class="px-5 py-3 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
          <p class="text-xs font-semibold text-gray-500">
            <% if @participants.size == 50 %>
              Erste 50 Treffer für „<%= params[:q] %>" — Suche verfeinern für genauere Ergebnisse
            <% else %>
              <%= @participants.size %> <%= @participants.size == 1 ? "Treffer" : "Treffer" %> für „<%= params[:q] %>"
            <% end %>
          </p>
        </div>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Name</th>
              <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Geburtsdatum</th>
              <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Konto (E-Mail)</th>
              <th class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktion</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @participants.each do |participant| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="py-3.5 px-4 font-semibold text-gray-900 text-sm">
                  <%= participant.last_name %>, <%= participant.first_name %>
                </td>
                <td class="py-3.5 px-4 text-sm text-gray-600">
                  <%= participant.date_of_birth&.strftime("%d.%m.%Y") || "—" %>
                </td>
                <td class="py-3.5 px-4 text-sm text-gray-500">
                  <%= participant.user.email %>
                </td>
                <td class="py-3.5 px-4 text-right">
                  <%= link_to "Profil ansehen", participant_path(participant),
                        class: "text-blue-600 font-bold hover:text-blue-800 bg-blue-50 px-3 py-1.5 rounded-md text-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-12 text-center">
          <p class="text-sm font-semibold text-gray-700">Keine Treffer für „<%= params[:q] %>"</p>
          <p class="text-xs text-gray-400 mt-1">Prüfe die Schreibweise oder suche nach der E-Mail-Adresse.</p>
        </div>
      <% end %>
    <% else %>
      <div class="py-12 text-center">
        <p class="text-sm font-medium text-gray-500">Gib mindestens 2 Zeichen ein, um zu suchen.</p>
      </div>
    <% end %>
  </div>

</div>
