<div class="max-w-4xl mx-auto mt-6 sm:mt-10 mb-16 px-4">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="mb-6">
    <%= link_to dashboards_admin_path,
          class: "inline-flex items-center gap-1.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition mb-3 py-2 -ml-1 px-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("dashboards.admin.title") %>
    <% end %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Offene Präsenzkontrollen</h1>
    <p class="text-gray-500 mt-1 text-sm sm:text-base">
      Vergangene Trainings, deren Präsenzkontrolle noch nicht abgeschlossen wurde.
    </p>
  </div>

  <% if @open_sessions.any? %>
    <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden divide-y divide-gray-100">
      <% @open_sessions.each do |session| %>
        <% trainers = session.course.course_trainers.map { |ct| ct.trainer&.full_name }.compact %>
        <%= link_to training_session_path(session),
              class: "group flex items-center gap-4 px-4 sm:px-6 py-4 hover:bg-gray-50 active:bg-gray-100 transition" do %>
          <div class="w-12 text-center shrink-0">
            <% if session.start_time %>
              <p class="text-lg font-extrabold leading-none text-gray-900"><%= session.start_time.in_time_zone.strftime("%-d") %></p>
              <p class="text-xs font-semibold text-gray-500 uppercase"><%= session.start_time.in_time_zone.strftime("%b") %></p>
            <% else %>
              <p class="text-xs text-gray-400">&mdash;</p>
            <% end %>
          </div>
          <div class="min-w-0 flex-1">
            <p class="font-bold text-gray-900 text-sm truncate"><%= session.course.title %></p>
            <p class="text-xs text-gray-500 mt-0.5">
              <% if session.start_time %>
                <%= session.start_time.in_time_zone.strftime("%A, %H:%M") %>
                <% if session.end_time %>&ndash; <%= session.end_time.in_time_zone.strftime("%H:%M") %> <%= t("misc.time_suffix") %><% end %>
              <% end %>
            </p>
            <p class="text-xs text-gray-400 mt-0.5 truncate">
              <% if trainers.any? %>
                Zuständig: <%= trainers.join(", ") %>
              <% else %>
                Kein Trainer zugewiesen
              <% end %>
            </p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-4 w-4 text-gray-300 group-hover:text-gray-500 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl px-6 py-16 text-center">
      <div class="mx-auto w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mb-4">
        <svg class="w-7 h-7 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <p class="text-gray-700 font-bold">Alle Präsenzkontrollen sind abgeschlossen.</p>
      <p class="text-gray-400 text-sm mt-1">Es gibt aktuell keine offenen Kontrollen.</p>
    </div>
  <% end %>

</div>
