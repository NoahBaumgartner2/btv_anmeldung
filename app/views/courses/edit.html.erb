<% content_for :title, "Kurs bearbeiten" %>

<div class="max-w-3xl mx-auto mt-6 sm:mt-10 mb-16 px-4">

  <div class="mb-8">
    <%= link_to t("courses.edit.back"), manage_course_path(@course),
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t("courses.edit.title") %></h1>
    <p class="text-gray-500 mt-1 text-sm"><%= t("courses.edit.subtitle", title: @course.title) %></p>
  </div>

  <%= render "form", course: @course %>

</div>
