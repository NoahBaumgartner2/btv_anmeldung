<% content_for :title, "Kurs bearbeiten" %>

<div class="max-w-3xl mx-auto mt-6 sm:mt-10 mb-16 px-4">

  <div class="mb-8">
    <%= link_to "← Zurück zur Kursverwaltung", manage_course_path(@course),
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2">Kurs bearbeiten</h1>
    <p class="text-gray-500 mt-1 text-sm">Passe die Daten für &bdquo;<%= @course.title %>&ldquo; an.</p>
  </div>

  <%= render "form", course: @course %>

</div>
