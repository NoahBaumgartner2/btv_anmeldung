<div class="max-w-5xl mx-auto w-full">

  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
      <h1 class="font-bold text-3xl text-gray-900"><%= @course.title %></h1>
      <span class="inline-block mt-2 bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded uppercase tracking-wide">
        <%= @course.registration_type %>
      </span>
    </div>
<div class="flex flex-wrap gap-3">
      <%= link_to "Kind für diesen Kurs anmelden", new_course_registration_path(course_id: @course.id), class: "bg-green-600 py-2 px-4 border border-transparent shadow-sm text-sm font-bold rounded-md text-white hover:bg-green-700 transition" %>

      <%= link_to "Zurück", courses_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 transition" %>
      <%= link_to "Bearbeiten", edit_course_path(@course), class: "bg-orange-100 py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-orange-700 hover:bg-orange-200 transition" %>
      <%= button_to "Löschen", @course, method: :delete, data: { turbo_confirm: "Wirklich löschen?" }, class: "cursor-pointer bg-red-600 py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white hover:bg-red-700 transition" %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-10">
    <h2 class="text-lg font-bold text-gray-800 border-b border-gray-100 pb-3 mb-4">Kursinformationen</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-3">
        <p class="text-sm font-medium text-gray-500">Beschreibung</p>
        <p class="mt-1 text-gray-900"><%= @course.description.presence || "-" %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-500">Ort / Halle</p>
        <p class="mt-1 text-gray-900 font-semibold"><%= @course.location %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-500">Zeitraum</p>
        <p class="mt-1 text-gray-900">
          <%= @course.start_date&.strftime("%d.%m.%Y") %> – <%= @course.end_date&.strftime("%d.%m.%Y") %>
        </p>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-500">Einstellungen</p>
        <ul class="mt-1 text-sm text-gray-700 space-y-1">
          <li><%= @course.allows_holiday_deduction ? "✅ Ferienabzug möglich" : "❌ Kein Ferienabzug" %></li>
          <li><%= @course.has_payment ? "✅ Kostenpflichtig" : "❌ Kostenlos" %></li>
          <li><%= @course.has_ticketing ? "🎟️ Ticketing aktiv" : "🎟️ Kein Ticketing" %></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="mb-6 flex justify-between items-end">
    <h2 class="text-2xl font-bold text-gray-900">Angemeldete Teilnehmer (<%= @course.course_registrations.count %>)</h2>
  </div>

  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-lg overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Name</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Bezahlt?</th>
          <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Profil</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% if @course.course_registrations.any? %>
          <% @course.course_registrations.includes(:participant).each do |registration| %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="py-4 px-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= registration.participant.first_name %> <%= registration.participant.last_name %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <% status_color = registration.status == 'bestätigt' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>
                <span class="px-2 py-1 rounded-full text-xs font-medium <%= status_color %>">
                  <%= registration.status.capitalize %>
                </span>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <%= registration.payment_cleared ? "✅ Ja" : "⏳ Ausstehend" %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "Teilnehmer ansehen", participant_path(registration.participant), class: "text-blue-600 hover:text-blue-900" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="py-8 text-center text-sm text-gray-500">
              Noch keine Teilnehmer für diesen Kurs angemeldet.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>
