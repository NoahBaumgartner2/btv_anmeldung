<% content_for :title, "Kursangebot" %>

<div class="max-w-5xl mx-auto w-full px-4 sm:px-6 mt-10 mb-16">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Kursangebot</h1>
      <p class="text-gray-500 mt-1">Wähle die passende Kategorie und melde dich direkt an.</p>
    </div>
    <% if current_user&.admin? %>
      <%= link_to "+ Neuen Kurs erstellen", new_course_path,
            class: "shrink-0 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-5 rounded-lg shadow-sm transition text-sm" %>
    <% end %>
  </div>

  <%# ── Kategorien ──────────────────────────────────────────────────────── %>
  <% if @courses.any? %>
    <% @courses.group_by { |c| c.title.split("(").first.strip }.sort.each do |category, courses_in_category| %>

      <details class="group bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-4 [&_summary::-webkit-details-marker]:hidden">

        <summary class="flex cursor-pointer items-center justify-between px-5 py-4 hover:bg-gray-50 transition select-none">
          <div class="flex items-center gap-3">
            <span class="text-gray-400 transition-transform duration-200 group-open:rotate-90">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </span>
            <div>
              <h2 class="text-base font-bold text-gray-900"><%= category %></h2>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= courses_in_category.count %> <%= courses_in_category.count == 1 ? "Termin verfügbar" : "Termine verfügbar" %>
              </p>
            </div>
          </div>

          <%# Schnell-Info: Orte in dieser Kategorie %>
          <div class="hidden sm:flex items-center gap-3 mr-4">
            <% locations = courses_in_category.map(&:location).compact.uniq.first(2) %>
            <% locations.each do |loc| %>
              <span class="text-xs text-gray-500 font-medium bg-gray-100 px-2.5 py-1 rounded-full"><%= loc %></span>
            <% end %>
            <% if courses_in_category.map(&:location).compact.uniq.size > 2 %>
              <span class="text-xs text-gray-400">+<%= courses_in_category.map(&:location).compact.uniq.size - 2 %> weitere</span>
            <% end %>
          </div>
        </summary>

        <%# Kurs-Zeilen %>
        <div class="border-t border-gray-100">
          <% courses_in_category.each_with_index do |course, i| %>
            <%
              confirmed_count = course.course_registrations.count { |r| r.status == "bestätigt" }
              total_count     = course.course_registrations.size
              is_full         = course.max_participants.present? && confirmed_count >= course.max_participants
              is_single       = course.registration_mode == "single_session"
            %>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 px-5 py-4
                        <%= i < courses_in_category.size - 1 ? "border-b border-gray-100" : "" %>
                        hover:bg-gray-50 transition">

              <%# Linke Seite: Titel + Metadaten %>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <h3 class="font-semibold text-gray-900 text-sm"><%= course.title %></h3>

                  <% if is_single %>
                    <span class="inline-block bg-purple-100 text-purple-700 text-xs font-bold px-2 py-0.5 rounded-full">Drop-In</span>
                  <% end %>

                  <% if is_full %>
                    <span class="inline-block bg-orange-100 text-orange-700 text-xs font-bold px-2 py-0.5 rounded-full">Ausgebucht</span>
                  <% end %>
                </div>

                <p class="text-xs text-gray-400 font-medium flex flex-wrap items-center gap-x-2">
                  <% if course.location.present? %>
                    <span><%= course.location %></span>
                    <span class="text-gray-300">·</span>
                  <% end %>
                  <% if is_single %>
                    <span>Einzeltermine, jederzeit einsteigen</span>
                  <% elsif course.start_date && course.end_date %>
                    <span><%= course.start_date.strftime("%-d. %b %Y") %> – <%= course.end_date.strftime("%-d. %b %Y") %></span>
                  <% end %>
                  <% if course.max_participants.present? && !is_full %>
                    <% remaining = course.max_participants - confirmed_count %>
                    <span class="text-gray-300">·</span>
                    <span class="<%= remaining <= 3 ? "text-orange-500 font-semibold" : "text-gray-400" %>">
                      noch <%= remaining %> <%= remaining == 1 ? "Platz" : "Plätze" %> frei
                    </span>
                  <% elsif !is_single && !is_full %>
                    <span class="text-gray-300">·</span>
                    <span><%= confirmed_count %> Anmeldung<%= confirmed_count == 1 ? "" : "en" %></span>
                  <% end %>
                </p>
              </div>

              <%# Rechte Seite: Aktionen %>
              <div class="flex items-center gap-2 shrink-0">
                <% if current_user&.admin? %>
                  <%= link_to "Verwalten", manage_course_path(course),
                        class: "text-xs font-bold text-gray-500 hover:text-gray-800 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-lg transition" %>
                <% end %>

                <% if is_single %>
                  <%= link_to "Termine ansehen", course_path(course),
                        class: "text-xs font-bold bg-purple-600 hover:bg-purple-700 text-white px-4 py-1.5 rounded-lg transition shadow-sm" %>
                <% elsif is_full %>
                  <%= link_to "Details", course_path(course),
                        class: "text-xs font-bold bg-white border border-gray-300 text-gray-600 hover:bg-gray-50 px-3 py-1.5 rounded-lg transition" %>
                  <%= link_to "Warteliste", new_course_registration_path(course_id: course.id),
                        class: "text-xs font-bold bg-orange-500 hover:bg-orange-600 text-white px-4 py-1.5 rounded-lg transition shadow-sm" %>
                <% else %>
                  <%= link_to "Details", course_path(course),
                        class: "text-xs font-bold bg-white border border-gray-300 text-gray-600 hover:bg-gray-50 px-3 py-1.5 rounded-lg transition" %>
                  <%= link_to "Anmelden", new_course_registration_path(course_id: course.id),
                        class: "text-xs font-bold bg-green-600 hover:bg-green-700 text-white px-4 py-1.5 rounded-lg transition shadow-sm" %>
                <% end %>
              </div>

            </div>
          <% end %>
        </div>

      </details>

    <% end %>
  <% else %>
    <div class="bg-white p-12 rounded-2xl border border-gray-200 shadow-sm text-center">
      <h3 class="text-lg font-bold text-gray-900 mb-1">Noch keine Kurse vorhanden</h3>
      <p class="text-gray-500 text-sm">Sobald Kurse erstellt werden, erscheinen sie hier.</p>
    </div>
  <% end %>

</div>
