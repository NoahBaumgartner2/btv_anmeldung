<div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 mt-10 mb-16">

  <div class="flex justify-between items-center mb-12">
    <div>
      <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">Kursangebot</h1>
      <p class="text-gray-500 mt-2 text-lg">Wähle die passende Kategorie für dein Kind.</p>
    </div>

    <% if current_user&.admin? %>
      <%= link_to "+ Neuen Kurs erstellen", new_course_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-5 rounded-lg shadow-sm transition" %>
    <% end %>
  </div>

  <% @courses.group_by { |c| c.title.split('(').first.strip }.sort.each do |category, courses_in_category| %>

    <details class="group bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-6 [&_summary::-webkit-details-marker]:hidden">

      <summary class="flex cursor-pointer items-center justify-between bg-blue-50 px-6 py-5 border-b border-transparent group-open:border-blue-100 transition-colors hover:bg-blue-100/50">

        <div class="flex items-center gap-4">
          <span class="text-blue-600 transition duration-300 group-open:-rotate-180">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </span>

          <div>
            <h2 class="text-2xl font-extrabold text-blue-900"><%= category %></h2>
            <p class="text-blue-700 text-sm mt-0.5 group-open:hidden">Klicken, um Termine anzuzeigen</p>
            <p class="text-blue-700 text-sm mt-0.5 hidden group-open:block">Wähle deinen bevorzugten Termin aus.</p>
          </div>
        </div>

        <span class="bg-blue-200 text-blue-800 py-1.5 px-4 rounded-full text-sm font-bold whitespace-nowrap">
          <%= courses_in_category.count %> <%= courses_in_category.count == 1 ? 'Option' : 'Optionen' %>
        </span>
      </summary>

      <div class="divide-y divide-gray-100 border-t border-blue-100 group-open:animate-fadeIn">
        <% courses_in_category.each do |course| %>
          <div class="p-6 hover:bg-gray-50 transition flex flex-col lg:flex-row lg:items-center justify-between gap-6">

            <div class="flex-grow">
              <h3 class="text-xl font-bold text-gray-900"><%= course.title %></h3>
              <p class="text-gray-500 text-sm mt-1 line-clamp-2"><%= course.description %></p>

              <div class="mt-3 flex flex-wrap gap-4 text-sm text-gray-600 font-medium">
                <div class="flex items-center bg-gray-100 px-2 py-1 rounded">
                  <span class="mr-2">📍</span> <%= course.location.presence || "Ort unbekannt" %>
                </div>

                <% if course.registration_mode == 'single_session' %>
                  <div class="flex items-center bg-purple-50 text-purple-700 px-2 py-1 rounded border border-purple-100">
                    <span class="mr-2">🎟️</span> Einzelanmeldung (Drop-In)
                  </div>
                <% else %>
                  <div class="flex items-center bg-gray-100 px-2 py-1 rounded">
                    <span class="mr-2"></span> <%= course.start_date&.strftime("%d.%m.%y") %> – <%= course.end_date&.strftime("%d.%m.%y") %>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row lg:flex-col items-start sm:items-center lg:items-end gap-3 min-w-[220px]">
              <% if course.registration_mode == 'single_session' %>
                <div class="text-sm font-medium text-purple-600 mb-1">
                  Datumsspezifische Anmeldung
                </div>
                <div class="flex gap-2 w-full">
                  <%= link_to "Termine ansehen", course_path(course), class: "flex-1 text-center bg-purple-600 text-white py-2 px-4 rounded-lg text-sm font-bold hover:bg-purple-700 transition shadow-sm" %>
                </div>
              <% else %>
                <div class="text-sm font-medium text-gray-500">
                  Aktuell <span class="font-bold text-gray-900"><%= course.course_registrations.count %></span> Anmeldungen
                </div>
                <div class="flex gap-2 w-full">
                  <%= link_to "Details", course_path(course), class: "flex-1 text-center bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-lg text-sm font-bold hover:bg-gray-50 transition" %>
                  <%= link_to "Anmelden", new_course_registration_path(course_id: course.id), class: "flex-1 text-center bg-green-600 text-white py-2 px-4 rounded-lg text-sm font-bold hover:bg-green-700 transition shadow-sm" %>
                </div>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>

    </details>
    <% end %>

  <% if @courses.empty? %>
    <div class="text-center bg-white p-10 rounded-2xl border border-gray-200 shadow-sm">
      <span class="text-4xl"></span>
      <h3 class="text-lg font-bold text-gray-900 mt-4">Noch keine Kurse vorhanden</h3>
      <p class="text-gray-500 mt-1">Sobald Kurse erstellt werden, erscheinen sie hier.</p>
    </div>
  <% end %>

</div>
