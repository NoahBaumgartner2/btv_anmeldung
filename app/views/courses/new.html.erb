<% content_for :title, "Neuer Kurs" %>

<div class="max-w-3xl mx-auto mt-6 sm:mt-10 mb-16 px-4">

  <div class="mb-8">
    <%= link_to "← Zurück", courses_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2">Neuen Kurs erstellen</h1>
    <p class="text-gray-500 mt-1 text-sm">Lege einen neuen Kurs an und definiere die Einstellungen.</p>
  </div>

  <%= render "form", course: @course %>

</div>
