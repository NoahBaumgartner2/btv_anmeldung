<%
  has_dates      = @course.start_date.present? && @course.end_date.present?
  existing_count = @course.training_sessions.count
  course_holidays = has_dates ? Holiday.where("start_date <= ? AND end_date >= ?", @course.end_date, @course.start_date).order(:start_date) : []
  weeks_total    = has_dates ? ((@course.end_date.to_date - @course.start_date.to_date) / 7.0).ceil : nil

  hours   = (6..22).map { |h| [format("%02d", h), h] }
  minutes = [["00", 0], ["15", 15], ["30", 30], ["45", 45]]
%>

<div class="max-w-2xl mx-auto mt-10 w-full mb-16 px-4">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to "← Zurück zum Maschinenraum", manage_course_path(@course),
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition min-h-11 inline-flex items-center" %>
    <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900 mt-3">Trainings generieren</h1>
    <p class="text-gray-500 mt-1">Erstelle automatisch alle Einzel-Sessions für diesen Kurs.</p>
  </div>

  <%# ── Kein Datum gesetzt → Formular sperren ──────────────────────────── %>
  <% unless has_dates %>
    <div class="bg-red-50 border border-red-300 rounded-xl p-6 mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-bold text-red-800">Kein Kurszeitraum gesetzt</p>
        <p class="text-sm text-red-700 mt-1">
          Dieser Kurs hat kein Start- oder Enddatum. Bitte zuerst den Kurs bearbeiten, bevor Trainings generiert werden können.
        </p>
      </div>
      <%= link_to "Kurs bearbeiten", edit_course_path(@course),
            class: "shrink-0 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-5 rounded-lg text-sm transition" %>
    </div>
  <% end %>

  <%# ── Kurs-Kontext ────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 mb-6">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Kurs-Informationen</p>
    <h2 class="text-lg font-bold text-gray-900 mb-3"><%= @course.title %></h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
      <% zeitraum_class = has_dates ? "bg-gray-50 rounded-lg p-3" : "bg-red-50 rounded-lg p-3 border border-red-200" %>
      <%= content_tag :div, class: zeitraum_class do %>
        <p class="text-xs font-semibold text-gray-500 mb-0.5">Zeitraum</p>
        <% if has_dates %>
          <p class="font-bold text-gray-800">
            <%= @course.start_date.strftime("%-d. %b %Y") %> – <%= @course.end_date.strftime("%-d. %b %Y") %>
          </p>
        <% else %>
          <p class="font-bold text-red-600">Nicht gesetzt</p>
        <% end %>
      <% end %>
      <% if weeks_total %>
        <div class="bg-gray-50 rounded-lg p-3">
          <p class="text-xs font-semibold text-gray-500 mb-0.5">Dauer</p>
          <p class="font-bold text-gray-800">ca. <%= weeks_total %> Wochen</p>
        </div>
      <% end %>
      <div class="bg-gray-50 rounded-lg p-3">
        <p class="text-xs font-semibold text-gray-500 mb-0.5">Ort</p>
        <p class="font-bold text-gray-800"><%= @course.location.presence || "—" %></p>
      </div>
    </div>

    <% if existing_count > 0 %>
      <div class="mt-4 bg-orange-50 border border-orange-200 rounded-lg px-4 py-3 text-sm text-orange-800">
        <strong>Achtung:</strong> Für diesen Kurs existieren bereits <%= existing_count %> Sessions.
        Daten, für die bereits eine Session besteht, werden automatisch übersprungen.
      </div>
    <% end %>
  </div>

  <%# ── Formular (nur wenn Daten vorhanden) ────────────────────────────── %>
  <% if has_dates %>
    <%= form_with url: create_generated_trainings_course_path(@course), method: :post do |f| %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-6">

        <%# Wochentag %>
        <div>
          <p class="text-sm font-bold text-gray-700 mb-3">Wochentag</p>
          <div class="flex gap-2 flex-wrap">
            <% [["Mo", 1], ["Di", 2], ["Mi", 3], ["Do", 4], ["Fr", 5], ["Sa", 6], ["So", 0]].each do |label, value| %>
              <label class="cursor-pointer">
                <%= f.radio_button :day_of_week, value, class: "sr-only peer", id: "day_#{value}" %>
                <span class="peer-checked:bg-primary-600 peer-checked:text-white peer-checked:border-primary-600
                             block border-2 border-gray-200 bg-gray-50 text-gray-700 hover:border-primary-300
                             font-bold px-4 py-2.5 rounded-xl text-sm transition select-none w-14 text-center">
                  <%= label %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Uhrzeit – Dropdowns statt Browser-Timepicker %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <div>
            <p class="text-sm font-bold text-gray-700 mb-2">Beginn</p>
            <div class="flex items-center gap-2">
              <select name="start_hour" required
                      class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
                <option value="">Std.</option>
                <% hours.each do |label, val| %>
                  <option value="<%= val %>" <%= "selected" if @course.default_start_hour == val %>><%= label %></option>
                <% end %>
              </select>
              <span class="text-gray-500 font-bold shrink-0">:</span>
              <select name="start_minute" required
                      class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
                <% minutes.each do |label, val| %>
                  <option value="<%= val %>" <%= "selected" if @course.default_start_minute == val %>><%= label %></option>
                <% end %>
              </select>
              <span class="text-sm text-gray-400 shrink-0">Uhr</span>
            </div>
          </div>

          <div>
            <p class="text-sm font-bold text-gray-700 mb-2">Ende <span class="font-normal text-gray-400">(optional)</span></p>
            <div class="flex items-center gap-2">
              <select name="end_hour"
                      class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
                <option value="">Std.</option>
                <% hours.each do |label, val| %>
                  <option value="<%= val %>" <%= "selected" if @course.default_end_hour == val %>><%= label %></option>
                <% end %>
              </select>
              <span class="text-gray-500 font-bold shrink-0">:</span>
              <select name="end_minute"
                      class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
                <% minutes.each do |label, val| %>
                  <option value="<%= val %>" <%= "selected" if @course.default_end_minute == val %>><%= label %></option>
                <% end %>
              </select>
              <span class="text-sm text-gray-400 shrink-0">Uhr</span>
            </div>
          </div>
        </div>

        <%# Ferien im Kurszeitraum %>
        <div>
          <p class="text-sm font-bold text-gray-700 mb-2">Ferien im Kurszeitraum</p>
          <% if course_holidays.any? %>
            <div class="rounded-lg border border-yellow-200 bg-yellow-50 divide-y divide-yellow-100 overflow-hidden">
              <% course_holidays.each do |holiday| %>
                <label class="px-4 py-2.5 flex items-start gap-3 text-sm cursor-pointer hover:bg-yellow-100 transition min-h-11">
                  <input type="checkbox" name="holiday_ids[]" value="<%= holiday.id %>"
                         checked
                         class="w-4 h-4 mt-0.5 rounded border-yellow-400 text-primary-600 focus:ring-primary-500 shrink-0">
                  <div class="flex-1 min-w-0">
                    <span class="block font-semibold text-yellow-900 leading-snug"><%= holiday.title %></span>
                    <span class="block text-xs text-yellow-700 font-medium mt-0.5">
                      <%= holiday.start_date.strftime("%-d. %b") %> – <%= holiday.end_date.strftime("%-d. %b %Y") %>
                    </span>
                  </div>
                </label>
              <% end %>
            </div>
            <p class="text-xs text-gray-400 mt-2">Deaktivierte Ferien werden beim Generieren nicht übersprungen.</p>
          <% else %>
            <div class="rounded-lg border border-gray-100 bg-gray-50 px-4 py-3 text-sm text-gray-500">
              Keine Ferien im Kurszeitraum eingetragen.
            </div>
          <% end %>
        </div>

        <%# Manuelle Ferien %>
        <div>
          <p class="text-sm font-bold text-gray-700 mb-2">
            Weitere Ferien / Sperrtage
            <span class="font-normal text-gray-400">(optional)</span>
          </p>
          <div id="extra-holidays-list" class="space-y-2">
            <%# Dynamisch hinzugefügte Zeilen landen hier %>
          </div>
          <button type="button" id="add-holiday-btn"
                  class="mt-3 flex items-center gap-1.5 text-sm font-semibold text-primary-600 hover:text-primary-800 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Ferienzeitraum hinzufügen
          </button>
        </div>

        <script nonce="<%= request.content_security_policy_nonce %>">
          (function() {
            var list = document.getElementById('extra-holidays-list');
            var btn  = document.getElementById('add-holiday-btn');
            var idx  = 0;

            btn.addEventListener('click', function() {
              var i = idx++;
              var row = document.createElement('div');
              row.className = 'flex flex-col gap-2 bg-gray-50 border border-gray-200 rounded-lg px-3 py-3';
              row.innerHTML =
                '<input type="text" name="extra_holidays[' + i + '][title]" placeholder="Bezeichnung (z.B. Sportferien)" ' +
                  'class="w-full rounded-lg border border-gray-300 px-2.5 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11">' +
                '<div class="flex items-center gap-2">' +
                  '<input type="date" name="extra_holidays[' + i + '][start_date]" ' +
                    'class="flex-1 min-w-0 rounded-lg border border-gray-300 px-2.5 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11">' +
                  '<span class="text-gray-400 text-sm shrink-0">–</span>' +
                  '<input type="date" name="extra_holidays[' + i + '][end_date]" ' +
                    'class="flex-1 min-w-0 rounded-lg border border-gray-300 px-2.5 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11">' +
                  '<button type="button" class="remove-holiday shrink-0 text-gray-400 hover:text-red-500 transition p-1 min-h-11 flex items-center" title="Entfernen">' +
                    '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
                  '</button>' +
                '</div>';
              row.querySelector('.remove-holiday').addEventListener('click', function() {
                row.remove();
              });
              list.appendChild(row);
            });
          })();
        </script>

      </div>

      <div class="mt-6 flex flex-col sm:flex-row items-center gap-3">
        <%= f.submit "Trainings jetzt generieren",
              class: "w-full sm:w-auto cursor-pointer bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 px-6 rounded-xl shadow-sm transition text-sm" %>
        <%= link_to "Abbrechen", manage_course_path(@course),
              class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-xl text-sm transition" %>
      </div>
    <% end %>
  <% end %>

</div>
