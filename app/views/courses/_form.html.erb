<%= form_with(model: course, class: "contents") do |form| %>
  <% if course.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 px-5 py-4 mb-6">
      <p class="text-sm font-bold text-red-800 mb-2"><%= course.errors.count %> Fehler:</p>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
        <% course.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── 1. Benennung & Kategorie ──────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Benennung &amp; Kategorie</p>
    </div>
    <div class="p-6 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <%= form.label :category, "Kategorie", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-400 mb-1.5">z.B. Kids Gym, Krabbel Gym — gleiche Kategorie wird auf der Startseite gruppiert.</p>
          <%= form.text_field :category,
                placeholder: "z.B. Kids Gym",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
        <div>
          <%= form.label :title, "Kursname", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-400 mb-1.5">Vollständiger Name des Kurses, z.B. Kids Gym (Mittwoch Morgen).</p>
          <%= form.text_field :title,
                placeholder: "z.B. Kids Gym (Mittwoch Morgen)",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
      </div>
      <div>
        <%= form.label :description, "Kursbeschreibung", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :description,
              rows: 3,
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>
  </div>

  <%# ── 2. Zeitraum & Ort ─────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Zeitraum &amp; Ort</p>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div>
          <%= form.label :start_date, "Startdatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.date_field :start_date,
                data: { controller: "datepicker" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
        <div>
          <%= form.label :end_date, "Enddatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.date_field :end_date,
                data: { controller: "datepicker" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
        <div>
          <%= form.label :location, "Ort / Halle", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :location,
                placeholder: "z.B. Turnhalle Mitte",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
      </div>
    </div>
  </div>

  <%# ── 3. Trainingszeit ──────────────────────────────────────────────────── %>
  <% hours   = (6..22).map { |h| [format("%02d", h), h] } %>
  <% minutes = [["00", 0], ["15", 15], ["30", 30], ["45", 45]] %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Trainingszeit</p>
    </div>
    <div class="p-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">Beginn</p>
          <div class="flex items-center gap-2">
            <select name="course[default_start_hour]"
                    class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
              <option value="">Std.</option>
              <% hours.each do |label, val| %>
                <option value="<%= val %>" <%= "selected" if course.default_start_hour == val %>><%= label %></option>
              <% end %>
            </select>
            <span class="text-gray-500 font-bold shrink-0">:</span>
            <select name="course[default_start_minute]"
                    class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
              <% minutes.each do |label, val| %>
                <option value="<%= val %>" <%= "selected" if course.default_start_minute == val %>><%= label %></option>
              <% end %>
            </select>
            <span class="text-sm text-gray-400 shrink-0">Uhr</span>
          </div>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">Ende <span class="font-normal text-gray-400">(optional)</span></p>
          <div class="flex items-center gap-2">
            <select name="course[default_end_hour]"
                    class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
              <option value="">Std.</option>
              <% hours.each do |label, val| %>
                <option value="<%= val %>" <%= "selected" if course.default_end_hour == val %>><%= label %></option>
              <% end %>
            </select>
            <span class="text-gray-500 font-bold shrink-0">:</span>
            <select name="course[default_end_minute]"
                    class="flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white min-h-11">
              <% minutes.each do |label, val| %>
                <option value="<%= val %>" <%= "selected" if course.default_end_minute == val %>><%= label %></option>
              <% end %>
            </select>
            <span class="text-sm text-gray-400 shrink-0">Uhr</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── 4. Anmeldemodus & Kapazität ───────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Anmeldemodus &amp; Kapazität</p>
    </div>
    <div class="p-6 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <%= form.label :registration_mode, "Anmeldemodus", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :registration_mode,
                [["Für das gesamte Semester (einmalige Anmeldung)", "semester"],
                 ["Für jedes Training einzeln (Drop-In / Krabbel Gym)", "single_session"]],
                { prompt: "Bitte wählen…" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
        <div>
          <%= form.label :max_participants, "Max. Teilnehmerzahl", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.number_field :max_participants,
                min: 1, placeholder: "z.B. 20",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
        </div>
      </div>

      <%# Altersbeschränkung %>
      <div class="border-t border-gray-100 pt-5">
        <p class="text-sm font-medium text-gray-700 mb-0.5">Altersbeschränkung <span class="font-normal text-gray-400">(optional)</span></p>
        <p class="text-xs text-gray-400 mb-3">Leer lassen = keine Einschränkung. Das Alter wird anhand des Kursstarts berechnet.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <%= form.label :min_age, "Mindestalter", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="flex items-center gap-2">
              <%= form.number_field :min_age,
                    min: 0, max: 120, placeholder: "z.B. 3",
                    class: "flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
              <span class="text-sm text-gray-400 shrink-0">Jahre</span>
            </div>
          </div>
          <div>
            <%= form.label :max_age, "Höchstalter", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="flex items-center gap-2">
              <%= form.number_field :max_age,
                    min: 0, max: 120, placeholder: "z.B. 5",
                    class: "flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
              <span class="text-sm text-gray-400 shrink-0">Jahre</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── 5. Trainer-Zuweisung ──────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Trainer-Zuweisung</p>
    </div>
    <div class="p-6">
      <% if Trainer.any? %>
        <p class="text-sm text-gray-500 mb-4">Wähle aus, welche Trainer diesen Kurs in ihrem Dashboard sehen und verwalten dürfen.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <%= form.collection_check_boxes(:trainer_ids, Trainer.includes(:user).all, :id, ->(t) { t.user.email }) do |b| %>
            <label class="flex items-center gap-3 bg-gray-50 hover:bg-primary-50 border border-gray-200 hover:border-primary-300 px-4 py-3 rounded-lg transition cursor-pointer min-h-11">
              <%= b.check_box class: "h-4 w-4 text-primary-600 rounded border-gray-300 focus:ring-primary-500 shrink-0 cursor-pointer" %>
              <span class="text-sm font-medium text-gray-700 truncate"><%= b.text %></span>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">
          Noch keine Trainer angelegt.
          <%= link_to "Jetzt Trainer erstellen →", new_trainer_path, class: "font-semibold text-primary-600 hover:text-primary-800" %>
        </p>
      <% end %>
    </div>
  </div>

  <%# ── 6. Weitere Einstellungen ──────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Weitere Einstellungen</p>
    </div>
    <div class="p-6 space-y-5">

      <%# Kostenpflichtig %>
      <div>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= form.check_box :has_payment,
                id: "course_has_payment",
                class: "h-5 w-5 text-primary-600 rounded border-gray-300 focus:ring-primary-500 cursor-pointer shrink-0" %>
          <div>
            <span class="text-sm font-medium text-gray-800">Dieser Kurs ist kostenpflichtig</span>
          </div>
        </label>

        <div id="price-field" class="<%= course.has_payment? ? "" : "hidden" %> mt-4 ml-8 space-y-4">
          <div>
            <p class="text-sm font-medium text-gray-700 mb-1">Preis</p>
            <div class="flex items-center gap-2 max-w-xs">
              <span class="text-sm font-semibold text-gray-500 shrink-0">CHF</span>
              <%= form.text_field :price_chf,
                    placeholder: "0.00",
                    class: "flex-1 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
            </div>
            <p class="text-xs text-gray-400 mt-1">Preis in Schweizer Franken (z.B. 120.00)</p>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-700 mb-2">Akzeptierte Zahlungsmethoden</p>
            <input type="hidden" name="course[payment_methods][]" value="">
            <div class="flex flex-col gap-2">
              <% Course::PAYMENT_METHODS.each do |value, label| %>
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <%= check_box_tag "course[payment_methods][]", value,
                        course.payment_methods.include?(value),
                        id: "course_payment_methods_#{value}",
                        class: "h-4 w-4 text-primary-600 rounded border-gray-300 focus:ring-primary-500 cursor-pointer" %>
                  <span class="text-sm text-gray-700"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <script nonce="<%= content_security_policy_nonce %>">
          document.getElementById('course_has_payment').addEventListener('change', function() {
            document.getElementById('price-field').classList.toggle('hidden', !this.checked);
          });
        </script>
      </div>

      <div class="border-t border-gray-100 pt-5 space-y-4">
        <%# Ticketing %>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= form.check_box :has_ticketing,
                class: "h-5 w-5 text-primary-600 rounded border-gray-300 focus:ring-primary-500 cursor-pointer shrink-0" %>
          <span class="text-sm font-medium text-gray-800">Ticketing / QR-Codes für diesen Kurs aktivieren</span>
        </label>

        <%# J+S %>
        <div>
          <label class="flex items-center gap-3 cursor-pointer">
            <%= form.check_box :is_js_training,
                  class: "h-5 w-5 text-primary-600 rounded border-gray-300 focus:ring-primary-500 cursor-pointer shrink-0" %>
            <span class="text-sm font-medium text-gray-800">Dies ist ein J+S-Training</span>
          </label>
          <p class="text-xs text-gray-400 mt-1 ml-8">Aktiviere diese Option, wenn der Kurs bei Jugend+Sport (BASPO) gemeldet wird.</p>
        </div>
      </div>
    </div>
  </div>

  <%# ── 7. Pflichtangaben bei Anmeldung ───────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Pflichtangaben bei Anmeldung</p>
    </div>
    <div class="p-6">
      <p class="text-sm text-gray-500 mb-4">Welche Angaben müssen Teilnehmende zusätzlich zu Vorname, Nachname, Geburtsdatum und Geschlecht zwingend hinterlegt haben?</p>
      <div class="space-y-3">
        <% Course::CONFIGURABLE_REQUIRED_FIELDS.each do |field, label| %>
          <%
            hints = {
              ahv_number:       "Wird für die Meldung ans Amt für Sport benötigt.",
              js_person_number: "Wird für die BASPO J+S Meldung benötigt.",
              nationality:      "Wird für die BASPO J+S Meldung benötigt.",
              mother_tongue:    "Wird für die BASPO J+S Meldung benötigt.",
              zip_code:         "Wird für die BASPO J+S Meldung benötigt.",
              city:             "Wird für die BASPO J+S Meldung benötigt.",
              country:          "Wird für die BASPO J+S Meldung benötigt.",
              street:           "Wird für die BASPO J+S Meldung benötigt."
            }
          %>
          <div class="flex items-start gap-3">
            <%= form.check_box :"requires_#{field}",
                  class: "h-5 w-5 mt-0.5 text-primary-600 rounded border-gray-300 focus:ring-primary-500 cursor-pointer shrink-0" %>
            <div>
              <%= form.label :"requires_#{field}", label, class: "text-sm font-medium text-gray-800 cursor-pointer block" %>
              <p class="text-xs text-gray-400 mt-0.5"><%= hints[field] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Aktionen ───────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row gap-3">
    <%= form.submit course.new_record? ? "Kurs erstellen" : "Änderungen speichern",
          class: "w-full sm:w-auto cursor-pointer bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition min-h-11" %>
    <%= link_to "Abbrechen", course.new_record? ? courses_path : manage_course_path(course),
          class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 px-6 rounded-xl text-sm transition min-h-11 flex items-center justify-center" %>
  </div>
<% end %>
