<%= form_with(model: course, class: "contents") do |form| %>
  <% if course.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 px-4 py-3 font-medium rounded-lg mb-6 border border-red-200">
      <h2><%= pluralize(course.errors.count, "Fehler") %> verhinderten das Speichern:</h2>
      <ul class="list-disc ml-5 mt-2 text-sm">
        <% course.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="md:col-span-2">
      <%= form.label :title, "Kurstitel", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :title, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div class="md:col-span-2">
      <%= form.label :description, "Beschreibung", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :description, rows: 4, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :location, "Ort / Halle", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :location, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :registration_type, "Anmelde-Typ", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :registration_type, ['pro_training', 'einmalig', 'quartal'], { prompt: "Bitte wählen" }, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white" %>
    </div>

    <div>
      <%= form.label :start_date, "Startdatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :start_date, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :end_date, "Enddatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :end_date, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
  </div>

  <div class="space-y-4 mb-8 bg-gray-50 p-5 rounded-lg border border-gray-200">
    <h3 class="text-sm font-bold text-gray-700 border-b border-gray-200 pb-2">Einstellungen</h3>

    <div class="flex items-center mt-3">
      <%= form.check_box :allows_holiday_deduction, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :allows_holiday_deduction, "Ferienabzug erlaubt", class: "ml-2 block text-sm text-gray-900" %>
    </div>

    <div class="flex items-center">
      <%= form.check_box :has_ticketing, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :has_ticketing, "Ticketing (Warteliste/Tickets) aktivieren", class: "ml-2 block text-sm text-gray-900" %>
    </div>

    <div class="flex items-center">
      <%= form.check_box :has_payment, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :has_payment, "Zahlungspflichtig", class: "ml-2 block text-sm text-gray-900" %>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-5 border-t border-gray-200">
    <%= link_to "Abbrechen", courses_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 transition" %>
    <%= form.submit "Kurs speichern", class: "cursor-pointer inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition" %>
  </div>
<% end %>
