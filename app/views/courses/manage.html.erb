<div class="max-w-6xl mx-auto w-full px-4 mt-8 mb-16">

  <div class="flex justify-between items-center mb-8">
    <div>
      <span class="text-red-600 font-bold text-sm tracking-wider uppercase mb-1 block">Maschinenraum</span>
      <h1 class="font-extrabold text-3xl text-gray-900"><%= @course.title %></h1>
    </div>
    <div>
      <%= link_to "Zurück zum Dashboard", current_user.admin? ? dashboards_admin_path : dashboards_trainer_path, class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm font-bold text-gray-700 hover:bg-gray-50" %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 mb-8">
    <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-4">
      <h2 class="text-xl font-bold text-gray-900">Trainings-Termine & Präsenzkontrolle</h2>
      <% if current_user.admin? %>
        <div class="flex gap-2">
          <%= link_to "⚙️ Automatisch Generieren", generate_trainings_course_path(@course), class: "bg-purple-100 text-purple-700 text-sm font-bold py-1.5 px-3 rounded-md hover:bg-purple-200" %>
          <%= link_to "+ Manuell", new_training_session_path(course_id: @course.id), class: "bg-blue-600 text-white text-sm font-bold py-1.5 px-3 rounded-md hover:bg-blue-700" %>
        </div>
      <% end %>
    </div>

    <% if @course.training_sessions.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <% @course.training_sessions.order(start_time: :desc).each do |session| %>
          <%= link_to session, class: "block bg-gray-50 p-4 rounded-xl border border-gray-200 hover:border-blue-400 hover:bg-white transition" do %>
            <div class="flex justify-between items-center mb-1">
              <h3 class="font-bold text-gray-900"><%= session.start_time&.strftime("%d.%m.%Y") %></h3>
              <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= session.attendances.count %> da</span>
            </div>
            <p class="text-sm text-blue-600 font-medium mt-2">Checkliste öffnen &rarr;</p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm">Noch keine Trainings erfasst.</p>
    <% end %>
  </div>

  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden">
    <div class="bg-white px-6 py-5 border-b border-gray-100">
      <h2 class="text-xl font-bold text-gray-900">Angemeldete Kinder (<%= @course.course_registrations.count %>)</h2>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase">Name</th>
          <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase">Status</th>
          <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase">Bezahlt?</th>
          <th class="py-3 px-6 text-right text-xs font-bold text-gray-500 uppercase">Aktionen</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% @course.course_registrations.includes(:participant).each do |reg| %>
          <tr class="hover:bg-gray-50">
            <td class="py-4 px-6 font-medium text-gray-900"><%= reg.participant.first_name %> <%= reg.participant.last_name %></td>
            <td class="py-4 px-6">
              <% color = reg.status == 'bestätigt' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>
              <span class="px-2 py-1 rounded-full text-xs font-bold <%= color %>"><%= reg.status.capitalize %></span>
            </td>
            <td class="py-4 px-6 text-sm text-gray-500"><%= reg.payment_cleared ? "✅ Ja" : "⏳ Nein" %></td>
            <td class="py-4 px-6 text-right text-sm">
              <% if current_user.admin? %>
                <%= link_to "Bearbeiten", edit_course_registration_path(reg), class: "text-orange-600 font-bold hover:text-orange-800" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
