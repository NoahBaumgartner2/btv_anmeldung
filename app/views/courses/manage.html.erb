<%
  now = Time.current
  all_sessions = @course.training_sessions.order(:start_time).to_a

  sessions_by_month = all_sessions.group_by { |s|
    s.start_time ? s.start_time.beginning_of_month : nil
  }

  total_count     = all_sessions.size
  past_count      = all_sessions.count { |s| s.end_time ? s.end_time < now : s.start_time && s.start_time < now }
  upcoming_count  = all_sessions.count { |s| s.start_time && s.start_time > now && !s.is_canceled }
  live_session    = all_sessions.find { |s| s.start_time && s.end_time && s.start_time <= now && s.end_time >= now }

  confirmed_count = @course.course_registrations.where(status: 'bestätigt').count
  waitlist_count  = @course.course_registrations.where(status: 'warteliste').count
  pending_count   = @course.course_registrations.where(status: 'ausstehend').count
%>

<div class="max-w-6xl mx-auto w-full px-4 mt-6 sm:mt-8 mb-16">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 sm:mb-8 gap-4">
    <div>
      <span class="text-red-600 font-bold text-sm tracking-wider uppercase mb-1 block"><%= t("courses.manage.header_label") %></span>
      <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900"><%= @course.title %></h1>
    </div>

    <%# Desktop: inline buttons %>
    <div class="hidden sm:flex gap-2 flex-wrap">
      <% if current_user.admin? %>
        <%= link_to t("courses.manage.edit_course"), edit_course_path(@course),
              class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
        <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
              class: "bg-purple-100 text-purple-700 text-sm font-bold py-2 px-4 rounded-lg hover:bg-purple-200 transition" %>
        <%= link_to t("courses.manage.add_manual"), new_training_session_path(course_id: @course.id),
              class: "bg-primary-600 text-white text-sm font-bold py-2 px-4 rounded-lg hover:bg-primary-700 transition" %>
        <%= render 'delete_modal', course: @course %>
      <% end %>
      <%= link_to t("courses.manage.back_to_dashboard"), current_user.admin? ? dashboards_admin_path : dashboards_trainer_path,
            class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
    </div>

    <%# Mobile: stacked buttons %>
    <div class="sm:hidden flex flex-col gap-2 w-full">
      <% if current_user.admin? %>
        <div class="flex gap-2">
          <%= link_to edit_course_path(@course),
                class: "flex-1 text-center bg-white border border-gray-300 py-2.5 px-3 rounded-lg shadow-sm text-sm font-bold text-gray-700 active:bg-gray-100 transition min-h-11" do %>
            <%= t("courses.manage.edit") %>
          <% end %>
          <%= link_to new_training_session_path(course_id: @course.id),
                class: "flex-1 text-center bg-primary-600 text-white text-sm font-bold py-2.5 px-3 rounded-lg active:bg-primary-800 transition min-h-11" do %>
            <%= t("courses.manage.add_training") %>
          <% end %>
        </div>
        <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
              class: "text-center bg-purple-100 text-purple-700 text-sm font-bold py-2.5 px-3 rounded-lg active:bg-purple-200 transition min-h-11" %>
        <%= render 'delete_modal', course: @course %>
      <% end %>
      <%= link_to t("courses.manage.back_to_dashboard"), current_user.admin? ? dashboards_admin_path : dashboards_trainer_path,
            class: "text-center bg-white border border-gray-300 py-2.5 px-3 rounded-lg shadow-sm text-sm font-bold text-gray-700 active:bg-gray-100 transition min-h-11" %>
    </div>
  </div>

  <%# ── Live-Banner ─────────────────────────────────────────────────────── %>
  <% if live_session %>
    <div class="mb-6 bg-green-50 border border-green-300 rounded-xl px-4 sm:px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <span class="relative flex h-3 w-3 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
        </span>
        <div>
          <p class="font-bold text-green-900"><%= t("courses.manage.live_now") %></p>
          <p class="text-sm text-green-700">
            <%= live_session.start_time.strftime("%-d. %B %Y, %H:%M") %> &ndash;
            <%= live_session.end_time.strftime("%H:%M") %> <%= t("misc.time_suffix") %>
          </p>
        </div>
      </div>
      <%= link_to t("courses.manage.open_attendance"), training_session_path(live_session),
            class: "shrink-0 w-full sm:w-auto text-center bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-bold py-2.5 px-5 rounded-lg text-sm transition min-h-11" %>
    </div>
  <% end %>

  <%# ── Stats ───────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 sm:mb-8">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-gray-900"><%= total_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.sessions_label") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-primary-600"><%= upcoming_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.upcoming") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-green-600"><%= confirmed_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.confirmed") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-orange-500"><%= waitlist_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.waitlist") %></p>
    </div>
    <% if pending_count > 0 %>
    <div class="bg-white rounded-xl border border-yellow-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-yellow-500"><%= pending_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.payment_open") %></p>
    </div>
    <% end %>
  </div>

  <%# ── Sessions ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 mb-6 sm:mb-8 overflow-hidden">
    <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-base sm:text-lg font-bold text-gray-900"><%= t("courses.manage.trainings_title") %></h2>
      <span class="text-sm text-gray-400 font-medium"><%= t("courses.manage.dates_count", count: total_count) %></span>
    </div>

    <% if all_sessions.any? %>
      <% sessions_by_month.each do |month_start, sessions| %>
        <%
          month_is_past = month_start && month_start.end_of_month < now.to_date
        %>

        <%# Monats-Trennzeile %>
        <div class="px-4 sm:px-6 py-2 bg-gray-50 border-b border-gray-100 flex items-center gap-2">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">
            <% if month_start %>
              <%= month_start.strftime("%B %Y") %>
            <% else %>
              <%= t("courses.manage.no_date") %>
            <% end %>
          </span>
          <span class="text-xs text-gray-400">(<%= sessions.size %>)</span>
          <% if month_is_past %>
            <span class="ml-auto text-xs text-gray-400 font-medium"><%= t("courses.manage.past") %></span>
          <% end %>
        </div>

        <% sessions.each do |session| %>
          <%
            is_live      = session.start_time && session.end_time && session.start_time <= now && session.end_time >= now
            is_past      = session.end_time ? session.end_time < now : (session.start_time && session.start_time < now)
            is_canceled  = session.is_canceled?
            attendance   = session.attendances.size
          %>

          <div class="px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-3 border-b border-gray-50 last:border-0
            <%= is_live ? 'bg-green-50' : (is_past ? 'opacity-60' : 'hover:bg-gray-50') %> transition">

            <div class="flex items-center gap-3 sm:gap-4">
              <%# Datum-Block %>
              <div class="w-11 sm:w-14 text-center shrink-0">
                <% if session.start_time %>
                  <p class="text-base sm:text-lg font-extrabold leading-none text-gray-900 <%= is_past ? 'text-gray-400' : '' %>">
                    <%= session.start_time.strftime("%-d") %>
                  </p>
                  <p class="text-xs font-semibold text-gray-500 uppercase">
                    <%= session.start_time.strftime("%b") %>
                  </p>
                <% else %>
                  <p class="text-xs text-gray-400 font-medium">&mdash;</p>
                <% end %>
              </div>

              <%# Details %>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <% if session.start_time %>
                    <span class="font-semibold text-gray-900 text-sm">
                      <span class="hidden sm:inline"><%= session.start_time.strftime("%A") %>, </span>
                      <span class="sm:hidden"><%= session.start_time.strftime("%a") %>, </span>
                      <% if session.end_time %>
                        <%= session.start_time.strftime("%H:%M") %> &ndash; <%= session.end_time.strftime("%H:%M") %>
                      <% else %>
                        <%= session.start_time.strftime("%H:%M") %> <%= t("misc.time_suffix") %>
                      <% end %>
                    </span>
                  <% end %>

                  <% if is_live %>
                    <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-800 text-xs font-bold px-2.5 py-0.5 rounded-full">
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                      </span>
                      Live
                    </span>
                  <% elsif is_canceled %>
                    <span class="bg-red-100 text-red-700 text-xs font-bold px-2.5 py-0.5 rounded-full"><%= t("courses.manage.cancelled") %></span>
                  <% end %>
                </div>

                <p class="text-xs text-gray-400 mt-0.5 truncate">
                  <%= @course.location.presence || t("courses.manage.no_location") %>
                  <span class="mx-1">&middot;</span>
                  <%= attendance %> <%= t("courses.manage.present", count: attendance) %>
                </p>
              </div>
            </div>

            <%# Aktionen %>
            <div class="flex items-center gap-2 shrink-0 sm:ml-0 ml-14">
              <% if is_live %>
                <%= link_to t("courses.manage.attendance_control"), training_session_path(session),
                      class: "bg-green-600 hover:bg-green-700 active:bg-green-800 text-white text-sm font-bold py-2 px-4 rounded-lg transition min-h-11 flex items-center" %>
              <% else %>
                <%= link_to t("courses.manage.attendance_control"), training_session_path(session),
                      class: "bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 text-sm font-bold py-2 px-4 rounded-lg transition min-h-11 flex items-center" %>
              <% end %>
            </div>

          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 text-sm font-medium"><%= t("courses.manage.no_sessions") %></p>
        <% if current_user.admin? %>
          <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
                class: "mt-3 inline-block text-primary-600 font-bold hover:underline text-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Teilnehmende ────────────────────────────────────────────────────── %>
  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden">
    <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100">
      <h2 class="text-base sm:text-lg font-bold text-gray-900">
        <%= t("courses.manage.participants_title") %>
      </h2>
      <p class="text-sm font-medium text-gray-400 mt-0.5">
        <%= confirmed_count %> <%= t("courses.manage.confirmed_label") %><% if waitlist_count > 0 %>, <%= waitlist_count %> <%= t("courses.manage.waitlist") %><% end %><% if pending_count > 0 %>, <%= pending_count %> <%= t("courses.manage.payment_open") %><% end %>
      </p>
    </div>

    <% if @course.course_registrations.any? %>

      <%# ── Mobile: Card-Layout ────────────────────────────────────────── %>
      <div class="sm:hidden divide-y divide-gray-100">
        <% @course.course_registrations.includes(:participant).order(status: :asc).each do |reg| %>
          <% p = reg.participant %>
          <div class="p-4">
            <%# Name + Status %>
            <div class="flex items-start justify-between gap-2 mb-2">
              <div class="min-w-0">
                <p class="font-semibold text-gray-900 text-sm truncate"><%= p.first_name %> <%= p.last_name %></p>
                <% if reg.status == "ausstehend" && reg.sumup_checkout_id.present? && !reg.payment_cleared? %>
                  <span class="inline-flex items-center gap-1 bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full mt-1">
                    <%= t("courses.manage.payment_pending") %>
                  </span>
                <% end %>
              </div>
              <% case reg.status %>
              <% when 'bestätigt' %>
                <span class="shrink-0 bg-green-100 text-green-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_confirmed") %></span>
              <% when 'warteliste' %>
                <span class="shrink-0 bg-orange-100 text-orange-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_waitlist") %></span>
              <% when 'ausstehend' %>
                <span class="shrink-0 bg-yellow-100 text-yellow-700 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_open") %></span>
              <% else %>
                <span class="shrink-0 bg-gray-100 text-gray-600 text-xs font-bold px-2.5 py-1 rounded-full"><%= reg.status_label %></span>
              <% end %>
            </div>

            <%# Zahlungsstatus %>
            <% if @course.has_payment? %>
              <div class="mb-3">
                <% if reg.payment_cleared? %>
                  <span class="inline-flex items-center gap-1 text-green-700 font-semibold text-xs">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    <%= t("courses.manage.paid") %>
                  </span>
                <% else %>
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-yellow-600 font-medium text-xs"><%= t("courses.manage.payment_pending") %></span>
                    <% if current_user.admin? %>
                      <%= button_to mark_as_paid_course_registration_path(reg),
                            method: :post,
                            class: "text-xs bg-green-50 active:bg-green-200 text-green-700 font-semibold border border-green-200 px-2.5 py-1.5 rounded-lg transition cursor-pointer min-h-11 flex items-center",
                            data: { turbo_confirm: t("courses.manage.mark_paid_confirm", name: "#{p.first_name} #{p.last_name}") } do %>
                        <%= t("courses.manage.cash_received") %>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%# Actions %>
            <div class="flex gap-2">
              <%# Details-Button + Modal %>
              <div data-controller="modal" class="flex-1">
                <button type="button"
                        data-action="click->modal#open"
                        class="w-full text-center text-gray-600 font-bold bg-gray-100 active:bg-gray-200 py-2.5 px-3 rounded-lg text-sm transition cursor-pointer min-h-11">
                  <%= t("courses.manage.details") %>
                </button>

                <div data-modal-target="dialog"
                     data-action="click->modal#backdropClose"
                     class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4">
                  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-5 sm:p-6 text-left">
                    <div class="flex items-center gap-3 sm:gap-4 mb-5">
                      <div class="h-12 w-12 sm:h-14 sm:w-14 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-extrabold text-lg sm:text-xl shrink-0">
                        <%= p.first_name&.first&.upcase %><%= p.last_name&.first&.upcase %>
                      </div>
                      <div class="min-w-0">
                        <h3 class="text-lg sm:text-xl font-extrabold text-gray-900 leading-tight truncate"><%= p.first_name %> <%= p.last_name %></h3>
                        <p class="text-xs text-gray-400 font-medium mt-0.5"><%= p.gender&.capitalize %></p>
                      </div>
                    </div>

                    <dl class="space-y-3 text-sm mb-6">
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.birthdate") %></dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= p.date_of_birth&.strftime("%d.%m.%Y") || "&mdash;".html_safe %></dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.email") %></dt>
                        <dd class="font-semibold text-gray-900 text-right truncate"><%= p.user.email %></dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.phone") %></dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= p.phone_number.presence || "&mdash;".html_safe %></dd>
                      </div>
                      <% if p.ahv_number.present? %>
                        <div class="flex justify-between gap-4">
                          <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.ahv_number") %></dt>
                          <dd class="font-semibold text-gray-900 text-right"><%= p.ahv_number %></dd>
                        </div>
                      <% end %>
                      <div class="flex justify-between gap-4 pt-2 border-t border-gray-100">
                        <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.registration_status") %></dt>
                        <dd class="font-semibold text-right">
                          <% case reg.status %>
                          <% when 'bestätigt' %>
                            <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_confirmed") %></span>
                          <% when 'warteliste' %>
                            <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_waitlist") %></span>
                          <% when 'ausstehend' %>
                            <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_payment_open") %></span>
                          <% else %>
                            <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2 py-0.5 rounded-full"><%= reg.status_label %></span>
                          <% end %>
                        </dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.payment_label") %></dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= reg.payment_cleared ? t("courses.manage.payment_cleared") : t("courses.manage.payment_outstanding") %></dd>
                      </div>
                    </dl>

                    <button type="button"
                            data-action="click->modal#close"
                            class="w-full bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 rounded-xl transition cursor-pointer min-h-11">
                      <%= t("courses.manage.close") %>
                    </button>
                  </div>
                </div>
              </div>

              <% if current_user.admin? %>
                <%= link_to edit_course_registration_path(reg),
                      class: "flex items-center justify-center w-11 h-11 rounded-lg bg-primary-50 active:bg-primary-100 text-primary-600 shrink-0",
                      aria: { label: t("courses.manage.edit_aria", name: p.first_name) } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
              <% end %>

              <% if reg.status != "storniert" %>
                <%# Abmelden-Button + Modal %>
                <div data-controller="modal">
                  <button type="button"
                          data-action="click->modal#open"
                          class="flex items-center justify-center w-11 h-11 rounded-lg bg-red-50 active:bg-red-100 text-red-600 shrink-0 cursor-pointer"
                          aria-label="<%= t("courses.manage.unsubscribe_aria", name: p.first_name) %>">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>

                  <div data-modal-target="dialog"
                       data-action="click->modal#backdropClose"
                       class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4">
                    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-5 sm:p-6 text-left">
                      <div class="flex items-center gap-3 mb-5">
                        <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
                          <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                        </div>
                        <div>
                          <h3 class="text-lg font-extrabold text-gray-900"><%= t("courses.manage.unsubscribe_confirm", name: "#{p.first_name} #{p.last_name}") %></h3>
                          <p class="text-xs text-gray-500"><%= t("courses.manage.unsubscribe_parents_info") %></p>
                        </div>
                      </div>

                      <%= form_with url: trainer_cancel_course_registration_path(reg), method: :post, data: { turbo: false }, class: "space-y-4" do %>
                        <div>
                          <label class="block text-xs font-bold text-gray-700 mb-1.5 uppercase tracking-wide"><%= t("courses.manage.reason_label") %> <span class="font-normal text-gray-400"><%= t("courses.manage.reason_optional") %></span></label>
                          <textarea name="cancellation_reason"
                                    rows="3"
                                    placeholder="<%= t("courses.manage.reason_placeholder") %>"
                                    class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
                        </div>

                        <label class="flex items-start gap-3 cursor-pointer bg-amber-50 border border-amber-200 rounded-lg p-3">
                          <%= check_box_tag "notify_admin", "1",
                                reg.payment_cleared? && @course.has_payment?,
                                class: "mt-0.5 h-5 w-5 text-amber-600 border-gray-300 rounded cursor-pointer focus:ring-amber-500" %>
                          <div>
                            <p class="text-sm font-bold text-amber-900"><%= t("courses.manage.notify_admin_title") %></p>
                            <p class="text-xs text-amber-700 mt-0.5">
                              <%= t("courses.manage.notify_admin_body") %>
                            </p>
                          </div>
                        </label>

                        <div class="flex gap-3 pt-2">
                          <button type="submit"
                                  class="flex-1 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold py-2.5 px-4 rounded-xl text-sm transition cursor-pointer min-h-11">
                            <%= t("courses.manage.unsubscribe_now") %>
                          </button>
                          <button type="button"
                                  data-action="click->modal#close"
                                  class="flex-1 bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition min-h-11">
                            <%= t("courses.manage.cancel") %>
                          </button>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# ── Desktop: Tabelle ───────────────────────────────────────────── %>
      <table class="hidden sm:table min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_name") %></th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_status") %></th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_paid") %></th>
            <th class="py-3 px-6 text-right text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @course.course_registrations.includes(:participant).order(status: :asc).each do |reg| %>
            <% p = reg.participant %>
            <tr class="hover:bg-gray-50 transition">
              <td class="py-4 px-6 text-sm">
                <span class="font-semibold text-gray-900"><%= p.first_name %> <%= p.last_name %></span>
                <% if reg.status == "ausstehend" && reg.sumup_checkout_id.present? && !reg.payment_cleared? %>
                  <span class="ml-1.5 inline-flex items-center gap-1 bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    </svg>
                    <%= t("courses.manage.payment_pending") %>
                  </span>
                <% end %>
              </td>
              <td class="py-4 px-6">
                <% case reg.status %>
                <% when 'bestätigt' %>
                  <span class="bg-green-100 text-green-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_confirmed") %></span>
                <% when 'warteliste' %>
                  <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_waitlist") %></span>
                <% when 'ausstehend' %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2.5 py-1 rounded-full"><%= t("courses.manage.status_payment_open") %></span>
                <% else %>
                  <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2.5 py-1 rounded-full"><%= reg.status_label %></span>
                <% end %>
              </td>
              <td class="py-4 px-6 text-sm">
                <% if !@course.has_payment? %>
                  <span class="text-gray-300 font-medium">&mdash;</span>
                <% elsif reg.payment_cleared? %>
                  <span class="inline-flex items-center gap-1 text-green-700 font-semibold">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    <%= t("courses.manage.paid") %>
                  </span>
                <% else %>
                  <div class="flex items-center gap-2">
                    <span class="text-yellow-600 font-medium"><%= t("courses.manage.payment_outstanding") %></span>
                    <% if current_user.admin? %>
                      <%= button_to mark_as_paid_course_registration_path(reg),
                            method: :post,
                            class: "text-xs bg-green-50 hover:bg-green-100 text-green-700 font-semibold border border-green-200 px-2 py-1 rounded-lg transition cursor-pointer",
                            data: { turbo_confirm: t("courses.manage.mark_paid_confirm", name: "#{p.first_name} #{p.last_name}") } do %>
                        <%= t("courses.manage.cash_received") %>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </td>
              <td class="py-4 px-6 text-right text-sm">
                <div class="inline-flex items-center gap-3">
                  <%# Details-Button + Modal %>
                  <div data-controller="modal" class="contents">
                    <button type="button"
                            data-action="click->modal#open"
                            class="text-gray-600 font-bold hover:text-gray-900 transition cursor-pointer">
                      <%= t("courses.manage.details") %>
                    </button>

                    <div data-modal-target="dialog"
                         data-action="click->modal#backdropClose"
                         class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4">
                      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 text-left">
                        <div class="flex items-center gap-4 mb-5">
                          <div class="h-14 w-14 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-extrabold text-xl shrink-0">
                            <%= p.first_name&.first&.upcase %><%= p.last_name&.first&.upcase %>
                          </div>
                          <div>
                            <h3 class="text-xl font-extrabold text-gray-900 leading-tight"><%= p.first_name %> <%= p.last_name %></h3>
                            <p class="text-xs text-gray-400 font-medium mt-0.5"><%= p.gender&.capitalize %></p>
                          </div>
                        </div>

                        <dl class="space-y-3 text-sm mb-6">
                          <div class="flex justify-between gap-4">
                            <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.birthdate") %></dt>
                            <dd class="font-semibold text-gray-900 text-right"><%= p.date_of_birth&.strftime("%d.%m.%Y") || "—" %></dd>
                          </div>
                          <div class="flex justify-between gap-4">
                            <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.email") %></dt>
                            <dd class="font-semibold text-gray-900 text-right truncate"><%= p.user.email %></dd>
                          </div>
                          <div class="flex justify-between gap-4">
                            <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.phone") %></dt>
                            <dd class="font-semibold text-gray-900 text-right"><%= p.phone_number.presence || "—" %></dd>
                          </div>
                          <% if p.ahv_number.present? %>
                            <div class="flex justify-between gap-4">
                              <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.ahv_number") %></dt>
                              <dd class="font-semibold text-gray-900 text-right"><%= p.ahv_number %></dd>
                            </div>
                          <% end %>
                          <div class="flex justify-between gap-4 pt-2 border-t border-gray-100">
                            <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.registration_status") %></dt>
                            <dd class="font-semibold text-right">
                              <% case reg.status %>
                              <% when 'bestätigt' %>
                                <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_confirmed") %></span>
                              <% when 'warteliste' %>
                                <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_waitlist") %></span>
                              <% when 'ausstehend' %>
                                <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= t("courses.manage.status_payment_open") %></span>
                              <% else %>
                                <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2 py-0.5 rounded-full"><%= reg.status_label %></span>
                              <% end %>
                            </dd>
                          </div>
                          <div class="flex justify-between gap-4">
                            <dt class="text-gray-400 font-medium shrink-0"><%= t("courses.manage.payment_label") %></dt>
                            <dd class="font-semibold text-gray-900 text-right"><%= reg.payment_cleared ? t("courses.manage.payment_cleared") : t("courses.manage.payment_outstanding") %></dd>
                          </div>
                        </dl>

                        <button type="button"
                                data-action="click->modal#close"
                                class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 rounded-xl transition cursor-pointer min-h-11">
                          <%= t("courses.manage.close") %>
                        </button>
                      </div>
                    </div>
                  </div>

                  <% if current_user.admin? %>
                    <%= link_to t("courses.manage.edit_link"), edit_course_registration_path(reg),
                          class: "text-primary-600 font-bold hover:text-primary-800" %>
                  <% end %>

                  <% if reg.status != "storniert" %>
                    <%# Abmelden-Button + Modal %>
                    <div data-controller="modal" class="contents">
                      <button type="button"
                              data-action="click->modal#open"
                              class="text-red-600 font-bold hover:text-red-800 transition cursor-pointer">
                        <%= t("courses.manage.unsubscribe") %>
                      </button>

                      <div data-modal-target="dialog"
                           data-action="click->modal#backdropClose"
                           class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4">
                        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 text-left">
                          <div class="flex items-center gap-3 mb-5">
                            <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
                              <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                              </svg>
                            </div>
                            <div>
                              <h3 class="text-lg font-extrabold text-gray-900"><%= t("courses.manage.unsubscribe_confirm", name: "#{p.first_name} #{p.last_name}") %></h3>
                              <p class="text-xs text-gray-500"><%= t("courses.manage.unsubscribe_parents_info") %></p>
                            </div>
                          </div>

                          <%= form_with url: trainer_cancel_course_registration_path(reg), method: :post, data: { turbo: false }, class: "space-y-4" do %>
                            <div>
                              <label class="block text-xs font-bold text-gray-700 mb-1.5 uppercase tracking-wide"><%= t("courses.manage.reason_label") %> <span class="font-normal text-gray-400"><%= t("courses.manage.reason_optional") %></span></label>
                              <textarea name="cancellation_reason"
                                        rows="3"
                                        placeholder="<%= t("courses.manage.reason_placeholder") %>"
                                        class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
                            </div>

                            <label class="flex items-start gap-3 cursor-pointer bg-amber-50 border border-amber-200 rounded-lg p-3">
                              <%= check_box_tag "notify_admin", "1",
                                    reg.payment_cleared? && @course.has_payment?,
                                    class: "mt-0.5 h-4 w-4 text-amber-600 border-gray-300 rounded cursor-pointer focus:ring-amber-500" %>
                              <div>
                                <p class="text-sm font-bold text-amber-900"><%= t("courses.manage.notify_admin_title") %></p>
                                <p class="text-xs text-amber-700 mt-0.5">
                                  <%= t("courses.manage.notify_admin_body") %>
                                  <%= t("courses.manage.notify_admin_body_detail") %>
                                </p>
                              </div>
                            </label>

                            <div class="flex gap-3 pt-2">
                              <button type="submit"
                                      class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-4 rounded-xl text-sm transition cursor-pointer min-h-11">
                                <%= t("courses.manage.unsubscribe_now") %>
                              </button>
                              <button type="button"
                                      data-action="click->modal#close"
                                      class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition min-h-11">
                                <%= t("courses.manage.cancel") %>
                              </button>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-gray-500 text-sm font-medium"><%= t("courses.manage.no_registrations") %></p>
      </div>
    <% end %>
  </div>

</div>
