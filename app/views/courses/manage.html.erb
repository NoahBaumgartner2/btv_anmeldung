<% content_for :head do %>
  <%= tag.meta name: "turbo-cache-control", content: "no-cache" %>
<% end %>

<%
  now = Time.current
  all_sessions = @course.training_sessions.order(:start_time).to_a

  sessions_by_month = all_sessions.group_by { |s|
    s.start_time ? s.start_time.beginning_of_month : nil
  }

  total_count     = all_sessions.size
  past_count      = all_sessions.count { |s| s.end_time ? s.end_time < now : s.start_time && s.start_time < now }
  upcoming_count  = all_sessions.count { |s|
    s.start_time && !s.is_canceled &&
    (s.end_time ? s.end_time > now : s.start_time > now)
  }
  live_session    = all_sessions.find do |s|
    next unless s.start_time && s.start_time <= now && !s.is_canceled
    s.end_time ? s.end_time > now : s.start_time > 2.hours.ago
  end

  waitlist_count  = @course.course_registrations.where(status: 'warteliste').count
  trial_count     = @course.course_registrations.where(status: 'schnuppern').count

  status_order = { 'bestätigt' => 0, 'platz_frei' => 1, 'schnuppern' => 2, 'warteliste' => 3, 'ausstehend' => 4 }.freeze
  # Pro Teilnehmer nur EINE Anmeldung anzeigen. Dabei eine aktive (nicht stornierte)
  # Anmeldung bevorzugen, sonst würde z.B. ein noch offener "ausstehend"-Datensatz von
  # einer neueren Stornierung verdeckt – er bliebe unsichtbar, obwohl er den Platz
  # belegt (und damit die Warteliste-Hochstufung blockiert). Innerhalb gleicher
  # Aktivität gewinnt die neueste Anmeldung.
  sorted_registrations = @course.course_registrations
    .includes(:participant)
    .to_a
    .sort_by { |r| [r.status == "storniert" ? 1 : 0, -(r.created_at&.to_i || 0)] }
    .uniq(&:participant_id)
    .sort_by { |r| [status_order.fetch(r.status, 99), r.participant&.last_name.to_s] }
  active_registrations    = sorted_registrations.reject { |r| r.status == "storniert" }
  cancelled_registrations = sorted_registrations.select { |r| r.status == "storniert" }

  # Anzeige-Aufteilung: NUR reine "ausstehend"-Anmeldungen (gestarteter, aber nie
  # abgeschlossener Checkout) wandern in die zugeklappte Sektion "Zahlung ausstehend".
  # Bestätigte-aber-noch-nicht-bezahlte Teilnehmer (z.B. manuell erfasst, Barzahlung
  # offen) sind vollwertige Teilnehmer: Sie belegen einen Platz (siehe
  # OCCUPYING_STATUSES / Warteliste-Logik) und bleiben daher in der Hauptliste und in
  # der bestätigt-Zählung. Der offene Zahlungsstatus inkl. "Bar erhalten"-Button wird
  # direkt auf ihrer Teilnehmer-Karte angezeigt.
  pending_payment_registrations = active_registrations.select { |r| r.status == "ausstehend" }
  main_registrations = active_registrations - pending_payment_registrations

  confirmed_count = main_registrations.count { |r| r.status == "bestätigt" }
  pending_count   = pending_payment_registrations.size
%>

<div class="max-w-6xl mx-auto w-full px-4 mt-6 sm:mt-8 mb-16" data-course-id="<%= @course.id %>">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 sm:mb-8 gap-4">
    <div>
      <span class="text-red-600 font-bold text-sm tracking-wider uppercase mb-1 block"><%= t("courses.manage.header_label") %></span>
      <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900"><%= @course.title %></h1>
    </div>

    <%# Desktop: inline buttons %>
    <div class="hidden sm:flex gap-2 flex-wrap">
      <% if current_user.admin? %>
        <%= link_to t("courses.manage.edit_course"), edit_course_path(@course),
              class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
        <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
              class: "bg-purple-100 text-purple-700 text-sm font-bold py-2 px-4 rounded-lg hover:bg-purple-200 transition" %>
        <%= link_to t("courses.manage.add_manual"), new_training_session_path(course_id: @course.id),
              class: "bg-primary-600 text-white text-sm font-bold py-2 px-4 rounded-lg hover:bg-primary-700 transition" %>
        <%= render 'delete_modal', course: @course %>
      <% end %>
      <%= link_to t("courses.manage.back_to_dashboard"), current_user.admin? ? dashboards_admin_path : dashboards_trainer_path,
            class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
    </div>

    <%# Mobile: stacked buttons %>
    <div class="sm:hidden flex flex-col gap-2 w-full">
      <% if current_user.admin? %>
        <div class="flex gap-2">
          <%= link_to edit_course_path(@course),
                class: "flex-1 text-center bg-white border border-gray-300 py-2.5 px-3 rounded-lg shadow-sm text-sm font-bold text-gray-700 active:bg-gray-100 transition min-h-11" do %>
            <%= t("courses.manage.edit") %>
          <% end %>
          <%= link_to new_training_session_path(course_id: @course.id),
                class: "flex-1 text-center bg-primary-600 text-white text-sm font-bold py-2.5 px-3 rounded-lg active:bg-primary-800 transition min-h-11" do %>
            <%= t("courses.manage.add_training") %>
          <% end %>
        </div>
        <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
              class: "text-center bg-purple-100 text-purple-700 text-sm font-bold py-2.5 px-3 rounded-lg active:bg-purple-200 transition min-h-11" %>
        <%= render 'delete_modal', course: @course %>
      <% end %>
      <%= link_to t("courses.manage.back_to_dashboard"), current_user.admin? ? dashboards_admin_path : dashboards_trainer_path,
            class: "text-center bg-white border border-gray-300 py-2.5 px-3 rounded-lg shadow-sm text-sm font-bold text-gray-700 active:bg-gray-100 transition min-h-11" %>
    </div>
  </div>

  <%# ── Live-Banner ─────────────────────────────────────────────────────── %>
  <% if live_session %>
    <div class="mb-6 bg-green-50 border border-green-300 rounded-xl px-4 sm:px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <span class="relative flex h-3 w-3 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
        </span>
        <div>
          <p class="font-bold text-green-900"><%= t("courses.manage.live_now") %></p>
          <p class="text-sm text-green-700">
            <%= live_session.start_time.in_time_zone.strftime("%-d. %B %Y, %H:%M") %>
            <% if live_session.end_time %>&ndash; <%= live_session.end_time.in_time_zone.strftime("%H:%M") %> <%= t("misc.time_suffix") %><% end %>
          </p>
        </div>
      </div>
      <%= link_to t("courses.manage.open_attendance"), training_session_path(live_session),
            class: "shrink-0 w-full sm:w-auto text-center bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-bold py-2.5 px-5 rounded-lg text-sm transition min-h-11" %>
    </div>
  <% end %>

  <%# ── Stats ─────────────────────────────────────────────────────────────── %>

  <%# Teilnehmer-Statistik (immer sichtbar) %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-green-600"><%= confirmed_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.confirmed") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-orange-500"><%= waitlist_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.waitlist") %></p>
    </div>
    <% if pending_count > 0 %>
    <div class="bg-white rounded-xl border border-yellow-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-yellow-500"><%= pending_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.payment_open") %></p>
    </div>
    <% end %>
    <% if trial_count > 0 %>
    <div class="bg-white rounded-xl border border-amber-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-amber-500"><%= trial_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("course_registrations.statuses.schnuppern") %></p>
    </div>
    <% end %>
  </div>

  <%# Session-Statistik %>
  <div class="grid grid-cols-2 gap-3 mb-6 sm:mb-8">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-gray-900"><%= total_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.sessions_label") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-3 sm:p-4 text-center">
      <p class="text-xl sm:text-2xl font-extrabold text-primary-600"><%= upcoming_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide"><%= t("courses.manage.upcoming") %></p>
    </div>
  </div>

  <%# ── Manuelle Anmeldung (nur Trainer/Admin mit Berechtigung) ───────────── %>
  <%
    _trainer = Trainer.find_by(user: current_user)
    _ct = @course.course_trainers.find_by(trainer: _trainer)
    _can_manually_enroll = current_user.admin? || _ct&.can_manually_enroll?
  %>
  <% if _can_manually_enroll %>
    <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden mb-6 sm:mb-8"
         data-controller="manual-enroll">
      <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100">
        <h2 class="text-base sm:text-lg font-bold text-gray-900">Kind manuell anmelden</h2>
        <p class="text-sm font-medium text-gray-400 mt-0.5">Bestehende Familie suchen oder neue Familie erfassen</p>
      </div>

      <div class="p-4 sm:p-6">
        <%# Tab-Wechsel %>
        <div class="flex gap-2 mb-5">
          <button type="button"
                  data-action="click->manual-enroll#showSearch"
                  data-manual-enroll-target="searchTab"
                  class="flex-1 py-2 px-4 rounded-lg text-sm font-bold bg-primary-600 text-white transition">
            Bestehende Familie suchen
          </button>
          <button type="button"
                  data-action="click->manual-enroll#showCreate"
                  data-manual-enroll-target="createTab"
                  class="flex-1 py-2 px-4 rounded-lg text-sm font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
            Neue Familie erstellen
          </button>
        </div>

        <%# Suche-Panel %>
        <div data-manual-enroll-target="searchPanel">
          <input type="text"
                 placeholder="Name oder E-Mail der Eltern / des Kindes..."
                 data-manual-enroll-target="searchInput"
                 data-action="input->manual-enroll#search"
                 class="block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 mb-3">

          <div data-manual-enroll-target="searchResults" class="space-y-2"></div>

          <%= form_with url: manual_enroll_course_path(@course), method: :post, data: { "manual-enroll-target": "enrollForm" }, class: "hidden" do |f| %>
            <%= f.hidden_field :participant_id, data: { "manual-enroll-target": "participantId" } %>
          <% end %>
        </div>

        <%# Neue Familie erstellen Panel %>
        <div data-manual-enroll-target="createPanel" class="hidden">
          <%= render "participants/form",
                participant: @manual_participant,
                form_url: manual_enroll_course_path(@course),
                submit_label: "Kind anmelden & Account erstellen",
                hide_cancel: true,
                hide_admin_section: true,
                manual_enroll_mode: true %>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Teilnehmende ────────────────────────────────────────────────────── %>
  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl mb-6 sm:mb-8">
    <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100">
      <h2 class="text-base sm:text-lg font-bold text-gray-900">
        <%= t("courses.manage.participants_title") %>
      </h2>
      <p class="text-sm font-medium text-gray-400 mt-0.5">
        <%= confirmed_count %> <%= t("courses.manage.confirmed_label") %><% if trial_count > 0 %>, <%= trial_count %> <%= t("course_registrations.statuses.schnuppern") %><% end %><% if waitlist_count > 0 %>, <%= waitlist_count %> <%= t("courses.manage.waitlist") %><% end %><% if pending_count > 0 %>, <%= pending_count %> <%= t("courses.manage.payment_open") %><% end %>
      </p>
    </div>

    <% if @course.course_registrations.count > 5 %>
      <div class="px-4 sm:px-6 py-3 border-b border-gray-100">
        <input type="text"
               id="participants-search"
               placeholder="Teilnehmer suchen..."
               class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
               oninput="filterParticipants(this.value)">
      </div>
    <% end %>

    <% if @course.course_registrations.any? %>

      <%# ── Mobile: Card-Layout ────────────────────────────────────────── %>
      <div class="<%= @course.course_registrations.count > 10 ? 'max-h-[600px] overflow-y-auto' : '' %>">
      <div class="sm:hidden divide-y divide-gray-100">
        <% main_registrations.each do |reg| %>
          <%= render "manage_participant_card", reg: reg %>
        <% end %>
      </div>
      </div>

      <%# ── Desktop: Tabelle ───────────────────────────────────────────── %>
      <div class="<%= @course.course_registrations.count > 10 ? 'max-h-[600px] overflow-y-auto' : '' %> overflow-hidden rounded-b-2xl">
      <table class="hidden sm:table w-full table-fixed divide-y divide-gray-200">
        <colgroup>
          <col class="w-[40%]">
          <col class="w-[22%]">
          <col class="w-[20%]">
          <col class="w-[18%]">
        </colgroup>
        <thead class="bg-gray-50">
          <tr>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_name") %></th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_status") %></th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_paid") %></th>
            <th class="py-3 px-6 text-right text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t("courses.manage.col_actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% main_registrations.each do |reg| %>
            <%= render "manage_participant_row", reg: reg %>
          <% end %>
        </tbody>
      </table>
      </div>

      <% if pending_payment_registrations.any? %>
        <details class="border-t border-gray-100">
          <summary class="px-4 sm:px-6 py-3 text-sm font-medium text-gray-400 cursor-pointer hover:text-gray-600 hover:bg-gray-50 transition list-none flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
            <%= t("courses.manage.pending_payment_section", count: pending_payment_registrations.count) %>
          </summary>
          <p class="px-4 sm:px-6 py-2 text-xs text-gray-400 bg-gray-50/50"><%= t("courses.manage.pending_payment_hint") %></p>

          <%# Mobile: Card-Layout %>
          <div class="sm:hidden divide-y divide-gray-100">
            <% pending_payment_registrations.each do |reg| %>
              <%= render "manage_participant_card", reg: reg %>
            <% end %>
          </div>

          <%# Desktop: Tabelle %>
          <div class="overflow-hidden">
            <table class="hidden sm:table w-full table-fixed divide-y divide-gray-200">
              <colgroup>
                <col class="w-[40%]">
                <col class="w-[22%]">
                <col class="w-[20%]">
                <col class="w-[18%]">
              </colgroup>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% pending_payment_registrations.each do |reg| %>
                  <%= render "manage_participant_row", reg: reg %>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      <% end %>

      <% if cancelled_registrations.any? %>
        <details class="border-t border-gray-100">
          <summary class="px-4 sm:px-6 py-3 text-sm font-medium text-gray-400 cursor-pointer hover:text-gray-600 hover:bg-gray-50 transition list-none flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
            <%= t("courses.manage.cancelled_registrations_label", count: cancelled_registrations.count) %>
          </summary>
          <div class="divide-y divide-gray-100 bg-gray-50/50">
            <% cancelled_registrations.each do |reg| %>
              <% p = reg.participant %>
              <div class="px-4 sm:px-6 py-3 flex items-center justify-between gap-3 opacity-60">
                <span class="text-sm font-medium text-gray-600"><%= p.first_name %> <%= p.last_name %></span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-gray-200 text-gray-500"><%= t("course_registrations.statuses.storniert") %></span>
              </div>
            <% end %>
          </div>
        </details>
      <% end %>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-gray-500 text-sm font-medium"><%= t("courses.manage.no_registrations") %></p>
      </div>
    <% end %>
  </div>

  <%# ── Zugriffsverwaltung (nur für restricted + admin) ─────────────────── %>
  <% if @course.restricted? && current_user.admin? %>
    <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden mb-6 sm:mb-8">
      <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100">
        <h2 class="text-base sm:text-lg font-bold text-gray-900">Zugriffsverwaltung</h2>
        <p class="text-sm font-medium text-gray-400 mt-0.5">Benutzer mit Zugriff auf diesen Kurs</p>
      </div>

      <%# Bestehende Zugriffe %>
      <% if @course.course_access_grants.any? %>
        <ul class="divide-y divide-gray-100">
          <% @course.course_access_grants.includes(:user).each do |grant| %>
            <li class="px-4 sm:px-6 py-3 flex items-center justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="text-sm font-medium text-gray-900"><%= grant.user.email %></span>
                <% if grant.confirmed? %>
                  <span class="text-green-600 font-semibold text-sm">Bestätigt</span>
                <% else %>
                  <span class="text-yellow-600 font-semibold text-sm">Eingeladen</span>
                <% end %>
              </div>
              <%= button_to revoke_access_course_path(@course, user_id: grant.user_id),
                    method: :delete,
                    class: "text-xs text-red-600 font-bold hover:text-red-800 transition cursor-pointer bg-transparent border-0 p-0",
                    data: { turbo_confirm: "Zugriff für #{grant.user.email} entfernen?" } do %>
                Entfernen
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-4 sm:px-6 py-4 text-sm text-gray-400 font-medium">
          Noch niemand eingeladen.
        </div>
      <% end %>

      <%# Zugriff erteilen %>
      <div class="px-4 sm:px-6 py-4 border-t border-gray-100 bg-gray-50">
        <%= form_with url: grant_access_course_path(@course), method: :post, class: "flex gap-2" do |f| %>
          <%= f.email_field :email,
                placeholder: "E-Mail-Adresse",
                required: true,
                class: "flex-1 min-w-0 rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <%= f.submit "Zugriff erteilen",
                class: "shrink-0 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold py-2 px-4 rounded-lg transition cursor-pointer" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Sessions ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-4 sm:px-6 py-4 sm:py-5 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-base sm:text-lg font-bold text-gray-900"><%= t("courses.manage.trainings_title") %></h2>
      <span class="text-sm text-gray-400 font-medium"><%= t("courses.manage.dates_count", count: total_count) %></span>
    </div>

    <% if all_sessions.any? %>
      <% sessions_by_month.each do |month_start, sessions| %>
        <%
          month_is_past = month_start && month_start.end_of_month < now.to_date
        %>

        <%# Monats-Trennzeile %>
        <div class="px-4 sm:px-6 py-2 bg-gray-50 border-b border-gray-100 flex items-center gap-2">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">
            <% if month_start %>
              <%= month_start.strftime("%B %Y") %>
            <% else %>
              <%= t("courses.manage.no_date") %>
            <% end %>
          </span>
          <span class="text-xs text-gray-400">(<%= sessions.size %>)</span>
          <% if month_is_past %>
            <span class="ml-auto text-xs text-gray-400 font-medium"><%= t("courses.manage.past") %></span>
          <% end %>
        </div>

        <% sessions.each do |session| %>
          <%
            is_live      = !session.is_canceled? && session.start_time && session.start_time <= now &&
                           (session.end_time ? session.end_time > now : session.start_time > 2.hours.ago)
            is_past      = session.end_time ? session.end_time < now : (session.start_time && session.start_time < now)
            is_canceled  = session.is_canceled?
            attendance   = session.attendances.size
          %>

          <div class="px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-3 border-b border-gray-50 last:border-0
            <%= is_live ? 'bg-green-50' : (is_past ? 'opacity-60' : 'hover:bg-gray-50') %> transition">

            <div class="flex items-center gap-3 sm:gap-4">
              <%# Datum-Block %>
              <div class="w-11 sm:w-14 text-center shrink-0">
                <% if session.start_time %>
                  <p class="text-base sm:text-lg font-extrabold leading-none text-gray-900 <%= is_past ? 'text-gray-400' : '' %>">
                    <%= session.start_time.in_time_zone.strftime("%-d") %>
                  </p>
                  <p class="text-xs font-semibold text-gray-500 uppercase">
                    <%= session.start_time.in_time_zone.strftime("%b") %>
                  </p>
                <% else %>
                  <p class="text-xs text-gray-400 font-medium">&mdash;</p>
                <% end %>
              </div>

              <%# Details %>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <% if session.start_time %>
                    <span class="font-semibold text-gray-900 text-sm">
                      <span class="hidden sm:inline"><%= session.start_time.in_time_zone.strftime("%A") %>, </span>
                      <span class="sm:hidden"><%= session.start_time.in_time_zone.strftime("%a") %>, </span>
                      <% if session.end_time %>
                        <%= session.start_time.in_time_zone.strftime("%H:%M") %> &ndash; <%= session.end_time.in_time_zone.strftime("%H:%M") %>
                      <% else %>
                        <%= session.start_time.in_time_zone.strftime("%H:%M") %> <%= t("misc.time_suffix") %>
                      <% end %>
                    </span>
                  <% end %>

                  <% if is_live %>
                    <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-800 text-xs font-bold px-2.5 py-0.5 rounded-full">
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                      </span>
                      Live
                    </span>
                  <% elsif is_canceled %>
                    <span class="bg-red-100 text-red-700 text-xs font-bold px-2.5 py-0.5 rounded-full"><%= t("courses.manage.cancelled") %></span>
                  <% end %>
                </div>

                <p class="text-xs text-gray-400 mt-0.5 truncate">
                  <%= @course.location.presence || t("courses.manage.no_location") %>
                  <span class="mx-1">&middot;</span>
                  <%= attendance %> <%= t("courses.manage.present", count: attendance) %>
                </p>
              </div>
            </div>

            <%# Aktionen %>
            <div class="flex items-center gap-2 shrink-0 sm:ml-0 ml-14">
              <% if is_live %>
                <%= link_to t("courses.manage.attendance_control"), training_session_path(session),
                      class: "bg-green-600 hover:bg-green-700 active:bg-green-800 text-white text-sm font-bold py-2 px-4 rounded-lg transition min-h-11 flex items-center" %>
              <% else %>
                <%= link_to t("courses.manage.attendance_control"), training_session_path(session),
                      class: "bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 text-sm font-bold py-2 px-4 rounded-lg transition min-h-11 flex items-center" %>
              <% end %>
            </div>

          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 text-sm font-medium"><%= t("courses.manage.no_sessions") %></p>
        <% if current_user.admin? %>
          <%= link_to t("courses.manage.auto_generate"), generate_trainings_course_path(@course),
                class: "mt-3 inline-block text-primary-600 font-bold hover:underline text-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>

</div>

<script>
function filterParticipants(query) {
  const q = query.toLowerCase().trim();

  // Mobile cards
  document.querySelectorAll('.sm\\:hidden [data-participant-name]').forEach(function(card) {
    card.closest('.p-4') && (card.closest('.p-4').style.display = (!q || card.dataset.participantName.toLowerCase().includes(q)) ? '' : 'none');
  });

  // Desktop rows
  document.querySelectorAll('table tbody tr[data-participant-name]').forEach(function(row) {
    row.style.display = (!q || row.dataset.participantName.toLowerCase().includes(q)) ? '' : 'none';
  });
}
</script>
