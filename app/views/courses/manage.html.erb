<%
  now = Time.current
  all_sessions = @course.training_sessions.order(:start_time).to_a

  sessions_by_month = all_sessions.group_by { |s|
    s.start_time ? s.start_time.beginning_of_month : nil
  }

  total_count     = all_sessions.size
  past_count      = all_sessions.count { |s| s.end_time ? s.end_time < now : s.start_time && s.start_time < now }
  upcoming_count  = all_sessions.count { |s| s.start_time && s.start_time > now && !s.is_canceled }
  live_session    = all_sessions.find { |s| s.start_time && s.end_time && s.start_time <= now && s.end_time >= now }

  confirmed_count = @course.course_registrations.where(status: 'bestätigt').count
  waitlist_count  = @course.course_registrations.where(status: 'warteliste').count
  pending_count   = @course.course_registrations.where(status: 'ausstehend').count
%>

<div class="max-w-6xl mx-auto w-full px-4 mt-8 mb-16">

  <%# ── Header ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <span class="text-red-600 font-bold text-sm tracking-wider uppercase mb-1 block">Maschinenraum</span>
      <h1 class="font-extrabold text-3xl text-gray-900"><%= @course.title %></h1>
    </div>
    <div class="flex gap-2 flex-wrap">
      <% if current_user.admin? %>
        <%= link_to "Kurs bearbeiten", edit_course_path(@course),
              class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
        <%= link_to "Automatisch generieren", generate_trainings_course_path(@course),
              class: "bg-purple-100 text-purple-700 text-sm font-bold py-2 px-4 rounded-lg hover:bg-purple-200 transition" %>
        <%= link_to "+ Manuell hinzufügen", new_training_session_path(course_id: @course.id),
              class: "bg-primary-600 text-white text-sm font-bold py-2 px-4 rounded-lg hover:bg-primary-700 transition" %>
      <% end %>
      <%= link_to "Zurück zum Dashboard", current_user.admin? ? dashboards_admin_path : dashboards_trainer_path,
            class: "bg-white border border-gray-300 py-2 px-4 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition" %>
    </div>
  </div>

  <%# ── Live-Banner ─────────────────────────────────────────────────────── %>
  <% if live_session %>
    <div class="mb-6 bg-green-50 border border-green-300 rounded-xl px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
        </span>
        <div>
          <p class="font-bold text-green-900">Training läuft gerade</p>
          <p class="text-sm text-green-700">
            <%= live_session.start_time.strftime("%-d. %B %Y, %H:%M") %> –
            <%= live_session.end_time.strftime("%H:%M") %> Uhr
          </p>
        </div>
      </div>
      <%= link_to "Präsenzkontrolle öffnen", training_session_path(live_session),
            class: "shrink-0 bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-5 rounded-lg text-sm transition" %>
    </div>
  <% end %>

  <%# ── Stats ───────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 text-center">
      <p class="text-2xl font-extrabold text-gray-900"><%= total_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide">Sessions total</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 text-center">
      <p class="text-2xl font-extrabold text-primary-600"><%= upcoming_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide">Bevorstehend</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 text-center">
      <p class="text-2xl font-extrabold text-green-600"><%= confirmed_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide">Bestätigt</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 text-center">
      <p class="text-2xl font-extrabold text-orange-500"><%= waitlist_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide">Warteliste</p>
    </div>
    <% if pending_count > 0 %>
    <div class="bg-white rounded-xl border border-yellow-200 shadow-sm p-4 text-center">
      <p class="text-2xl font-extrabold text-yellow-500"><%= pending_count %></p>
      <p class="text-xs font-semibold text-gray-500 mt-0.5 uppercase tracking-wide">Zahlung offen</p>
    </div>
    <% end %>
  </div>

  <%# ── Sessions ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-lg font-bold text-gray-900">Trainings-Termine</h2>
      <span class="text-sm text-gray-400 font-medium"><%= total_count %> Termine</span>
    </div>

    <% if all_sessions.any? %>
      <% sessions_by_month.each do |month_start, sessions| %>
        <%
          month_is_past = month_start && month_start.end_of_month < now.to_date
        %>

        <%# Monats-Trennzeile %>
        <div class="px-6 py-2 bg-gray-50 border-b border-gray-100 flex items-center gap-2">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">
            <% if month_start %>
              <%= month_start.strftime("%B %Y") %>
            <% else %>
              Kein Datum
            <% end %>
          </span>
          <span class="text-xs text-gray-400">(<%= sessions.size %> Termine)</span>
          <% if month_is_past %>
            <span class="ml-auto text-xs text-gray-400 font-medium">Vergangen</span>
          <% end %>
        </div>

        <% sessions.each do |session| %>
          <%
            is_live      = session.start_time && session.end_time && session.start_time <= now && session.end_time >= now
            is_past      = session.end_time ? session.end_time < now : (session.start_time && session.start_time < now)
            is_canceled  = session.is_canceled?
            attendance   = session.attendances.size
          %>

          <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-gray-50 last:border-0
            <%= is_live ? 'bg-green-50' : (is_past ? 'opacity-60' : 'hover:bg-gray-50') %> transition">

            <div class="flex items-center gap-4">
              <%# Datum-Block %>
              <div class="w-14 text-center shrink-0">
                <% if session.start_time %>
                  <p class="text-lg font-extrabold leading-none text-gray-900 <%= is_past ? 'text-gray-400' : '' %>">
                    <%= session.start_time.strftime("%-d") %>
                  </p>
                  <p class="text-xs font-semibold text-gray-500 uppercase">
                    <%= session.start_time.strftime("%b") %>
                  </p>
                <% else %>
                  <p class="text-xs text-gray-400 font-medium">—</p>
                <% end %>
              </div>

              <%# Details %>
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <% if session.start_time %>
                    <span class="font-semibold text-gray-900 text-sm">
                      <%= session.start_time.strftime("%A") %>
                      <% if session.end_time %>
                        , <%= session.start_time.strftime("%H:%M") %> – <%= session.end_time.strftime("%H:%M") %> Uhr
                      <% else %>
                        , <%= session.start_time.strftime("%H:%M") %> Uhr
                      <% end %>
                    </span>
                  <% end %>

                  <% if is_live %>
                    <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-800 text-xs font-bold px-2.5 py-0.5 rounded-full">
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                      </span>
                      Läuft gerade
                    </span>
                  <% elsif is_canceled %>
                    <span class="bg-red-100 text-red-700 text-xs font-bold px-2.5 py-0.5 rounded-full">Abgesagt</span>
                  <% end %>
                </div>

                <p class="text-xs text-gray-400 mt-0.5">
                  <%= @course.location.presence || "Kein Ort angegeben" %>
                  <span class="mx-1">·</span>
                  <%= attendance %> <%= attendance == 1 ? "Anwesend" : "Anwesende" %>
                </p>
              </div>
            </div>

            <%# Aktionen %>
            <div class="flex items-center gap-2 shrink-0">
              <% if is_live %>
                <%= link_to "Präsenzkontrolle", training_session_path(session),
                      class: "bg-green-600 hover:bg-green-700 text-white text-sm font-bold py-2 px-4 rounded-lg transition" %>
              <% else %>
                <%= link_to "Präsenzkontrolle", training_session_path(session),
                      class: "bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-bold py-2 px-4 rounded-lg transition" %>
              <% end %>
            </div>

          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 text-sm font-medium">Noch keine Trainings-Sessions geplant.</p>
        <% if current_user.admin? %>
          <%= link_to "Automatisch generieren", generate_trainings_course_path(@course),
                class: "mt-3 inline-block text-primary-600 font-bold hover:underline text-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Teilnehmende ────────────────────────────────────────────────────── %>
  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-2xl overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-lg font-bold text-gray-900">
        Teilnehmende
        <span class="ml-2 text-sm font-medium text-gray-400">
          <%= confirmed_count %> bestätigt<% if waitlist_count > 0 %>, <%= waitlist_count %> Warteliste<% end %><% if pending_count > 0 %>, <%= pending_count %> Zahlung offen<% end %>
        </span>
      </h2>
    </div>

    <% if @course.course_registrations.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Name</th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
            <th class="py-3 px-6 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Bezahlt</th>
            <th class="py-3 px-6 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktionen</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @course.course_registrations.includes(:participant).order(status: :asc).each do |reg| %>
            <% p = reg.participant %>
            <tr class="hover:bg-gray-50 transition">
              <td class="py-4 px-6 text-sm">
                <span class="font-semibold text-gray-900"><%= p.first_name %> <%= p.last_name %></span>
                <% if reg.status == "ausstehend" && reg.sumup_checkout_id.present? && !reg.payment_cleared? %>
                  <span class="ml-1.5 inline-flex items-center gap-1 bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    </svg>
                    Zahlung ausstehend
                  </span>
                <% end %>
              </td>
              <td class="py-4 px-6">
                <% case reg.status %>
                <% when 'bestätigt' %>
                  <span class="bg-green-100 text-green-800 text-xs font-bold px-2.5 py-1 rounded-full">Bestätigt</span>
                <% when 'warteliste' %>
                  <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2.5 py-1 rounded-full">Warteliste</span>
                <% when 'ausstehend' %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2.5 py-1 rounded-full">Zahlung offen</span>
                <% else %>
                  <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2.5 py-1 rounded-full"><%= reg.status %></span>
                <% end %>
              </td>
              <td class="py-4 px-6 text-sm">
                <% if !@course.has_payment? %>
                  <span class="text-gray-300 font-medium">—</span>
                <% elsif reg.payment_cleared? %>
                  <span class="inline-flex items-center gap-1 text-green-700 font-semibold">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Bezahlt
                  </span>
                <% else %>
                  <div class="flex items-center gap-2">
                    <span class="text-yellow-600 font-medium">Ausstehend</span>
                    <% if current_user.admin? %>
                      <%= button_to "✓ Bar erhalten",
                            mark_as_paid_course_registration_path(reg),
                            method: :post,
                            class: "text-xs bg-green-50 hover:bg-green-100 text-green-700 font-semibold border border-green-200 px-2 py-1 rounded-lg transition cursor-pointer",
                            data: { turbo_confirm: "Zahlung für #{p.first_name} #{p.last_name} als erhalten markieren?" } %>
                    <% end %>
                  </div>
                <% end %>
              </td>
              <td class="py-4 px-6 text-right text-sm">
                <div class="inline-flex items-center gap-3">
                  <button type="button"
                          onclick="var el=document.getElementById('detail-modal-<%= reg.id.to_json %>'); el.classList.remove('hidden'); el.classList.add('flex')"
                          class="text-gray-600 font-bold hover:text-gray-900 transition cursor-pointer">
                    Details
                  </button>
                  <% if current_user.admin? %>
                    <%= link_to "Bearbeiten", edit_course_registration_path(reg),
                          class: "text-primary-600 font-bold hover:text-primary-800" %>
                  <% end %>
                  <% if reg.status != "storniert" %>
                    <button type="button"
                            onclick="var el=document.getElementById('cancel-modal-<%= reg.id.to_json %>'); el.classList.remove('hidden'); el.classList.add('flex')"
                            class="text-red-600 font-bold hover:text-red-800 transition cursor-pointer">
                      Abmelden
                    </button>
                  <% end %>
                </div>

                <%# ── Abmelde-Modal ────────────────────────────────────── %>
                <% if reg.status != "storniert" %>
                  <div id="cancel-modal-<%= reg.id %>"
                       class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4"
                       onclick="this.classList.remove('flex'); this.classList.add('hidden')">
                    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 text-left" onclick="event.stopPropagation()">
                      <div class="flex items-center gap-3 mb-5">
                        <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
                          <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                        </div>
                        <div>
                          <h3 class="text-lg font-extrabold text-gray-900"><%= p.first_name %> <%= p.last_name %> abmelden?</h3>
                          <p class="text-xs text-gray-500">Die Eltern werden per E-Mail informiert.</p>
                        </div>
                      </div>

                      <%= form_with url: trainer_cancel_course_registration_path(reg), method: :post, data: { turbo: false }, class: "space-y-4" do %>
                        <div>
                          <label class="block text-xs font-bold text-gray-700 mb-1.5 uppercase tracking-wide">Begründung <span class="font-normal text-gray-400">(optional)</span></label>
                          <textarea name="cancellation_reason"
                                    rows="3"
                                    placeholder="z.B. Verletzung, Kurswechsel, …"
                                    class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
                        </div>

                        <label class="flex items-start gap-3 cursor-pointer bg-amber-50 border border-amber-200 rounded-lg p-3">
                          <input type="checkbox" name="notify_admin" value="1"
                                 <%= (reg.payment_cleared? && @course.has_payment?) ? "checked" : "" %>
                                 class="mt-0.5 h-4 w-4 text-amber-600 border-gray-300 rounded cursor-pointer focus:ring-amber-500">
                          <div>
                            <p class="text-sm font-bold text-amber-900">Administrator wegen Rückerstattung benachrichtigen</p>
                            <p class="text-xs text-amber-700 mt-0.5">
                              Ankreuzen, wenn die Eltern Geld zurückbekommen sollen.
                              Der Admin erhält dann eine E-Mail und kümmert sich um die Rückerstattung.
                            </p>
                          </div>
                        </label>

                        <div class="flex gap-3 pt-2">
                          <button type="submit"
                                  class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-4 rounded-xl text-sm transition cursor-pointer">
                            Jetzt abmelden
                          </button>
                          <button type="button"
                                  onclick="document.getElementById('cancel-modal-<%= reg.id.to_json %>').classList.add('hidden')"
                                  class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition">
                            Abbrechen
                          </button>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <%# Detail-Modal %>
                <div id="detail-modal-<%= reg.id %>"
                     class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4"
                     onclick="this.classList.remove('flex'); this.classList.add('hidden')">
                  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 text-left" onclick="event.stopPropagation()">

                    <%# Kopf %>
                    <div class="flex items-center gap-4 mb-5">
                      <div class="h-14 w-14 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-extrabold text-xl shrink-0">
                        <%= p.first_name.first.upcase %><%= p.last_name.first.upcase %>
                      </div>
                      <div>
                        <h3 class="text-xl font-extrabold text-gray-900 leading-tight"><%= p.first_name %> <%= p.last_name %></h3>
                        <p class="text-xs text-gray-400 font-medium mt-0.5"><%= p.gender&.capitalize %></p>
                      </div>
                    </div>

                    <%# Detailzeilen %>
                    <dl class="space-y-3 text-sm mb-6">
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0">Geburtsdatum</dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= p.date_of_birth&.strftime("%d.%m.%Y") || "—" %></dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0">E-Mail</dt>
                        <dd class="font-semibold text-gray-900 text-right truncate"><%= p.user.email %></dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0">Telefon</dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= p.phone_number.presence || "—" %></dd>
                      </div>
                      <% if p.ahv_number.present? %>
                        <div class="flex justify-between gap-4">
                          <dt class="text-gray-400 font-medium shrink-0">AHV-Nummer</dt>
                          <dd class="font-semibold text-gray-900 text-right"><%= p.ahv_number %></dd>
                        </div>
                      <% end %>
                      <div class="flex justify-between gap-4 pt-2 border-t border-gray-100">
                        <dt class="text-gray-400 font-medium shrink-0">Anmeldestatus</dt>
                        <dd class="font-semibold text-right">
                          <% case reg.status %>
                          <% when 'bestätigt' %>
                            <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-0.5 rounded-full">Bestätigt</span>
                          <% when 'warteliste' %>
                            <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-0.5 rounded-full">Warteliste</span>
                          <% when 'ausstehend' %>
                            <span class="bg-yellow-100 text-yellow-700 text-xs font-bold px-2 py-0.5 rounded-full">Zahlung offen</span>
                          <% else %>
                            <span class="bg-gray-100 text-gray-600 text-xs font-bold px-2 py-0.5 rounded-full"><%= reg.status %></span>
                          <% end %>
                        </dd>
                      </div>
                      <div class="flex justify-between gap-4">
                        <dt class="text-gray-400 font-medium shrink-0">Bezahlung</dt>
                        <dd class="font-semibold text-gray-900 text-right"><%= reg.payment_cleared ? "Bezahlt" : "Ausstehend" %></dd>
                      </div>
                    </dl>

                    <button type="button"
                            onclick="document.getElementById('detail-modal-<%= reg.id.to_json %>').classList.add('hidden')"
                            class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 rounded-xl transition cursor-pointer">
                      Schliessen
                    </button>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-gray-500 text-sm font-medium">Noch keine Anmeldungen für diesen Kurs.</p>
      </div>
    <% end %>
  </div>

</div>
