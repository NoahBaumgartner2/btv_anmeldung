<div data-controller="modal">
  <button type="button"
          data-action="click->modal#open"
          class="bg-red-50 border border-red-200 text-red-600 hover:bg-red-100 text-sm font-bold py-2 px-4 rounded-lg transition">
    <%= t("courses.delete_modal.btn") %>
  </button>

  <div data-modal-target="dialog"
       data-action="click->modal#backdropClose"
       class="hidden fixed inset-0 z-50 items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 text-left">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </div>
        <div>
          <h3 class="font-extrabold text-gray-900"><%= t("courses.delete_modal.title") %></h3>
          <p class="text-sm text-gray-500"><%= t("courses.delete_modal.irreversible") %></p>
        </div>
      </div>

      <p class="text-sm text-gray-700 mb-4">
        <%= t("courses.delete_modal.confirmation_html", title: course.title) %>
      </p>

      <%= form_with url: confirm_destroy_course_path(course), method: :post do |f| %>
        <div class="mb-4">
          <%= f.label :admin_password, t("courses.delete_modal.password_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.password_field :admin_password,
                required: true,
                placeholder: t("courses.delete_modal.password_placeholder"),
                class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent" %>
        </div>
        <div class="flex gap-3">
          <button type="button"
                  data-action="click->modal#close"
                  class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 rounded-xl transition cursor-pointer text-sm">
            <%= t("courses.delete_modal.cancel") %>
          </button>
          <%= f.submit t("courses.delete_modal.confirm"),
                class: "flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 rounded-xl transition cursor-pointer text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
