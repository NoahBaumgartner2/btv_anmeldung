<% primary = @_club&.effective_primary_color || "#dc2626" %>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0;font-size:15px;font-weight:600;color:#1e40af;font-family:Arial,Helvetica,sans-serif;">Du wurdest einem Kurs als Leiter zugeteilt!</p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= @trainer.full_name %>,<br><br>
  du wurdest dem Kurs <strong>„<%= @course.title %>“</strong> als Leiter zugeteilt.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 6px 0;font-size:15px;font-weight:700;color:#111827;font-family:Arial,Helvetica,sans-serif;"><%= @course.title %></p>
      <% if @course.start_date.present? && @course.end_date.present? %>
        <p style="margin:0 0 4px 0;font-size:14px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
          <strong>Zeitraum:</strong> <%= @course.start_date.strftime("%-d. %b %Y") %> – <%= @course.end_date.strftime("%-d. %b %Y") %>
        </p>
      <% end %>
      <% if @course.location.present? %>
        <p style="margin:0;font-size:14px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
          <strong>Ort:</strong> <%= @course.location %>
        </p>
      <% end %>
    </td>
  </tr>
</table>

<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
  <tr>
    <td align="center">
      <a href="<%= manage_course_url(@course) %>"
         style="display:inline-block;background-color:<%= primary %>;color:#ffffff;text-decoration:none;padding:12px 28px;border-radius:8px;font-size:15px;font-weight:700;font-family:Arial,Helvetica,sans-serif;">
        Kurs ansehen &rarr;
      </a>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px 0;font-size:13px;color:#6b7280;font-family:Arial,Helvetica,sans-serif;">
  Falls der Button nicht funktioniert, kopiere diesen Link in deinen Browser:
</p>
<p style="margin:0 0 24px 0;font-size:13px;color:#6b7280;word-break:break-all;font-family:Arial,Helvetica,sans-serif;">
  <%= manage_course_url(@course) %>
</p>

<p style="margin:0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Falls du diese E-Mail nicht erwartet hast, kannst du sie ignorieren.
</p>
