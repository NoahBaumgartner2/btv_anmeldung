<div class="max-w-lg mx-auto mt-10 mb-16 px-4">
  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Konto bearbeiten</h1>
    <p class="text-gray-500 mt-1">Passe deine Anmeldedaten an.</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-Mail Adresse", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "appearance-none block w-full px-3 py-2.5 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 text-base sm:text-sm" %>
        </div>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-xs text-yellow-600 mt-1">Ausstehende Bestätigung für: <strong><%= resource.unconfirmed_email %></strong></p>
        <% end %>
      </div>

      <%= render "devise/shared/password_field", f: f, field: :password,
            label: "Neues Passwort (leer lassen um beizubehalten)",
            autocomplete: "new-password",
            hint: @minimum_password_length ? "Mindestens #{@minimum_password_length} Zeichen" : nil %>

      <%= render "devise/shared/password_field", f: f, field: :password_confirmation,
            label: "Neues Passwort bestätigen", autocomplete: "new-password" %>

      <%= render "devise/shared/password_field", f: f, field: :current_password,
            label: "Aktuelles Passwort (zur Bestätigung der Änderungen)",
            autocomplete: "current-password" %>

      <div>
        <%= f.submit "Konto aktualisieren",
              class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 active:bg-primary-800 transition cursor-pointer min-h-11" %>
      </div>
    <% end %>
  </div>

  <div class="mt-6 bg-red-50 border border-red-200 rounded-xl p-5">
    <p class="text-sm font-bold text-red-800 mb-3">Konto löschen</p>
    <p class="text-sm text-red-700 mb-4">Diese Aktion kann nicht rückgängig gemacht werden.</p>
    <%= button_to "Konto unwiderruflich löschen", registration_path(resource_name),
          data: { turbo_confirm: "Bist du sicher? Diese Aktion kann nicht rückgängig gemacht werden." },
          method: :delete,
          class: "bg-red-600 hover:bg-red-700 active:bg-red-800 text-white text-sm font-bold py-2.5 px-4 rounded-lg transition cursor-pointer min-h-11" %>
  </div>
</div>

<%= render "devise/shared/password_toggle_script" %>
