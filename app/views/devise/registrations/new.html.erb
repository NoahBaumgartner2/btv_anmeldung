<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">Konto erstellen</h2>
    <p class="mt-2 text-center text-sm text-gray-600">
      Registriere dich, um Kurse für den BTV zu buchen.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm sm:rounded-xl sm:px-10 border border-gray-200">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "E-Mail Adresse", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary-500 focus:border-primary-500 sm:text-sm" %>
          </div>
        </div>

        <%= render "devise/shared/password_field", f: f, field: :password, label: "Passwort",
              autocomplete: "new-password",
              hint: @minimum_password_length ? "Mindestens #{@minimum_password_length} Zeichen" : nil %>

        <%= render "devise/shared/password_field", f: f, field: :password_confirmation,
              label: "Passwort bestätigen", autocomplete: "new-password" %>

        <div class="flex items-start gap-3">
          <%= f.check_box :subscribe_to_newsletter, checked: true,
                class: "mt-1 h-4 w-4 text-primary-600 border-gray-300 rounded cursor-pointer" %>
          <div>
            <%= f.label :subscribe_to_newsletter, class: "text-sm text-gray-700 cursor-pointer" do %>
              Ja, ich möchte den <strong>BTV-Newsletter</strong> erhalten und über neue Kurse informiert werden.
            <% end %>
          </div>
        </div>

        <div>
          <%= f.submit "Konto erstellen",
                class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 transition cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 pt-4 border-t border-gray-200">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

<%= render "devise/shared/password_toggle_script" %>
