<div class="space-y-1 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to t("devise.shared.links.back_to_login"), new_session_path(resource_name), class: "text-primary-600 hover:text-primary-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p>
      <%= t("devise.shared.links.no_account") %>
      <%= link_to t("devise.shared.links.sign_up"), new_registration_path(resource_name), class: "text-primary-600 hover:text-primary-800 font-medium" %>
    </p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to t("devise.shared.links.forgot_password"), new_password_path(resource_name), class: "text-primary-600 hover:text-primary-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to t("devise.shared.links.resend_confirmation"), send("new_#{resource_name}_confirmation_path"), class: "text-primary-600 hover:text-primary-800 font-medium" %></p>
  <% end %>
</div>
