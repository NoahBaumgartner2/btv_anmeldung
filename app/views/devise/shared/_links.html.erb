<div class="space-y-1 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "Zurück zum Login", new_session_path(resource_name), class: "text-blue-600 hover:text-blue-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p>
      Noch kein Konto?
      <%= link_to "Jetzt registrieren", new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-800 font-medium" %>
    </p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "Passwort vergessen?", new_password_path(resource_name), class: "text-blue-600 hover:text-blue-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "Bestätigungs-E-Mail erneut senden", send("new_#{resource_name}_confirmation_path"), class: "text-blue-600 hover:text-blue-800 font-medium" %></p>
  <% end %>
</div>
