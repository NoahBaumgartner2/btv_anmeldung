<% primary = defined?(@_club) && @_club ? @_club.effective_primary_color : "#dc2626" %>
<%
  club = @_club || ClubSetting.current
  club_name  = club&.club_name.presence || "BTV Anmeldung"
  club_email = club&.contact_email
%>

<p style="margin:0 0 20px 0;font-size:15px;color:#374151;font-family:Arial,Helvetica,sans-serif;">
  Hallo <%= greeting_name(@resource) %>,<br><br>
  willkommen! Bitte bestätige deine E-Mail-Adresse, um dein Konto zu aktivieren.
</p>

<table cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
  <tr>
    <td style="background:<%= primary %>;border-radius:8px;padding:12px 24px;">
      <%= link_to "E-Mail-Adresse bestätigen",
            user_confirmation_url(@resource, confirmation_token: @token),
            style: "color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;font-family:Arial,Helvetica,sans-serif;" %>
    </td>
  </tr>
</table>

<p style="margin:0 0 16px 0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Wenn du dich nicht registriert hast, kannst du diese E-Mail ignorieren.
</p>

<p style="margin:0 0 16px 0;font-size:13px;color:#9ca3af;font-family:Arial,Helvetica,sans-serif;">
  Bei Fragen erreichst du uns
  <% if club_email.present? %>
    unter <a href="mailto:<%= club_email %>" style="color:<%= primary %>;text-decoration:underline;"><%= club_email %></a>.
  <% else %>
    jederzeit über <%= club_name %>.
  <% end %>
</p>
