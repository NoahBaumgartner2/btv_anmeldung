<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-2xl sm:text-3xl font-extrabold text-gray-900"><%= t("devise.passwords.edit.title") %></h2>
    <p class="mt-2 text-center text-sm text-gray-600">
      <%= t("devise.passwords.edit.subtitle") %>
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm sm:rounded-xl sm:px-10 border border-gray-200">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <%= render "devise/shared/password_field", f: f, field: :password,
              label: t("devise.passwords.edit.new_password_label"),
              autocomplete: "new-password",
              hint: @minimum_password_length ? t("devise.passwords.edit.password_min_hint", count: @minimum_password_length) : nil %>

        <%= render "devise/shared/password_field", f: f, field: :password_confirmation,
              label: t("devise.passwords.edit.confirm_password_label"), autocomplete: "new-password" %>

        <div>
          <%= f.submit t("devise.passwords.edit.submit"),
                class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 active:bg-primary-800 transition cursor-pointer min-h-11" %>
        </div>
      <% end %>

      <div class="mt-6 pt-4 border-t border-gray-200">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

<%= render "devise/shared/password_toggle_script" %>
