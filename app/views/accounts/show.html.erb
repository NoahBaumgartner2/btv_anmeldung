<% content_for :title, "Mein Konto" %>

<div data-controller="delete-account">
<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900">Mein Konto</h1>
    <p class="text-gray-500 mt-1 text-sm">Datenschutz & Kontoeinstellungen</p>
  </div>

  <%# ── Kontoinformationen ─────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Kontoinformationen</p>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">E-Mail-Adresse</dt>
        <dd class="font-semibold text-gray-900"><%= current_user.email %></dd>
      </div>
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Konto erstellt am</dt>
        <dd class="font-semibold text-gray-900"><%= current_user.created_at.strftime("%-d. %B %Y") %></dd>
      </div>
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Teilnehmer</dt>
        <dd class="font-semibold text-gray-900"><%= @participants.size %> <%= @participants.size == 1 ? "Person" : "Personen" %> hinterlegt</dd>
      </div>
    </dl>
  </div>

  <%# ── Daten exportieren ──────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Recht auf Datenportabilität</p>
    </div>
    <div class="px-6 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-gray-900 mb-1">Meine Daten exportieren</p>
        <p class="text-xs text-gray-500 leading-relaxed">
          Lade alle deine gespeicherten Daten als JSON-Datei herunter: Konto, Teilnehmer,
          Kursanmeldungen und Anwesenheiten.
        </p>
      </div>
      <%= link_to export_account_path,
            class: "shrink-0 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Daten herunterladen
      <% end %>
    </div>
  </div>

  <%# ── Konto löschen ──────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-red-200 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-red-100 bg-red-50">
      <p class="text-xs font-bold text-red-600 uppercase tracking-wide">Gefahrenzone – Recht auf Löschung</p>
    </div>
    <div class="px-6 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-gray-900 mb-1">Konto unwiderruflich löschen</p>
        <p class="text-xs text-gray-500 leading-relaxed">
          Alle Teilnehmerdaten, Kursanmeldungen und Anwesenheiten werden dauerhaft gelöscht.
          Diese Aktion kann nicht rückgängig gemacht werden.
        </p>
      </div>
      <button type="button"
              data-action="click->delete-account#open"
              class="shrink-0 inline-flex items-center gap-2 bg-white border border-red-300 hover:bg-red-50 text-red-600 font-bold py-2.5 px-5 rounded-xl text-sm transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Konto löschen
      </button>
    </div>
  </div>

</div>

<%# ── Lösch-Modal (3-stufig) ──────────────────────────────────────────────── %>
<div data-delete-account-target="modal"
     data-action="click->delete-account#closeOnBackdrop"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900/80 backdrop-blur-sm p-4">
  <div data-delete-account-target="content"
       class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8">

    <%# ── Schritt-Indikator ──────────────────────────────────────────────── %>
    <div class="flex items-center gap-2 mb-6">
      <% [1, 2, 3].each do |n| %>
        <div data-delete-account-target="stepDot"
             data-step-number="<%= n %>"
             class="h-2 rounded-full transition-all duration-300 <%= n == 1 ? 'w-6 bg-red-500' : 'w-2 bg-gray-200' %>">
        </div>
      <% end %>
      <span data-delete-account-target="stepLabel"
            class="ml-auto text-xs text-gray-400 font-medium">Schritt 1 von 3</span>
    </div>

    <%# ══════════════════════════════════════════════════════════════════════ %>
    <%# SCHRITT 1 – Umfrage                                                   %>
    <%# ══════════════════════════════════════════════════════════════════════ %>
    <div data-delete-account-target="step" data-step-number="1">
      <div class="mb-5">
        <h2 class="text-lg font-bold text-gray-900">Bevor du gehst…</h2>
        <p class="text-xs text-gray-500 mt-0.5">Dein Feedback hilft uns, besser zu werden.</p>
      </div>

      <p class="text-sm font-medium text-gray-700 mb-3">Warum möchtest du dein Konto löschen?</p>

      <div class="space-y-2.5 mb-6">
        <% [
          ["no_use",      "Ich nutze die Plattform nicht mehr"],
          ["too_complex", "Die Bedienung ist zu kompliziert"],
          ["privacy",     "Datenschutzbedenken"],
          ["competitor",  "Wechsel zu einem anderen Anbieter"],
          ["other",       "Anderer Grund"]
        ].each do |value, label| %>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="radio"
                   name="delete_reason_choice"
                   value="<%= value %>"
                   data-delete-account-target="reasonRadio"
                   data-action="change->delete-account#reasonChanged"
                   class="w-4 h-4 text-red-600 border-gray-300 focus:ring-red-400 cursor-pointer">
            <span class="text-sm text-gray-700 group-hover:text-gray-900"><%= label %></span>
          </label>
        <% end %>
      </div>

      <div data-delete-account-target="otherWrapper" class="hidden mb-6">
        <label class="block text-xs font-medium text-gray-600 mb-1.5">
          Kannst du es kurz beschreiben? <span class="text-gray-400">(optional)</span>
        </label>
        <textarea data-delete-account-target="reasonText"
                  rows="2"
                  placeholder="Dein Feedback…"
                  class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
      </div>

      <div class="flex gap-3">
        <button type="button"
                data-delete-account-target="nextButton"
                data-action="click->delete-account#next"
                disabled
                class="flex-1 bg-red-600 hover:bg-red-700 disabled:bg-gray-200 disabled:text-gray-400 disabled:cursor-not-allowed text-white font-bold py-2.5 px-4 rounded-xl text-sm transition">
          Weiter
        </button>
        <button type="button"
                data-action="click->delete-account#close"
                class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition">
          Abbrechen
        </button>
      </div>
    </div>

    <%# ══════════════════════════════════════════════════════════════════════ %>
    <%# SCHRITT 2 – Was geht verloren %>
    <%# ══════════════════════════════════════════════════════════════════════ %>
    <div data-delete-account-target="step" data-step-number="2" class="hidden">
      <div class="mb-5">
        <h2 class="text-lg font-bold text-gray-900">Das geht verloren</h2>
        <p class="text-xs text-gray-500 mt-0.5">Bitte lies dies sorgfältig durch.</p>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4 text-xs text-red-700 leading-relaxed">
        <strong class="block mb-1">Folgende Daten werden dauerhaft gelöscht:</strong>
        <ul class="list-disc list-inside space-y-0.5">
          <li>Dein Konto (<%= current_user.email %>)</li>
          <li><%= @participants.size %> <%= @participants.size == 1 ? "Teilnehmer" : "Teilnehmer" %> und alle Profildaten</li>
          <li>Alle Kursanmeldungen und Anwesenheitseinträge</li>
        </ul>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 mb-6 text-xs text-blue-800 leading-relaxed flex gap-3">
        <svg class="w-4 h-4 text-blue-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span>
          Deine Daten werden auch für die <strong>NDS-Datenbank</strong> verwendet, um Trainings und Kurse für alle Teilnehmenden besser organisieren zu können. Mit der Löschung deines Kontos gehen auch diese Einträge verloren. Falls du nur eine Pause brauchst, kannst du dein Konto auch einfach behalten – es entstehen dir keine Kosten.
        </span>
      </div>

      <div class="flex gap-3">
        <button type="button"
                data-action="click->delete-account#next"
                class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-4 rounded-xl text-sm transition">
          Trotzdem löschen
        </button>
        <button type="button"
                data-action="click->delete-account#close"
                class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition">
          Konto behalten
        </button>
      </div>
    </div>

    <%# ══════════════════════════════════════════════════════════════════════ %>
    <%# SCHRITT 3 – Passwort-Bestätigung %>
    <%# ══════════════════════════════════════════════════════════════════════ %>
    <div data-delete-account-target="step" data-step-number="3" class="hidden">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900">Konto wirklich löschen?</h2>
          <p class="text-xs text-gray-500">Diese Aktion ist unwiderruflich.</p>
        </div>
      </div>

      <%= form_with url: account_path, method: :delete, data: { turbo: false } do |f| %>
        <input type="hidden" name="delete_reason"      data-delete-account-target="hiddenReason">
        <input type="hidden" name="delete_reason_text" data-delete-account-target="hiddenReasonText">

        <div class="mb-5">
          <%= f.label :password, "Passwort zur Bestätigung eingeben", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.password_field :password,
                placeholder: "Dein aktuelles Passwort",
                required: true,
                autocomplete: "current-password",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-red-400" %>
        </div>

        <div class="flex gap-3">
          <%= f.submit "Konto unwiderruflich löschen",
                class: "flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-4 rounded-xl text-sm transition cursor-pointer shadow-sm" %>
          <button type="button"
                  data-action="click->delete-account#close"
                  class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-4 rounded-xl text-sm transition">
            Abbrechen
          </button>
        </div>
      <% end %>
    </div>

  </div>
</div>
</div>
