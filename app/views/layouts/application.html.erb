<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BTV Anmeldung" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="BTV Anmeldung">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%# ── Vereinsfarben als CSS-Custom-Properties ────────────────────────────── %>
    <% _cs = club_setting %>
    <style nonce="<%= content_security_policy_nonce %>">
      :root {
        --color-primary:   <%= _cs.effective_primary_color %>;
        --color-secondary: <%= _cs.effective_secondary_color %>;
      }
    </style>

    <%# ── Turbo + Stimulus via ES-Module-Importmap ──────────────────────────── %>
    <script type="importmap" nonce="<%= content_security_policy_nonce %>">
    {
      "imports": {
        "@hotwired/turbo":                "<%= asset_path 'turbo.min.js' %>",
        "@hotwired/stimulus":             "<%= asset_path 'stimulus.js' %>",
        "controllers/color_sync_controller":        "<%= asset_path 'controllers/color_sync_controller.js' %>",
        "controllers/field_sorter_controller":      "<%= asset_path 'controllers/field_sorter_controller.js' %>",
        "controllers/confirm_unsubscribe_controller": "<%= asset_path 'controllers/confirm_unsubscribe_controller.js' %>",
        "controllers":                    "<%= asset_path 'controllers/index.js' %>"
      }
    }
    </script>
    <script type="module" nonce="<%= content_security_policy_nonce %>">
      import "@hotwired/turbo"
      import "controllers"
    </script>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased">

    <nav class="bg-white shadow-md border-b border-gray-200">
      <div class="container mx-auto px-5">
        <div class="flex justify-between h-16">

          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center gap-2.5" do %>
              <% if _cs.logo.attached? %>
                <%= image_tag _cs.logo, class: "h-8 w-auto object-contain", alt: _cs.club_name.presence || "Logo" %>
              <% end %>
              <span class="text-2xl font-black text-primary-700 tracking-tight">
                <%= _cs.club_name.presence || "Anmeldeportal" %>
              </span>
            <% end %>

            <div class="hidden md:flex items-center space-x-6 ml-10">
              <%= link_to "Kurse", courses_path, class: "text-gray-600 hover:text-primary-700 hover:bg-primary-50 px-3 py-2 rounded-md font-medium transition" %>

              <% if user_signed_in? %>
                  <div class="h-6 w-px bg-gray-300 mx-2"></div>
                  <%= link_to "Mein Profil", participants_path, class: "text-primary-600 hover:text-primary-800 px-3 py-2 rounded-md font-bold" %>
                  <% if current_user.admin? %>
                    <%= link_to "Admin-Dashboard", dashboards_admin_path, class: "text-red-600 hover:text-red-800 px-3 py-2 rounded-md font-bold" %>
                  <% end %>

                  <% if Trainer.exists?(user: current_user) && !current_user.admin? %>
                    <%= link_to "Meine Kurse", dashboards_trainer_path, class: "text-primary-600 hover:text-primary-800 px-3 py-2 rounded-md font-bold" %>
                  <% end %>
                <% end %>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <% if user_signed_in? %>
              <%= link_to account_path,
                    class: "hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-800 px-3 py-2 rounded-md transition",
                    title: "Konto & Datenschutz" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Konto
              <% end %>
              <%= button_to "Logout", destroy_user_session_path, method: :delete,
                    class: "text-sm font-medium text-gray-500 hover:text-gray-800 bg-gray-100 hover:bg-gray-200 px-3 py-2 rounded-md transition cursor-pointer" %>
            <% else %>
              <%= link_to "Anmelden", new_user_session_path,
                    class: "text-sm font-medium text-gray-600 hover:text-gray-900 px-3 py-2 rounded-md transition" %>
              <%= link_to "Registrieren", new_user_registration_path,
                    class: "bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold px-4 py-2 rounded-lg transition" %>
            <% end %>
          </div>

        </div>
      </div>
    </nav>

    <%# ── Flash-Benachrichtigungen ───────────────────────────────────────── %>
    <div class="fixed top-4 right-4 z-50 flex flex-col gap-2 w-full max-w-sm pointer-events-none" id="flash-container">
      <% if notice %>
        <div class="flash-toast pointer-events-auto flex items-start gap-3 bg-white border border-green-200 shadow-lg rounded-xl px-4 py-3.5 text-sm"
             role="alert">
          <div class="shrink-0 w-7 h-7 rounded-full bg-green-100 flex items-center justify-center mt-0.5">
            <svg class="w-4 h-4 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <p class="flex-1 font-medium text-gray-800 pt-0.5"><%= notice %></p>
          <button type="button" class="flash-close shrink-0 text-gray-400 hover:text-gray-600 transition mt-0.5" aria-label="Schliessen">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>
      <% if alert %>
        <div class="flash-toast pointer-events-auto flex items-start gap-3 bg-white border border-red-200 shadow-lg rounded-xl px-4 py-3.5 text-sm"
             role="alert">
          <div class="shrink-0 w-7 h-7 rounded-full bg-red-100 flex items-center justify-center mt-0.5">
            <svg class="w-4 h-4 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
          </div>
          <p class="flex-1 font-medium text-gray-800 pt-0.5"><%= alert %></p>
          <button type="button" class="flash-close shrink-0 text-gray-400 hover:text-gray-600 transition mt-0.5" aria-label="Schliessen">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>
    </div>

    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var DURATION = 5000;

        function dismissToast(toast) {
          toast.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(1rem)';
          setTimeout(function() { toast.remove(); }, 300);
        }

        document.querySelectorAll('.flash-toast').forEach(function(toast) {
          var timer = setTimeout(function() { dismissToast(toast); }, DURATION);

          toast.querySelector('.flash-close').addEventListener('click', function() {
            clearTimeout(timer);
            dismissToast(toast);
          });
        });
      })();
    </script>

    <% if content_for?(:full_width) %>
      <main>
        <%= yield %>
      </main>
    <% else %>
      <main class="container mx-auto mt-6 px-5 pb-20">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <%= yield %>
        </div>
      </main>
    <% end %>

  </body>
</html>
