<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to "← Kommandozentrale", dashboards_admin_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2">Meine Benachrichtigungen</h1>
    <p class="text-gray-500 mt-1 text-sm">Wähle, welche Benachrichtigungen du als Trainer erhalten möchtest.</p>
  </div>

  <%= form_with url: admin_notification_preferences_path, method: :patch do %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <ul class="divide-y divide-gray-100">
        <% [
          [ "cancel_notice",          "Abmeldung von Kurs",       "Wenn ein Teilnehmer sich vom Kurs abmeldet (Kurs dem du als Trainer zugewiesen bist)" ],
          [ "session_unsubscription", "Abmeldung von Training",   "Wenn ein Teilnehmer sich von einer einzelnen Trainingseinheit abmeldet" ],
          [ "attendance_reminder",    "Anwesenheitserinnerung",   "Wenn Anwesenheiten nach dem Training noch nicht erfasst wurden" ],
        ].each do |type, name, description| %>
          <% enabled = current_user.admin_notification_enabled?(type) %>
          <li class="flex items-center gap-4 px-6 py-4">
            <div class="shrink-0 w-9 h-9 rounded-xl bg-indigo-50 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800"><%= name %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= description %></p>
            </div>
            <label class="shrink-0 relative inline-flex items-center cursor-pointer">
              <input type="checkbox"
                     name="preferences[<%= type %>]"
                     value="1"
                     <%= "checked" if enabled %>
                     class="sr-only peer">
              <span class="block h-6 w-11 rounded-full bg-gray-200 transition-colors duration-200 peer-checked:bg-green-500 peer-focus:ring-2 peer-focus:ring-indigo-500 peer-focus:ring-offset-2 after:content-[''] after:absolute after:top-1 after:left-1 after:h-4 after:w-4 after:rounded-full after:bg-white after:shadow after:transition-transform after:duration-200 peer-checked:after:translate-x-5"></span>
            </label>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="mt-6">
      <%= submit_tag "Speichern",
            class: "w-full sm:w-auto bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition cursor-pointer min-h-11" %>
    </div>
  <% end %>

</div>
