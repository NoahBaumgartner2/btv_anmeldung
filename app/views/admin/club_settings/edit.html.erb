<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to t('admin.club_settings.edit.back'), admin_club_setting_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t('admin.club_settings.edit.title') %></h1>
    <p class="text-gray-500 mt-1 text-sm"><%= t('admin.club_settings.edit.subtitle') %></p>
  </div>

  <%= form_with model: @club_setting,
        url: admin_club_setting_path,
        method: :patch,
        multipart: true,
        data: { controller: "scroll-to-error" } do |f| %>

    <% if @club_setting.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-5 py-4 mb-6" data-error-scroll-target>
        <p class="text-sm font-bold text-red-800 mb-2"><%= @club_setting.errors.count %> Fehler:</p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
          <% @club_setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Vereinsname ────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3 mb-5">
        <%= t('admin.club_settings.edit.section_name') %>
      </p>
      <%= f.label :club_name, t('admin.club_settings.edit.label_name'), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :club_name,
            placeholder: "z.B. BTV Turnverein",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>

    <%# ── Farben ─────────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">
        <%= t('admin.club_settings.edit.section_colors') %>
      </p>

      <%# Primärfarbe %>
      <div data-controller="color-sync">
        <%= f.label :primary_color, t('admin.club_settings.edit.label_primary'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-2">Hauptfarbe für Buttons und Akzente. Standard: <code class="bg-gray-100 px-1 rounded">#dc2626</code></p>
        <div class="flex items-center gap-3">
          <input type="color"
                 data-color-sync-target="picker"
                 value="<%= @club_setting.effective_primary_color %>"
                 class="h-10 w-14 cursor-pointer rounded-lg border border-gray-300 p-1 shadow-sm">
          <%= f.text_field :primary_color,
                data: { "color-sync-target": "text" },
                placeholder: "#dc2626",
                maxlength: 7,
                class: "w-32 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <div class="w-8 h-8 rounded-lg border border-gray-200 shrink-0"
               id="primary-preview"
               style="background-color: <%= @club_setting.effective_primary_color %>"></div>
        </div>
      </div>

      <%# Sekundärfarbe %>
      <div data-controller="color-sync">
        <%= f.label :secondary_color, t('admin.club_settings.edit.label_secondary'), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-2">Akzentfarbe für Links und Highlights. Standard: <code class="bg-gray-100 px-1 rounded">#1d4ed8</code></p>
        <div class="flex items-center gap-3">
          <input type="color"
                 data-color-sync-target="picker"
                 value="<%= @club_setting.effective_secondary_color %>"
                 class="h-10 w-14 cursor-pointer rounded-lg border border-gray-300 p-1 shadow-sm">
          <%= f.text_field :secondary_color,
                data: { "color-sync-target": "text" },
                placeholder: "#1d4ed8",
                maxlength: 7,
                class: "w-32 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <div class="w-8 h-8 rounded-lg border border-gray-200 shrink-0"
               id="secondary-preview"
               style="background-color: <%= @club_setting.effective_secondary_color %>"></div>
        </div>
      </div>
    </div>

    <%# ── Logo ──────────────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3 mb-5">
        <%= t('admin.club_settings.edit.section_logo') %>
      </p>

      <% if @club_setting.logo.attached? %>
        <div class="flex items-center gap-5 mb-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
          <img src="<%= @club_setting.logo_url %>"
               alt="<%= t('admin.club_settings.edit.current_logo_label') %>"
               class="max-h-20 object-contain rounded-lg">
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-700 mb-1"><%= t('admin.club_settings.edit.current_logo_label') %></p>
            <p class="text-xs text-gray-400 mb-3"><%= t('admin.club_settings.edit.new_logo_hint') %></p>
            <%= link_to t('admin.club_settings.edit.remove_logo'),
                  destroy_logo_admin_club_setting_path,
                  class: "inline-flex items-center gap-1.5 text-xs font-semibold text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 border border-red-200 px-3 py-1.5 rounded-lg transition cursor-pointer",
                  data: { turbo_method: :delete, turbo_confirm: t('admin.club_settings.edit.remove_logo_confirm') } %>
          </div>
        </div>
      <% end %>

      <%= f.label :logo, @club_setting.logo.attached? ? t('admin.club_settings.edit.upload_logo_new') : t('admin.club_settings.edit.upload_logo'),
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <p class="text-xs text-gray-400 mb-2"><%= t('admin.club_settings.edit.logo_hint') %></p>
      <%= f.file_field :logo,
            accept: "image/png,image/jpeg,image/svg+xml",
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
    </div>

    <%# ── Datenschutz & Impressum ──────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3 mb-5">
        Datenschutz &amp; Impressum
      </p>
      <p class="text-xs text-gray-400 mb-5">
        Diese Angaben erscheinen in der Datenschutzerklärung und im Impressum. Pflichtfelder für eine DSGVO/DSG-konforme Datenschutzerklärung sind mit <span class="text-red-500">*</span> markiert.
      </p>

      <div class="space-y-5">

        <%# ── Kontaktadresse ── %>
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-3">Kontaktadresse <span class="text-red-500">*</span></p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <%= f.label :contact_street, "Strasse und Hausnummer", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :contact_street, placeholder: "Musterstrasse 12", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :contact_zip, "PLZ", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :contact_zip, placeholder: "3000", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :contact_city, "Ort", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :contact_city, placeholder: "Bern", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :contact_email, "Kontakt-E-Mail", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.email_field :contact_email, placeholder: "kontakt@verein.ch", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :contact_phone, "Telefon (optional)", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.telephone_field :contact_phone, placeholder: "+41 31 123 45 67", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div class="sm:col-span-2">
              <%= f.label :contact_website, "Website (optional)", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :contact_website, placeholder: "https://www.verein.ch", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">Verein &amp; verantwortliche Person (Impressum)</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :legal_form, "Rechtsform", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :legal_form, placeholder: "Eingetragener Verein", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :responsible_name, "Name (Verantwortliche Person)", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :responsible_name, placeholder: "Vorname Nachname", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div class="sm:col-span-2">
              <%= f.label :responsible_function, "Funktion im Verein", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :responsible_function, placeholder: "Präsident / Datenschutzverantwortliche", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <p class="text-sm font-semibold text-gray-700 mb-1">Datenschutzbeauftragte/r (optional)</p>
          <p class="text-xs text-gray-400 mb-3">Leer lassen, wenn kein DSB benannt ist.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :privacy_officer_name, "Name DSB", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :privacy_officer_name, placeholder: "Vorname Nachname", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :privacy_officer_email, "E-Mail DSB", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.email_field :privacy_officer_email, placeholder: "dsb@verein.ch", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <p class="text-sm font-semibold text-gray-700 mb-1">Dienstleister (für Datenschutzerklärung)</p>
          <p class="text-xs text-gray-400 mb-3">Werden in der Datenschutzerklärung unter «Drittanbieter» aufgeführt.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :payment_provider, "Zahlungsanbieter", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :payment_provider, placeholder: "SumUp", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :smtp_provider, "E-Mail-Versand (SMTP)", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :smtp_provider, placeholder: "Infomaniak", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :hosting_provider, "Hosting-Anbieter", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :hosting_provider, placeholder: "Hetzner", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
            <div>
              <%= f.label :hosting_country, "Hosting-Standort", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :hosting_country, placeholder: "Deutschland / EU", class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <%# ── Aktionen ───────────────────────────────────────────────────────────── %>
    <div class="flex flex-col sm:flex-row gap-3">
      <%= f.submit t('admin.club_settings.edit.save'),
            class: "w-full sm:w-auto bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition cursor-pointer min-h-11" %>
      <%= link_to t('admin.club_settings.edit.cancel'), admin_club_setting_path,
            class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 px-6 rounded-xl text-sm transition min-h-11" %>
    </div>

  <% end %>

</div>
