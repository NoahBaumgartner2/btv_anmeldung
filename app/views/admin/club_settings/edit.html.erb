<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to "← Vereinseinstellungen", admin_club_setting_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-3xl font-extrabold text-gray-900 mt-2">Vereinseinstellungen bearbeiten</h1>
    <p class="text-gray-500 mt-1 text-sm">Name, Farben und Logo des Vereins.</p>
  </div>

  <%= form_with model: @club_setting,
        url: admin_club_setting_path,
        method: :patch,
        multipart: true do |f| %>

    <% if @club_setting.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-5 py-4 mb-6">
        <p class="text-sm font-bold text-red-800 mb-2"><%= @club_setting.errors.count %> Fehler:</p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
          <% @club_setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Vereinsname ────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3 mb-5">
        Vereinsname
      </p>
      <%= f.label :club_name, "Name des Vereins", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :club_name,
            placeholder: "z.B. BTV Turnverein",
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </div>

    <%# ── Farben ─────────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">
        Vereinsfarben
      </p>

      <%# Primärfarbe %>
      <div data-controller="color-sync">
        <%= f.label :primary_color, "Primärfarbe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-2">Hauptfarbe für Buttons und Akzente. Standard: <code class="bg-gray-100 px-1 rounded">#dc2626</code></p>
        <div class="flex items-center gap-3">
          <input type="color"
                 data-color-sync-target="picker"
                 value="<%= @club_setting.effective_primary_color %>"
                 class="h-10 w-14 cursor-pointer rounded-lg border border-gray-300 p-1 shadow-sm">
          <%= f.text_field :primary_color,
                data: { "color-sync-target": "text" },
                placeholder: "#dc2626",
                maxlength: 7,
                class: "w-32 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <div class="w-8 h-8 rounded-lg border border-gray-200 shrink-0"
               id="primary-preview"
               style="background-color: <%= @club_setting.effective_primary_color %>"></div>
        </div>
      </div>

      <%# Sekundärfarbe %>
      <div data-controller="color-sync">
        <%= f.label :secondary_color, "Sekundärfarbe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-2">Akzentfarbe für Links und Highlights. Standard: <code class="bg-gray-100 px-1 rounded">#1d4ed8</code></p>
        <div class="flex items-center gap-3">
          <input type="color"
                 data-color-sync-target="picker"
                 value="<%= @club_setting.effective_secondary_color %>"
                 class="h-10 w-14 cursor-pointer rounded-lg border border-gray-300 p-1 shadow-sm">
          <%= f.text_field :secondary_color,
                data: { "color-sync-target": "text" },
                placeholder: "#1d4ed8",
                maxlength: 7,
                class: "w-32 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <div class="w-8 h-8 rounded-lg border border-gray-200 shrink-0"
               id="secondary-preview"
               style="background-color: <%= @club_setting.effective_secondary_color %>"></div>
        </div>
      </div>
    </div>

    <%# ── Logo ──────────────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3 mb-5">
        Vereinslogo
      </p>

      <% if @club_setting.logo.attached? %>
        <div class="flex items-center gap-5 mb-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
          <img src="<%= @club_setting.logo_url %>"
               alt="Aktuelles Logo"
               class="max-h-20 object-contain rounded-lg">
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-700 mb-1">Aktuelles Logo</p>
            <p class="text-xs text-gray-400 mb-3">Neues Bild auswählen, um das Logo zu ersetzen.</p>
            <%= link_to "Logo entfernen",
                  destroy_logo_admin_club_setting_path,
                  class: "inline-flex items-center gap-1.5 text-xs font-semibold text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 border border-red-200 px-3 py-1.5 rounded-lg transition cursor-pointer",
                  data: { turbo_method: :delete, turbo_confirm: "Logo wirklich entfernen?" } %>
          </div>
        </div>
      <% end %>

      <%= f.label :logo, @club_setting.logo.attached? ? "Neues Logo hochladen" : "Logo hochladen",
            class: "block text-sm font-medium text-gray-700 mb-1" %>
      <p class="text-xs text-gray-400 mb-2">PNG, JPEG oder SVG · Empfohlen: transparenter Hintergrund</p>
      <%= f.file_field :logo,
            accept: "image/png,image/jpeg,image/svg+xml",
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
    </div>

    <%# ── Aktionen ───────────────────────────────────────────────────────────── %>
    <div class="flex gap-3">
      <%= f.submit "Einstellungen speichern",
            class: "bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition cursor-pointer" %>
      <%= link_to "Abbrechen", admin_club_setting_path,
            class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 px-6 rounded-xl text-sm transition" %>
    </div>

  <% end %>

</div>
