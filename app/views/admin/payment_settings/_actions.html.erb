<% payment_configured = @payment_setting.persisted? && @payment_setting.fully_configured? %>

<%# ── Verbindung testen ───────────────────────────────────────────────────── %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
  <p class="text-sm font-bold text-gray-700 mb-1"><%= t('admin.payment_settings.show.test_title') %></p>
  <p class="text-xs text-gray-500 mb-4">
    Sendet eine Test-Anfrage an die SumUp API (<code class="bg-gray-100 px-1 rounded">/v0.1/me</code>), um den Access Token zu validieren.
  </p>
  <%= form_with url: test_connection_admin_payment_setting_path, method: :post, class: "flex gap-2" do |f| %>
    <%= f.submit t('admin.payment_settings.show.test_btn'),
          class: "bg-gray-800 hover:bg-gray-900 text-white font-bold py-2.5 px-5 rounded-xl text-sm transition cursor-pointer shadow-sm" %>
  <% end %>
</div>

<%# ── Offene Zahlungen prüfen ─────────────────────────────────────────────── %>
<%
  pending_count = CourseRegistration.where(
    status: "ausstehend", payment_cleared: false
  ).where.not(sumup_checkout_id: [nil, ""]).count
%>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
  <div class="flex items-start justify-between gap-4 mb-4">
    <div>
      <p class="text-sm font-bold text-gray-700 mb-1"><%= t('admin.payment_settings.show.pending_title') %></p>
      <p class="text-xs text-gray-500">
        Gleicht ausstehende Anmeldungen mit SumUp ab – nützlich wenn ein Webhook nicht ankam.
      </p>
    </div>
    <% if pending_count > 0 %>
      <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-800">
        <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 inline-block"></span>
        <%= t('admin.payment_settings.show.pending_badge', count: pending_count) %>
      </span>
    <% else %>
      <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>
        <%= t('admin.payment_settings.show.all_synced') %>
      </span>
    <% end %>
  </div>

  <% if pending_count > 0 %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3 mb-4 text-xs text-yellow-800">
      <strong><%= pending_count %> Anmeldung<%= pending_count == 1 ? "" : "en" %></strong>
      mit SumUp-Checkout und Status "ausstehend" – noch nicht als bezahlt markiert.
    </div>
  <% end %>

  <%= form_with url: sync_payments_admin_payment_setting_path, method: :post do |f| %>
    <%= f.submit t('admin.payment_settings.show.sync_btn'),
          class: "bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-5 rounded-xl text-sm transition cursor-pointer shadow-sm #{"opacity-50 cursor-not-allowed" unless payment_configured}",
          disabled: !payment_configured %>
  <% end %>

  <% unless payment_configured %>
    <p class="text-xs text-gray-400 mt-2"><%= t('admin.payment_settings.show.sync_unconfigured') %></p>
  <% end %>
</div>

<%# ── Automatischer Sync ──────────────────────────────────────────────────── %>
<div class="mt-4 rounded-xl border border-blue-100 bg-blue-50 px-5 py-3.5 flex items-start gap-3">
  <svg class="h-4 w-4 text-blue-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
  </svg>
  <p class="text-xs text-blue-800">
    <strong>Automatischer Sync aktiv:</strong>
    <code class="bg-blue-100 px-1 rounded font-mono">PaymentSyncJob</code> läuft via Solid Queue alle 15 Minuten.
    Eine manuelle Synchronisation ist nur nötig, wenn ein Webhook nicht angekommen ist.
  </p>
</div>
