<%
  configured  = @payment_setting.persisted? && @payment_setting.fully_configured?
  active      = @payment_setting.persisted? && @payment_setting.active?
%>

<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <%= link_to "← Kommandozentrale", dashboards_admin_path,
            class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2">Zahlungseinstellungen</h1>
      <p class="text-gray-500 mt-1 text-sm">SumUp-Konfiguration für Online-Zahlungen.</p>
    </div>
    <%= link_to "Bearbeiten", edit_admin_payment_setting_path,
          class: "shrink-0 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition min-h-11" %>
  </div>

  <%# ── Status-Banner ──────────────────────────────────────────────────────── %>
  <% if configured && active %>
    <div class="rounded-xl border border-green-200 bg-green-50 px-5 py-4 mb-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-green-200 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-green-800">SumUp aktiv</p>
        <p class="text-xs text-green-700 mt-0.5">Online-Zahlungen sind aktiviert · Währung: <%= @payment_setting.effective_currency.upcase %></p>
      </div>
    </div>
  <% elsif configured %>
    <div class="rounded-xl border border-yellow-200 bg-yellow-50 px-5 py-4 mb-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-yellow-200 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-yellow-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-yellow-800">Konfiguriert aber inaktiv</p>
        <p class="text-xs text-yellow-700 mt-0.5">SumUp ist eingerichtet, aber noch nicht aktiviert.</p>
      </div>
    </div>
  <% else %>
    <div class="rounded-xl border border-gray-200 bg-gray-50 px-5 py-4 mb-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-gray-700">Nicht konfiguriert</p>
        <p class="text-xs text-gray-500 mt-0.5">SumUp-Zugangsdaten noch nicht hinterlegt. ENV-Fallback aktiv wenn gesetzt.</p>
      </div>
    </div>
  <% end %>

  <%# ── SumUp API-Zugangsdaten ─────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">SumUp API-Zugangsdaten</p>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">API Key</dt>
        <dd class="font-mono text-xs text-gray-700 truncate max-w-xs">
          <%= @payment_setting.sumup_api_key.presence || "—" %>
        </dd>
      </div>
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Access Token</dt>
        <dd class="font-mono text-xs text-gray-600">
          <%= @payment_setting.sumup_access_token_present? ? "••••••••••••••••••••••••" : "—" %>
        </dd>
      </div>
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Merchant Code</dt>
        <dd class="font-mono text-xs text-gray-700">
          <%= @payment_setting.sumup_merchant_code.presence || "—" %>
        </dd>
      </div>
    </dl>
  </div>

  <%# ── Konfiguration ───────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">Konfiguration</p>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Währung</dt>
        <dd class="font-bold text-gray-900 uppercase"><%= @payment_setting.effective_currency %></dd>
      </div>
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-48 shrink-0">Status</dt>
        <dd>
          <% if active %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>
              Aktiv
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-gray-100 text-gray-600">
              <span class="w-1.5 h-1.5 rounded-full bg-gray-400 inline-block"></span>
              Inaktiv
            </span>
          <% end %>
        </dd>
      </div>
    </dl>
  </div>

  <%# ── Verbindung testen ───────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
    <p class="text-sm font-bold text-gray-700 mb-1">Verbindung testen</p>
    <p class="text-xs text-gray-500 mb-4">
      Sendet eine Test-Anfrage an die SumUp API (<code class="bg-gray-100 px-1 rounded">/v0.1/me</code>), um den Access Token zu validieren.
    </p>
    <%= form_with url: test_connection_admin_payment_setting_path, method: :post, class: "flex gap-2" do |f| %>
      <%= f.submit "Verbindung testen",
            class: "bg-gray-800 hover:bg-gray-900 text-white font-bold py-2.5 px-5 rounded-xl text-sm transition cursor-pointer shadow-sm" %>
    <% end %>
  </div>

  <%# ── Offene Zahlungen prüfen ─────────────────────────────────────────────── %>
  <%
    pending_count = CourseRegistration.where(
      status: "ausstehend", payment_cleared: false
    ).where.not(sumup_checkout_id: [nil, ""]).count
  %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <div class="flex items-start justify-between gap-4 mb-4">
      <div>
        <p class="text-sm font-bold text-gray-700 mb-1">Offene Zahlungen prüfen</p>
        <p class="text-xs text-gray-500">
          Gleicht ausstehende Anmeldungen mit SumUp ab – nützlich wenn ein Webhook nicht ankam.
        </p>
      </div>
      <% if pending_count > 0 %>
        <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-800">
          <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 inline-block"></span>
          <%= pending_count %> ausstehend
        </span>
      <% else %>
        <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>
          Alles abgeglichen
        </span>
      <% end %>
    </div>

    <% if pending_count > 0 %>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3 mb-4 text-xs text-yellow-800">
        <strong><%= pending_count %> Anmeldung<%= pending_count == 1 ? "" : "en" %></strong>
        mit SumUp-Checkout und Status "ausstehend" – noch nicht als bezahlt markiert.
      </div>
    <% end %>

    <%= form_with url: sync_payments_admin_payment_setting_path, method: :post do |f| %>
      <%= f.submit "Zahlungsstatus bei SumUp abgleichen",
            class: "bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-5 rounded-xl text-sm transition cursor-pointer shadow-sm #{"opacity-50 cursor-not-allowed" unless configured}",
            disabled: !configured %>
    <% end %>

    <% unless configured %>
      <p class="text-xs text-gray-400 mt-2">SumUp muss konfiguriert sein, um den Abgleich durchführen zu können.</p>
    <% end %>
  </div>

</div>
