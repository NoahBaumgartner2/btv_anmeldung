<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to t('admin.infomaniak_settings.edit.back'), admin_infomaniak_setting_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t('admin.infomaniak_settings.edit.title') %></h1>
    <p class="text-gray-500 mt-1 text-sm"><%= t('admin.infomaniak_settings.edit.subtitle') %></p>
  </div>

  <%= form_with model: @infomaniak_setting,
        url: admin_infomaniak_setting_path,
        method: :patch do |f| %>

    <% if @infomaniak_setting.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-5 py-4 mb-6">
        <p class="text-sm font-bold text-red-800 mb-2"><%= @infomaniak_setting.errors.count %> Fehler:</p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
          <% @infomaniak_setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Status-Toggle ──────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-bold text-gray-800"><%= t('admin.infomaniak_settings.edit.toggle_title') %></p>
          <p class="text-xs text-gray-500 mt-0.5">
            <%= t('admin.infomaniak_settings.edit.toggle_body') %>
          </p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= f.check_box :active,
                id: "toggle_active",
                class: "sr-only peer" %>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-300
                      rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white
                      after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white
                      after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5
                      after:transition-all peer-checked:bg-primary-600"></div>
        </label>
      </div>
    </div>

    <%# ── API-Zugangsdaten ───────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-5">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">
        <%= t('admin.infomaniak_settings.edit.section_credentials') %>
      </p>

      <%# API-Token (verschlüsselt) %>
      <div>
        <%= f.label :api_token, "API-Token", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1.5">
          Bearer-Token für die Infomaniak API-Authentifizierung. Leer lassen, um den gespeicherten Token beizubehalten.
          <% if @infomaniak_setting.api_token_present? %>
            <span class="text-green-600 font-semibold"><%= t('admin.infomaniak_settings.edit.token_set') %></span>
          <% end %>
        </p>
        <div class="relative">
          <%= f.password_field :api_token,
                placeholder: "••••••••••••••••••••••••",
                autocomplete: "new-password",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 pr-10 text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 js-pw-field" %>
          <button type="button"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600 js-pw-toggle"
                  tabindex="-1">
            <svg class="h-4 w-4 js-eye-show" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg class="h-4 w-4 js-eye-hide hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <%# Mailinglisten-ID %>
      <div>
        <%= f.label :mailing_list_id, "Mailinglisten-ID", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1.5">Numerische ID der Mailingliste im Infomaniak-Dashboard.</p>
        <%= f.text_field :mailing_list_id,
              placeholder: "123456",
              autocomplete: "off",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>

      <%# Base URL %>
      <div>
        <%= f.label :base_url, "API-URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1.5">
          Basis-URL der Infomaniak API. Leer lassen für den Standard
          <code class="bg-gray-100 px-1 rounded">https://api.infomaniak.com</code>.
        </p>
        <%= f.text_field :base_url,
              placeholder: "https://api.infomaniak.com",
              autocomplete: "off",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm font-mono shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <%# ── Credentials-Hinweis ────────────────────────────────────────────── %>
    <div class="rounded-xl border border-gray-200 bg-gray-50 px-5 py-4 mb-6 text-xs text-gray-500">
      <p class="font-semibold text-gray-600 mb-1">Credentials-Fallback</p>
      Falls keine DB-Einstellungen gespeichert sind, werden die Rails Credentials unter dem Key
      <code class="bg-gray-200 rounded px-1">infomaniak.api_token</code> und
      <code class="bg-gray-200 rounded px-1">infomaniak.mailing_list_id</code> verwendet.
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <%= f.submit t('admin.infomaniak_settings.edit.save'),
            class: "w-full sm:w-auto bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition cursor-pointer min-h-11" %>
      <%= link_to t('admin.infomaniak_settings.edit.cancel'), admin_infomaniak_setting_path,
            class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 px-6 rounded-xl text-sm transition min-h-11" %>
    </div>
  <% end %>

</div>

<script nonce="<%= request.content_security_policy_nonce %>">
  document.querySelectorAll('.js-pw-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = btn.closest('.relative').querySelector('.js-pw-field');
      var isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      btn.querySelector('.js-eye-show').classList.toggle('hidden', isHidden);
      btn.querySelector('.js-eye-hide').classList.toggle('hidden', !isHidden);
    });
  });
</script>
