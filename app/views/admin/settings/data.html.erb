<div class="max-w-3xl mx-auto mt-8 sm:mt-10 mb-16 px-4">

  <div class="mb-6">
    <%= link_to t("admin.settings.back"), dashboards_admin_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t("admin.settings.title") %></h1>
    <p class="text-gray-500 mt-1 text-sm"><%= t("admin.settings.subtitle") %></p>
  </div>

  <%= render "admin/settings/tabs", active: :data %>

  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-1"><%= t("admin.settings.data.title") %></h2>
    <p class="text-sm text-gray-500 mb-4"><%= t("admin.settings.data.desc") %></p>
    <div class="space-y-3">
      <%= render "admin/settings/link_card",
            url: admin_export_profiles_path,
            title: t("admin.settings.data.export_profiles_label"),
            desc: t("admin.settings.data.export_profiles_desc"),
            badge: (@export_profiles.any? ? @export_profiles.size : nil) %>
      <%= render "admin/settings/link_card",
            url: admin_reports_path,
            title: t("admin.settings.data.reports_label"),
            desc: t("admin.settings.data.reports_desc") %>
      <%= render "admin/settings/link_card",
            url: admin_nds_path,
            title: t("admin.settings.data.nds_label"),
            desc: t("admin.settings.data.nds_desc") %>
    </div>
  </section>

</div>
