<%# Link-Karte zu einer eigenständigen Verwaltungsseite.
    Locals: url, title, desc, badge (optional) %>
<%= link_to url,
      class: "group flex items-center gap-3.5 px-5 py-4 bg-white border border-gray-200 rounded-xl shadow-sm hover:border-primary-300 hover:bg-primary-50/40 transition min-h-14" do %>
  <div class="min-w-0 flex-1">
    <p class="text-sm font-bold text-gray-800 group-hover:text-primary-700 transition"><%= title %></p>
    <p class="text-xs text-gray-400 mt-0.5"><%= desc %></p>
  </div>
  <% if local_assigns[:badge].present? %>
    <span class="shrink-0 text-xs font-bold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full"><%= badge %></span>
  <% end %>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-300 group-hover:text-primary-400 shrink-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
  </svg>
<% end %>
