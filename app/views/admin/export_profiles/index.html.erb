<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ───────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <%= link_to t('admin.export_profiles.index.back'), dashboards_admin_path,
            class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t('admin.export_profiles.index.title') %></h1>
      <p class="text-gray-500 mt-1 text-sm"><%= t('admin.export_profiles.index.subtitle') %></p>
    </div>
    <%= link_to new_admin_export_profile_path,
          class: "shrink-0 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition min-h-11" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      <%= t('admin.export_profiles.index.new_btn') %>
    <% end %>
  </div>

  <%# ── Liste ────────────────────────────────────────────────────────────── %>
  <% if @export_profiles.any? %>
    <div class="space-y-3">
      <% @export_profiles.each do |profile| %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-5 py-4 flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1.5">
                <span class="text-base font-bold text-gray-900"><%= profile.name %></span>

                <%# Export-Typ Badge %>
                <% if profile.export_type == "anwesenheitsliste" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">
                    <%= t('admin.export_profiles.index.type_attendance') %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">
                    <%= t('admin.export_profiles.index.type_participants') %>
                  </span>
                <% end %>

                <%# Format Badge %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold uppercase
                             <%= profile.format == 'xlsx' ? 'bg-green-100 text-green-700' :
                                 profile.format == 'pdf'  ? 'bg-red-100 text-red-700' :
                                                            'bg-gray-100 text-gray-500' %>">
                  <%= profile.format %>
                </span>

                <% if profile.course %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-700">
                    <%= profile.course.title %>
                  </span>
                <% end %>
              </div>

              <% non_blank = profile.fields.reject(&:blank?) %>
              <% if non_blank.any? %>
                <div class="flex flex-wrap gap-1.5 mt-1">
                  <% non_blank.each do |field| %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                      <%= ExportProfile::AVAILABLE_FIELDS[field] || field %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="flex items-center gap-2 shrink-0">
              <%# Download-Button %>
              <%= link_to download_admin_export_profile_path(profile),
                    class: "inline-flex items-center gap-1.5 text-xs font-semibold text-primary-700 hover:text-primary-900 bg-primary-50 hover:bg-primary-100 px-3 py-1.5 rounded-lg transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                <%= t('admin.export_profiles.index.download') %>
              <% end %>

              <%# Bearbeiten %>
              <%= link_to edit_admin_export_profile_path(profile),
                    class: "inline-flex items-center gap-1.5 text-xs font-semibold text-gray-600 hover:text-gray-900 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-lg transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828a4 4 0 01-2.828 1.172H7v-2a4 4 0 011.172-2.828z"/>
                </svg>
                <%= t('admin.export_profiles.index.edit') %>
              <% end %>

              <%# Löschen %>
              <%= button_to admin_export_profile_path(profile), method: :delete,
                    class: "inline-flex items-center gap-1.5 text-xs font-semibold text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition",
                    data: { turbo_confirm: t('admin.export_profiles.index.delete_confirm', name: profile.name) } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                <%= t('admin.export_profiles.index.delete') %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm py-16 text-center">
      <div class="mx-auto w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-gray-700 mb-1"><%= t('admin.export_profiles.index.empty_title') %></p>
      <p class="text-xs text-gray-400 mb-5"><%= t('admin.export_profiles.index.empty_body') %></p>
      <%= link_to t('admin.export_profiles.index.empty_btn'), new_admin_export_profile_path,
            class: "inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-bold py-2 px-4 rounded-lg text-sm transition" %>
    </div>
  <% end %>

</div>
