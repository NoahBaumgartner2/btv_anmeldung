<%= form_with model: [:admin, export_profile], class: "space-y-8",
      data: { controller: "export-type" } do |f| %>

  <%# ── Fehler ──────────────────────────────────────────────────────────────── %>
  <% if export_profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 text-sm text-red-700 space-y-1">
      <% export_profile.errors.full_messages.each do |msg| %>
        <p>• <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════════════
      1. GRUNDEINSTELLUNGEN
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">1 · Grundeinstellungen</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <%# Export-Typ %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Export-Typ</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::EXPORT_TYPES.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :export_type, val, class: "accent-primary-600",
                    data: { action: "change->export-type#toggleExportType" } %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Profilname %>
      <div>
        <%= f.label :name, "Profilname", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.text_field :name,
              placeholder: "z. B. Anwesenheit Kids Gym Frühlingssemester",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
      </div>

      <%# Kurs-Filter %>
      <div>
        <%= f.label :course_id, class: "block text-sm font-semibold text-gray-700 mb-1.5" do %>
          Kurs
          <span class="hidden text-red-500 font-bold" data-export-type-target="anwesenheitSection">*</span>
        <% end %>
        <%= f.select :course_id,
              options_for_select(
                [["Alle Teilnehmer (kein Filter)", ""]] +
                Course.order(:title).map { |c| [c.title, c.id] },
                export_profile.course_id
              ),
              {},
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
        <p class="text-xs text-gray-400 mt-1" data-export-type-target="teilnehmerSection">
          Optional: Nur Teilnehmer dieses Kurses werden exportiert.
        </p>
        <p class="text-xs text-red-500 mt-1 hidden" data-export-type-target="anwesenheitSection baspoAwkSection">
          Pflichtfeld: Für diesen Export-Typ muss ein Kurs gewählt werden.
        </p>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      2a. FELDER & REIHENFOLGE (nur Teilnehmerliste)
  ══════════════════════════════════════════════════════════════════════════ %>
  <div data-export-type-target="teilnehmerSection"
       class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden
              <%= export_profile.export_type == 'anwesenheitsliste' ? 'hidden' : '' %>">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">2 · Felder &amp; Reihenfolge</p>
    </div>
    <div class="px-5 py-5">
      <p class="text-xs text-gray-500 mb-3">Aktiviere die gewünschten Felder. Die Reihenfolge bestimmt die Spaltenreihenfolge im Export.</p>
      <div data-controller="field-sorter" class="space-y-1.5">
        <% ordered   = export_profile.fields.reject(&:blank?) %>
        <% remaining = ExportProfile::AVAILABLE_FIELDS.keys - ordered %>
        <% (ordered + remaining).each do |key| %>
          <div data-field-sorter-target="row"
               class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-2.5 hover:border-gray-300 transition">
            <%= check_box_tag "export_profile[fields][]", key,
                  export_profile.fields.include?(key),
                  id: "export_profile_fields_#{key}",
                  class: "w-4 h-4 rounded accent-primary-600 shrink-0" %>
            <label for="export_profile_fields_<%= key %>"
                   class="flex-1 text-sm font-medium text-gray-700 cursor-pointer select-none">
              <%= ExportProfile::AVAILABLE_FIELDS[key] %>
            </label>
            <div class="flex gap-1 shrink-0">
              <button type="button" data-action="click->field-sorter#moveUp"
                      class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition" title="Nach oben">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
                </svg>
              </button>
              <button type="button" data-action="click->field-sorter#moveDown"
                      class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition" title="Nach unten">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </div>
          </div>
        <% end %>
        <%= hidden_field_tag "export_profile[fields][]", "" %>
      </div>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      2c. BASPO PERSONENIMPORT (nur BASPO-Typ)
  ══════════════════════════════════════════════════════════════════════════ %>
  <div data-export-type-target="baspoSection"
       class="bg-blue-50 rounded-xl border border-blue-200 overflow-hidden
              <%= export_profile.export_type == 'baspo_personenimport' ? '' : 'hidden' %>">
    <div class="px-5 py-3 border-b border-blue-200 bg-blue-100">
      <p class="text-xs font-bold text-blue-700 uppercase tracking-wider">2 · BASPO-Format</p>
    </div>
    <div class="px-5 py-5">
      <div class="flex gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="text-sm text-blue-800">
          <p class="font-semibold mb-1">Das BASPO-Format ist fix definiert.</p>
          <p class="text-blue-700">Die CSV enthält automatisch alle 14 Pflichtfelder im korrekten Format:</p>
          <p class="mt-2 font-mono text-xs text-blue-600 bg-blue-100 px-3 py-2 rounded-lg leading-relaxed">
            PERSONENNUMMER · NAME · VORNAME · GEBURTSDATUM · GESCHLECHT · AHV_NR · PEID ·
            NATIONALITAET · MUTTERSPRACHE · STRASSE · HAUSNUMMER · PLZ · ORT · LAND
          </p>
          <ul class="mt-3 text-xs text-blue-700 space-y-1 list-disc ml-4">
            <li>Trennzeichen: Semikolon, UTF-8 mit BOM (Excel-kompatibel)</li>
            <li>Geschlecht: m / w</li>
            <li>Geburtsdatum: DD.MM.YYYY</li>
            <li>PEID bleibt leer (wird von BASPO vergeben)</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      2d. BASPO AWK-KONFIGURATION (nur BASPO AWK)
  ══════════════════════════════════════════════════════════════════════════ %>
  <div data-export-type-target="baspoAwkSection"
       class="bg-blue-50 rounded-xl border border-blue-200 overflow-hidden
              <%= export_profile.export_type == 'baspo_awk' ? '' : 'hidden' %>">
    <div class="px-5 py-3 border-b border-blue-200 bg-blue-100">
      <p class="text-xs font-bold text-blue-700 uppercase tracking-wider">2 · AWK-Konfiguration</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <div class="flex gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="text-sm text-blue-800">
          <p class="font-semibold mb-1">Das AWK-Format ist fix definiert gemäss BASPO-Vorgaben.</p>
          <p class="text-blue-700">Pro Trainings-Session wird je eine Zeile für jeden anwesenden Teilnehmer und jeden Trainer exportiert.</p>
          <p class="mt-2 font-mono text-xs text-blue-600 bg-blue-100 px-3 py-2 rounded-lg">
            PERSONENNUMMER · FUNKTION · DATUM · AKTIVITAETSTYP · ZEIT · DAUER · ORT
          </p>
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold text-gray-700 mb-1.5">Zeitraum</p>
        <div class="flex flex-wrap gap-2 mb-3">
          <% ExportProfile::DATE_RANGE_TYPES.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :date_range_type, val, class: "accent-primary-600",
                    data: { action: "change->export-type#toggleDateRange" } %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
        <div data-export-type-target="dateCustomSection"
             class="grid grid-cols-2 gap-3 <%= export_profile.date_range_type != 'custom' ? 'hidden' : '' %>">
          <div>
            <%= f.label :date_from, "Von", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.date_field :date_from,
                  class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :date_to, "Bis", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.date_field :date_to,
                  class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      2b. ANWESENHEITS-KONFIGURATION (nur Anwesenheitsliste)
  ══════════════════════════════════════════════════════════════════════════ %>
  <div data-export-type-target="anwesenheitSection"
       class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden
              <%= export_profile.export_type == 'teilnehmerliste' ? 'hidden' : '' %>">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">2 · Anwesenheits-Konfiguration</p>
    </div>
    <div class="px-5 py-5 space-y-6">

      <%# Zeitraum %>
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-1.5">Zeitraum</p>
        <div class="flex flex-wrap gap-2 mb-3">
          <% ExportProfile::DATE_RANGE_TYPES.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :date_range_type, val, class: "accent-primary-600",
                    data: { action: "change->export-type#toggleDateRange" } %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
        <div data-export-type-target="dateCustomSection"
             class="grid grid-cols-2 gap-3 <%= export_profile.date_range_type != 'custom' ? 'hidden' : '' %>">
          <div>
            <%= f.label :date_from, "Von", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.date_field :date_from,
                  class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :date_to, "Bis", class: "block text-xs font-semibold text-gray-600 mb-1" %>
            <%= f.date_field :date_to,
                  class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>
      </div>

      <%# Fixe Spalten (Teilnehmer-Stammdaten) %>
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-0.5">Fixe Spalten (Teilnehmer-Stammdaten)</p>
        <p class="text-xs text-gray-400 mb-2">Diese Felder erscheinen links vor den Session-Spalten.</p>
        <div data-controller="field-sorter" class="space-y-1.5">
          <% ordered   = export_profile.fields.reject(&:blank?) %>
          <% remaining = ExportProfile::AVAILABLE_FIELDS.except("courses").keys - ordered %>
          <% (ordered + remaining).each do |key| %>
            <% next if key == "courses" %>
            <div data-field-sorter-target="row"
                 class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-2 hover:border-gray-300 transition">
              <%= check_box_tag "export_profile[fields][]", key,
                    export_profile.fields.include?(key),
                    id: "export_profile_att_fields_#{key}",
                    class: "w-4 h-4 rounded accent-primary-600 shrink-0" %>
              <label for="export_profile_att_fields_<%= key %>"
                     class="flex-1 text-sm font-medium text-gray-700 cursor-pointer select-none">
                <%= ExportProfile::AVAILABLE_FIELDS[key] %>
              </label>
              <div class="flex gap-1 shrink-0">
                <button type="button" data-action="click->field-sorter#moveUp"
                        class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
                  </svg>
                </button>
                <button type="button" data-action="click->field-sorter#moveDown"
                        class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </div>
            </div>
          <% end %>
          <%= hidden_field_tag "export_profile[fields][]", "" %>
        </div>
      </div>

      <%# Spaltenüberschrift-Format %>
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-1.5">Spaltenüberschrift Session-Datum</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::DATE_COLUMN_FORMATS.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :date_column_format, val, class: "accent-primary-600" %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Anwesenheitssymbole %>
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-1.5">Zellenwert / Symbolik</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::ATTENDANCE_SYMBOL_PRESETS.each do |key, syms| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :attendance_symbols, key, class: "accent-primary-600" %>
              <span class="font-medium text-gray-700">
                <%= { "symbols" => "Symbole", "letters" => "Buchstaben", "full" => "Volltext" }[key] %>
                <span class="text-gray-400 font-mono text-xs ml-1">
                  <%= "#{syms['anwesend']} / #{syms['abwesend']} / #{syms['abgemeldet']}" %>
                </span>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Zusammenfassungsspalten %>
      <div>
        <p class="text-sm font-semibold text-gray-700 mb-0.5">Zusammenfassungsspalten</p>
        <p class="text-xs text-gray-400 mb-2">Werden rechts nach den Session-Spalten eingefügt.</p>
        <div class="grid grid-cols-2 gap-2">
          <% ExportProfile::SUMMARY_COLUMNS.each do |val, label| %>
            <label class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2.5 cursor-pointer hover:border-gray-300 transition text-sm">
              <%= check_box_tag "export_profile[include_summary_columns][]", val,
                    Array(export_profile.include_summary_columns).include?(val),
                    class: "w-4 h-4 rounded accent-primary-600 shrink-0" %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
        <%= hidden_field_tag "export_profile[include_summary_columns][]", "" %>
      </div>

      <%# Zusatzoptionen %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-1.5">Sortierung</p>
          <%= f.select :sort_by,
                ExportProfile::SORT_OPTIONS.map { |v, l| [l, v] },
                { selected: export_profile.sort_by || "last_name" },
                class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-1.5">Leerzeilen zwischen Teilnehmern</p>
          <%= f.number_field :extra_empty_rows, min: 0, max: 5,
                class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <p class="text-xs text-gray-400 mt-1">Für handschriftliche Ergänzungen beim Drucken.</p>
        </div>
        <div class="flex flex-col justify-end pb-1">
          <label class="flex items-center gap-3 cursor-pointer">
            <%= f.check_box :include_canceled_sessions, class: "w-4 h-4 rounded accent-primary-600" %>
            <div>
              <span class="text-sm font-semibold text-gray-700">Abgesagte Trainings einschliessen</span>
              <p class="text-xs text-gray-400">Als eigene Spalte mit Hinweis ausgeben.</p>
            </div>
          </label>
        </div>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      3. FORMAT-EINSTELLUNGEN
  ══════════════════════════════════════════════════════════════════════════ %>
  <div data-export-type-target="formatSection"
       class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden
              <%= export_profile.export_type == 'baspo_personenimport' ? 'hidden' : '' %>">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">3 · Format</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <%# Datei-Format %>
      <div>
        <%= f.label :format, "Dateiformat", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <div class="flex gap-2 flex-wrap">
          <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white">
            <%= f.radio_button :format, "csv", class: "accent-primary-600",
                  data: { action: "change->export-type#toggleFormat" } %>
            <span class="text-sm font-medium text-gray-700">CSV</span>
          </label>
          <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white">
            <%= f.radio_button :format, "xlsx", class: "accent-primary-600",
                  data: { action: "change->export-type#toggleFormat" } %>
            <div>
              <span class="text-sm font-medium text-gray-700">Excel (XLSX)</span>
              <span class="ml-1.5 text-xs font-semibold text-secondary-600 bg-secondary-50 px-1.5 py-0.5 rounded">Anwesenheitsliste</span>
            </div>
          </label>
          <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white">
            <%= f.radio_button :format, "pdf", class: "accent-primary-600",
                  data: { action: "change->export-type#toggleFormat" } %>
            <div>
              <span class="text-sm font-medium text-gray-700">PDF</span>
              <span class="ml-1.5 text-xs font-semibold text-secondary-600 bg-secondary-50 px-1.5 py-0.5 rounded">Anwesenheitsliste</span>
            </div>
          </label>
        </div>
      </div>

      <%# CSV-spezifische Optionen %>
      <div data-export-type-target="csvSection"
           class="space-y-5 <%= export_profile.format != 'csv' ? 'hidden' : '' %>">

        <%# Spaltentrennzeichen %>
        <div>
          <p class="block text-sm font-semibold text-gray-700 mb-1.5">Spaltentrennzeichen</p>
          <div class="flex flex-wrap gap-2">
            <% ExportProfile::COL_SEPS.each do |val, label| %>
              <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
                <%= f.radio_button :col_sep, val, class: "accent-primary-600" %>
                <span class="font-medium text-gray-700"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Zeilentrennzeichen %>
        <div>
          <p class="block text-sm font-semibold text-gray-700 mb-1.5">Zeilenumbruch</p>
          <div class="flex flex-wrap gap-2">
            <% ExportProfile::ROW_SEPS.each do |val, label| %>
              <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
                <%= f.radio_button :row_sep, val, class: "accent-primary-600" %>
                <span class="font-medium text-gray-700 font-mono"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Anführungszeichen %>
        <div>
          <p class="block text-sm font-semibold text-gray-700 mb-1.5">Anführungszeichen</p>
          <div class="flex flex-wrap gap-2">
            <% ExportProfile::QUOTE_CHARS.each do |val, label| %>
              <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
                <%= f.radio_button :quote_char, val, class: "accent-primary-600" %>
                <span class="font-medium text-gray-700 font-mono"><%= label %></span>
              </label>
            <% end %>
          </div>
        </div>

      </div>

      <%# Kopfzeile – gilt für alle Formate %>
      <div>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :include_header, class: "w-4 h-4 rounded accent-primary-600" %>
          <div>
            <span class="text-sm font-semibold text-gray-700">Kopfzeile einschliessen</span>
            <p class="text-xs text-gray-400">Erste Zeile enthält die Spaltennamen / Spaltenüberschriften.</p>
          </div>
        </label>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      4. AUTOMATISCHER EXPORT
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">4 · Automatischer Export</p>
    </div>
    <div class="px-5 py-5 space-y-5">
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Intervall</p>
        <p class="text-xs text-gray-400 mb-2">Bei aktiviertem Intervall wird der Export automatisch generiert und per E-Mail versandt.</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::SCHEDULES.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :schedule, val, class: "accent-primary-600",
                    data: { action: "change->export-schedule#toggle" } %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>
      <div>
        <%= f.label :recipient_email, "Empfänger-E-Mail", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.email_field :recipient_email,
              placeholder: "admin@beispiel.ch",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
        <p class="text-xs text-gray-400 mt-1">Nur relevant wenn ein Intervall (nicht "Kein automatischer Export") gewählt ist.</p>
      </div>
    </div>
  </div>

  <%# ── Aktionen ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 pt-1">
    <%= f.submit export_profile.persisted? ? "Änderungen speichern" : "Exportprofil erstellen",
          class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition cursor-pointer min-h-11" %>
    <%= link_to "Abbrechen", admin_export_profiles_path,
          class: "w-full sm:w-auto text-center text-sm font-medium text-gray-500 hover:text-gray-700 bg-gray-100 hover:bg-gray-200 py-2.5 px-5 rounded-xl transition min-h-11" %>
  </div>

<% end %>
