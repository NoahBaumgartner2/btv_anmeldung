<%= form_with model: [:admin, export_profile], class: "space-y-8" do |f| %>

  <%# ── Fehler ──────────────────────────────────────────────────────────────── %>
  <% if export_profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 text-sm text-red-700 space-y-1">
      <% export_profile.errors.full_messages.each do |msg| %>
        <p>• <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════════════
      1. GRUNDEINSTELLUNGEN
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">1 · Grundeinstellungen</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <%# Name %>
      <div>
        <%= f.label :name, "Profilname", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.text_field :name,
              placeholder: "z. B. Teilnehmerliste komplett",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
        <p class="text-xs text-gray-400 mt-1">Dieser Name erscheint als Schaltfläche in der Teilnehmersuche.</p>
      </div>

      <%# Kurs-Filter %>
      <div>
        <%= f.label :course_id, "Kurs-Filter (optional)", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.select :course_id,
              options_for_select(
                [["Alle Teilnehmer (kein Filter)", ""]] +
                Course.order(:title).map { |c| [c.title, c.id] },
                export_profile.course_id
              ),
              {},
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
        <p class="text-xs text-gray-400 mt-1">Nur Teilnehmer, die in diesem Kurs angemeldet sind, werden exportiert.</p>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      2. FELDER & REIHENFOLGE
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">2 · Felder &amp; Reihenfolge</p>
    </div>
    <div class="px-5 py-5">
      <p class="text-xs text-gray-500 mb-3">Aktiviere die gewünschten Felder. Die Reihenfolge von oben nach unten bestimmt die Spaltenreihenfolge im Export.</p>

      <div data-controller="field-sorter" class="space-y-1.5">
        <%# Zuerst gewählte Felder in ihrer gespeicherten Reihenfolge, dann die restlichen %>
        <% ordered = export_profile.fields.reject(&:blank?) %>
        <% remaining = ExportProfile::AVAILABLE_FIELDS.keys - ordered %>
        <% (ordered + remaining).each do |key| %>
          <div data-field-sorter-target="row"
               class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-2.5 hover:border-gray-300 transition">
            <%# Checkbox %>
            <%= check_box_tag "export_profile[fields][]", key,
                  export_profile.fields.include?(key),
                  id: "export_profile_fields_#{key}",
                  class: "w-4 h-4 rounded accent-primary-600 shrink-0" %>
            <label for="export_profile_fields_<%= key %>"
                   class="flex-1 text-sm font-medium text-gray-700 cursor-pointer select-none">
              <%= ExportProfile::AVAILABLE_FIELDS[key] %>
            </label>
            <%# Sortier-Pfeile %>
            <div class="flex gap-1 shrink-0">
              <button type="button"
                      data-action="click->field-sorter#moveUp"
                      class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition"
                      title="Nach oben">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
                </svg>
              </button>
              <button type="button"
                      data-action="click->field-sorter#moveDown"
                      class="p-1 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition"
                      title="Nach unten">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </div>
          </div>
        <% end %>
        <%# Leeres verstecktes Feld damit leere Auswahl korrekt übermittelt wird %>
        <%= hidden_field_tag "export_profile[fields][]", "" %>
      </div>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      3. FORMAT-EINSTELLUNGEN
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">3 · Format</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <%# Datei-Format %>
      <div>
        <%= f.label :format, "Dateiformat", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <div class="flex gap-2">
          <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white">
            <%= f.radio_button :format, "csv", class: "accent-primary-600" %>
            <span class="text-sm font-medium text-gray-700">CSV</span>
          </label>
        </div>
      </div>

      <%# Spaltentrennzeichen %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Spaltentrennzeichen</p>
        <p class="text-xs text-gray-400 mb-2">Das Zeichen, das Werte in derselben Zeile voneinander trennt.</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::COL_SEPS.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :col_sep, val, class: "accent-primary-600" %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Zeilentrennzeichen %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Zeilenumbruch</p>
        <p class="text-xs text-gray-400 mb-2">Das Zeichen(n), das eine neue Zeile / einen neuen Datensatz signalisiert.</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::ROW_SEPS.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :row_sep, val, class: "accent-primary-600" %>
              <span class="font-medium text-gray-700 font-mono"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Anführungszeichen %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Anführungszeichen (Textwert-Umschliesszeichen)</p>
        <p class="text-xs text-gray-400 mb-2">Zeichen, das um Textwerte mit Sonderzeichen gesetzt wird.</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::QUOTE_CHARS.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :quote_char, val, class: "accent-primary-600" %>
              <span class="font-medium text-gray-700 font-mono"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Header-Zeile %>
      <div>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :include_header, class: "w-4 h-4 rounded accent-primary-600" %>
          <div>
            <span class="text-sm font-semibold text-gray-700">Kopfzeile einschliessen</span>
            <p class="text-xs text-gray-400">Erste Zeile enthält die Spaltennamen (z.&thinsp;B. "Nachname;Vorname;…").</p>
          </div>
        </label>
      </div>

    </div>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════════
      4. AUTOMATISCHER EXPORT (INTERVALL)
  ══════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-200 bg-white">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">4 · Automatischer Export</p>
    </div>
    <div class="px-5 py-5 space-y-5">

      <%# Intervall %>
      <div>
        <p class="block text-sm font-semibold text-gray-700 mb-1.5">Intervall</p>
        <p class="text-xs text-gray-400 mb-2">Bei aktiviertem Intervall wird der Export automatisch generiert und per E-Mail versandt.</p>
        <div class="flex flex-wrap gap-2">
          <% ExportProfile::SCHEDULES.each do |val, label| %>
            <label class="flex items-center gap-2 px-4 py-2.5 border rounded-lg cursor-pointer has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 transition bg-white text-sm">
              <%= f.radio_button :schedule, val, class: "accent-primary-600",
                    data: { action: "change->export-schedule#toggle" } %>
              <span class="font-medium text-gray-700"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Empfänger-E-Mail (immer sichtbar, aber nur relevant wenn Intervall aktiv) %>
      <div>
        <%= f.label :recipient_email, "Empfänger-E-Mail", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.email_field :recipient_email,
              placeholder: "admin@beispiel.ch",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" %>
        <p class="text-xs text-gray-400 mt-1">Wird nur verwendet wenn ein Intervall (nicht "Kein automatischer Export") ausgewählt ist.</p>
      </div>

    </div>
  </div>

  <%# ── Aktionen ─────────────────────────────────────────────────────────── %>
  <div class="flex items-center gap-3 pt-1">
    <%= f.submit export_profile.persisted? ? "Anderungen speichern" : "Exportprofil erstellen",
          class: "inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition cursor-pointer" %>
    <%= link_to "Abbrechen", admin_export_profiles_path,
          class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition" %>
  </div>

<% end %>
