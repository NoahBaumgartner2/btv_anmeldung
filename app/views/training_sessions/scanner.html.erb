<div class="max-w-xl mx-auto mt-10 p-4 text-center mb-16">
  <h1 class="text-3xl font-extrabold text-gray-900 mb-2">📸 Live-Scanner</h1>
  <p class="text-gray-500 mb-8">Klicke unten auf "Request Camera Permissions", um die Kamera zu starten.</p>

  <div id="reader" class="mx-auto w-full max-w-sm rounded-3xl shadow-md border-4 border-dashed border-purple-200 p-4 bg-white"></div>

  <div id="scan-result" class="mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-gray-100 text-gray-400 border border-gray-200 shadow-sm">
    Warte auf Kamera...
  </div>

  <%= link_to "Zurück zur Checkliste", training_session_path(@training_session), class: "mt-8 inline-block bg-white border border-gray-300 py-3 px-6 rounded-xl font-bold text-gray-700 hover:bg-gray-50 shadow-sm" %>
</div>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript" nonce="<%= request.content_security_policy_nonce %>"></script>

<script nonce="<%= request.content_security_policy_nonce %>">
  setTimeout(() => {
    if (!document.getElementById("reader")) return;

    const html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: {width: 250, height: 250} }, false);
    let lastScannedUrl = "";

    function onScanSuccess(decodedText, decodedResult) {
      if (decodedText === lastScannedUrl) return;
      lastScannedUrl = decodedText;

      const resultDiv = document.getElementById('scan-result');
      resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-blue-100 text-blue-800 border border-blue-200 shadow-sm";
      resultDiv.innerText = "⏳ Prüfe Ticket...";

      // BULLETPROOF-TRICK: Wir extrahieren nur den Pfad aus dem QR-Code!
      // Aus "http://localhost:3000/course_registrations/1/scan" wird "/course_registrations/1/scan"
      // BULLETPROOF-TRICK: Wir extrahieren den Pfad und hängen die aktuelle Checklisten-ID an!
      let fetchUrl = decodedText;
      try {
        let urlObj = new URL(decodedText);
        urlObj.searchParams.append("session_id", "<%= @training_session.id.to_json %>");
        fetchUrl = urlObj.pathname + urlObj.search; 
      } catch(e) {}

      // Wir schicken die Anfrage ab
      fetch(fetchUrl, {
        headers: { 
          'Accept': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        },
        credentials: 'same-origin'
      })
      .then(async (response) => {
        // Falls wir versehentlich auf der Login-Seite landen
        if (!response.ok || response.redirected || response.headers.get("content-type")?.includes("text/html")) {
          throw new Error("Sicherheits-Blockade oder nicht eingeloggt.");
        }
        return response.json();
      })
      .then(data => {
        if (data.success) {
          resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-green-100 text-green-800 border border-green-200 shadow-sm scale-105";
          resultDiv.innerText = data.message;
        } else {
          resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-red-100 text-red-800 border border-red-200 shadow-sm";
          resultDiv.innerText = "❌ " + (data.message || "Fehler beim Scan");
        }
        
        setTimeout(() => {
          lastScannedUrl = "";
          resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-gray-100 text-gray-400 border border-gray-200 shadow-sm";
          resultDiv.innerText = "Warte auf Kamera...";
        }, 2500);
      })
      .catch(err => {
        // HIER IST DER FIX: Wenn es kracht, wird es jetzt sichtbar ROT!
        console.error("Scanner Fehler:", err);
        resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-red-100 text-red-800 border border-red-200 shadow-sm";
        resultDiv.innerText = "❌ Scan fehlgeschlagen (Netzwerk?)";
        
        setTimeout(() => {
          lastScannedUrl = "";
          resultDiv.className = "mt-8 h-16 flex items-center justify-center rounded-2xl font-bold text-xl transition-all duration-300 bg-gray-100 text-gray-400 border border-gray-200 shadow-sm";
          resultDiv.innerText = "Warte auf Kamera...";
        }, 3000);
      });
    }

    html5QrcodeScanner.render(onScanSuccess);
  }, 500);
</script>
