<%
  course     = @training_session.course
  attended   = @training_session.is_canceled? ? 0 : @attendances_by_reg_id.values.count { |a| !a.abgemeldet? }
  total      = @registrations.size
  pct        = total > 0 ? (attended.to_f / total * 100).round : 0
%>

<div class="max-w-2xl mx-auto w-full px-4 mt-8 mb-16">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="mb-6">
    <%= link_to manage_course_path(course),
          class: "inline-flex items-center gap-1.5 text-sm font-semibold text-gray-400 hover:text-gray-700 transition mb-3" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= course.title %>
    <% end %>

    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold text-gray-900">
          Präsenzkontrolle
        </h1>
        <p class="text-gray-500 text-sm mt-1">
          <% if @training_session.start_time %>
            <%= @training_session.start_time.strftime("%-d. %B %Y") %>
            <% if @training_session.end_time %>
              · <%= @training_session.start_time.strftime("%H:%M") %> – <%= @training_session.end_time.strftime("%H:%M") %> Uhr
            <% else %>
              · <%= @training_session.start_time.strftime("%H:%M") %> Uhr
            <% end %>
          <% end %>
          <% if course.location.present? %>
            · <%= course.location %>
          <% end %>
        </p>
      </div>

      <%= link_to scanner_training_session_path(@training_session),
            class: "shrink-0 inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        QR-Scanner öffnen
      <% end %>
    </div>
  </div>

  <%# ── Absagen / Rückgängig ────────────────────────────────────────────── %>
  <% if @training_session.is_canceled? %>
    <% if current_user.admin? %>
      <div class="mb-6">
        <%= button_to uncancel_training_session_path(@training_session),
              method: :post,
              data: { turbo_confirm: "Absage wirklich rückgängig machen? Das Training wird wieder als aktiv markiert." },
              class: "inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Absage rückgängig machen
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="mb-6">
      <%# Trigger-Button %>
      <button type="button"
              data-panel="cancel-panel"
              onclick="document.getElementById(this.dataset.panel).classList.remove('hidden'); this.classList.add('hidden');"
              class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        Training absagen
      </button>

      <%# Bestätigungs-Panel %>
      <div id="cancel-panel" class="hidden mt-3 bg-red-50 border border-red-200 rounded-xl p-5">
        <h3 class="font-bold text-red-800 text-sm mb-3">Was passiert beim Absagen?</h3>
        <ul class="text-sm text-red-700 space-y-1.5 mb-4 list-disc list-inside">
          <li>Das Training wird dauerhaft als <strong>abgesagt</strong> markiert.</li>
          <li>Alle <strong><%= @registrations.size %> bestätigten Teilnehmenden</strong> erhalten sofort eine Absage per E-Mail.</li>
          <li>Die Anwesenheitskontrolle für dieses Training ist dann gesperrt.</li>
          <li>Nur Admins können die Absage danach rückgängig machen.</li>
        </ul>
        <div class="flex items-center gap-3">
          <%= button_to cancel_training_session_path(@training_session),
                method: :post,
                class: "inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-sm py-2 px-4 rounded-lg transition cursor-pointer" do %>
            Ja, Training absagen
          <% end %>
          <button type="button"
                  onclick="document.getElementById('cancel-panel').classList.add('hidden'); document.querySelector('[data-panel=cancel-panel]').classList.remove('hidden');"
                  class="text-sm font-semibold text-gray-600 hover:text-gray-900 transition cursor-pointer">
            Abbrechen
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Anwesenheits-Fortschritt ────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-3">
        <span class="text-3xl font-extrabold text-gray-900"><%= attended %></span>
        <span class="text-gray-400 font-medium text-sm">/ <%= total %> Teilnehmende</span>
      </div>
      <span class="text-sm font-bold <%= pct == 100 ? 'text-green-600' : 'text-gray-500' %>">
        <%= pct %> %
      </span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-2">
      <div class="h-2 rounded-full transition-all duration-500 <%= pct == 100 ? 'bg-green-500' : 'bg-primary-500' %>"
           style="width: <%= pct %>%"></div>
    </div>
    <% if @training_session.is_canceled? %>
      <p class="mt-3 text-xs font-bold text-red-600 uppercase tracking-wide">Abgesagt</p>
    <% end %>
  </div>

  <%# ── Teilnehmerliste ─────────────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-bold text-gray-900">Teilnehmende</h2>
      <span class="text-xs text-gray-400 font-medium"><%= total %> angemeldet</span>
    </div>

    <% if @registrations.any? %>
      <ul class="divide-y divide-gray-50">
        <% @registrations.each do |reg| %>
          <% participant     = reg.participant %>
          <% attendance      = @attendances_by_reg_id[reg.id] %>
          <% is_unsubscribed = attendance&.abgemeldet? %>
          <% is_present      = !@training_session.is_canceled? && attendance.present? && !is_unsubscribed %>

          <li class="px-5 py-3.5 flex items-center justify-between gap-3
                     <%= is_unsubscribed ? 'bg-red-50/40 opacity-60' : is_present ? 'bg-green-50/40' : 'hover:bg-gray-50' %> transition">
            <div class="flex items-center gap-3 min-w-0">
              <div class="h-9 w-9 shrink-0 rounded-full flex items-center justify-center font-bold text-sm
                          <%= is_unsubscribed ? 'bg-red-100 text-red-400' : is_present ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= participant.first_name[0] %><%= participant.last_name[0] %>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900 truncate">
                  <%= participant.first_name %> <%= participant.last_name %>
                </p>
                <% if is_unsubscribed %>
                  <p class="text-xs text-red-500 font-medium">Von Eltern abgemeldet</p>
                <% end %>
              </div>
            </div>

            <% if is_unsubscribed %>
              <span class="shrink-0 text-xs font-bold px-3.5 py-1.5 rounded-full bg-red-100 text-red-500">
                Abgemeldet
              </span>
            <% elsif @training_session.is_canceled? %>
              <span class="shrink-0 text-xs font-bold px-3.5 py-1.5 rounded-full bg-gray-100 text-gray-400">
                Abwesend
              </span>
            <% else %>
              <%= button_to toggle_attendance_training_session_path(@training_session, course_registration_id: reg.id),
                    method: :post,
                    class: "shrink-0 cursor-pointer text-xs font-bold px-3.5 py-1.5 rounded-full transition
                            #{is_present ? 'bg-green-100 text-green-800 hover:bg-green-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}" do %>
                <%= is_present ? "Anwesend" : "Abwesend" %>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-400 font-semibold text-sm">Keine bestätigten Teilnehmenden.</p>
      </div>
    <% end %>
  </div>

</div>
