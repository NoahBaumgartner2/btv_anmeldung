<%
  course     = @training_session.course
  attended   = @training_session.is_canceled? ? 0 : @attendances_by_reg_id.values.count { |a| !a.abgemeldet? }
  total      = @registrations.size
  pct        = total > 0 ? (attended.to_f / total * 100).round : 0
%>

<div class="max-w-2xl mx-auto w-full mt-6 sm:mt-8 mb-16">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="mb-5 sm:mb-6">
    <%= link_to manage_course_path(course),
          class: "inline-flex items-center gap-1.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition mb-3 min-h-[44px] py-2 -ml-1 px-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      <span class="break-words"><%= course.title %></span>
    <% end %>

    <div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 break-words">
        <%= t("training_sessions.show.title") %>
      </h1>
      <p class="text-gray-500 text-sm sm:text-base mt-1 break-words">
        <% if @training_session.start_time %>
          <%= @training_session.start_time.strftime("%-d. %B %Y") %>
          <% if @training_session.end_time %>
            · <%= @training_session.start_time.strftime("%H:%M") %> – <%= @training_session.end_time.strftime("%H:%M") %> <%= t("misc.time_suffix") %>
          <% else %>
            · <%= @training_session.start_time.strftime("%H:%M") %> <%= t("misc.time_suffix") %>
          <% end %>
        <% end %>
        <% if course.location.present? %>
          · <%= course.location %>
        <% end %>
      </p>
    </div>
  </div>

  <%# ── Abgesagt-Warnung ── %>
  <% if @training_session.is_canceled? %>
    <div class="mb-6 bg-red-50 border-2 border-red-300 rounded-2xl p-4 sm:p-5 flex items-start gap-3 sm:gap-4" role="alert">
      <div class="shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-red-100 flex items-center justify-center">
        <svg class="w-6 h-6 sm:w-7 sm:h-7 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-base sm:text-lg font-extrabold text-red-900"><%= t("training_sessions.show.cancelled_title") %></p>
        <p class="text-sm text-red-800 mt-1 break-words"><%= t("training_sessions.show.cancelled_body") %></p>
      </div>
    </div>
  <% end %>

  <%# ── QR-Scanner CTA (nur wenn nicht abgesagt) ─────────────────────────── %>
  <% unless @training_session.is_canceled? %>
    <%= link_to scanner_training_session_path(@training_session),
          class: "mb-5 sm:mb-6 w-full inline-flex items-center justify-center gap-2 bg-purple-600 hover:bg-purple-700 active:bg-purple-800 text-white font-extrabold text-base py-4 px-5 rounded-2xl transition shadow-sm min-h-[56px]" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <%= t("training_sessions.show.open_scanner") %>
    <% end %>
  <% end %>

  <%# ── Absagen / Rückgängig ────────────────────────────────────────────── %>
  <% if @training_session.is_canceled? %>
    <% if current_user.admin? %>
      <div class="mb-6">
        <%= button_to uncancel_training_session_path(@training_session),
              method: :post,
              data: { turbo_confirm: t("training_sessions.show.uncancel_confirm") },
              class: "inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <%= t("training_sessions.show.uncancel_btn") %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="mb-6" data-controller="cancel-training">
      <%# Trigger-Button %>
      <button type="button"
              data-cancel-training-target="trigger"
              data-action="click->cancel-training#open"
              class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <%= t("training_sessions.show.cancel_btn") %>
      </button>

      <%# Bestätigungs-Panel %>
      <div data-cancel-training-target="panel"
           class="hidden mt-3 bg-red-50 border border-red-200 rounded-xl p-5">
        <h3 class="font-bold text-red-800 text-sm mb-3"><%= t("training_sessions.show.cancel_panel_title") %></h3>
        <ul class="text-sm text-red-700 space-y-1.5 mb-4 list-disc list-inside">
          <li><%= t("training_sessions.show.cancel_bullet_1_html").html_safe %></li>
          <li><%= t("training_sessions.show.cancel_bullet_2_html", count: @registrations.size).html_safe %></li>
          <li><%= t("training_sessions.show.cancel_bullet_3") %></li>
          <li><%= t("training_sessions.show.cancel_bullet_4") %></li>
        </ul>
        <div class="flex items-center gap-3">
          <%= button_to cancel_training_session_path(@training_session),
                method: :post,
                class: "inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-sm py-2 px-4 rounded-lg transition cursor-pointer" do %>
            <%= t("training_sessions.show.confirm_cancel_btn") %>
          <% end %>
          <button type="button"
                  data-action="click->cancel-training#close"
                  class="text-sm font-semibold text-gray-600 hover:text-gray-900 transition cursor-pointer">
            <%= t("training_sessions.show.cancel_abort") %>
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Anwesenheits-Fortschritt ────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5 mb-6">
    <div class="flex items-center justify-between mb-3 gap-3">
      <div class="flex items-baseline gap-2 min-w-0">
        <span class="text-3xl sm:text-4xl font-extrabold text-gray-900"><%= attended %></span>
        <span class="text-gray-500 font-semibold text-sm sm:text-base">/ <%= total %> <%= t("training_sessions.show.participants_label") %></span>
      </div>
      <span class="shrink-0 text-base font-extrabold <%= pct == 100 ? 'text-green-600' : 'text-gray-700' %>">
        <%= pct %> %
      </span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
      <div class="h-2.5 rounded-full transition-all duration-500 <%= pct == 100 ? 'bg-green-500' : 'bg-primary-500' %>"
           style="width: <%= pct %>%"></div>
    </div>
  </div>

  <%# ── Teilnehmerliste ─────────────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-bold text-gray-900"><%= t("training_sessions.show.participants_label") %></h2>
      <span class="text-xs text-gray-400 font-medium"><%= t("training_sessions.show.registered_count", count: total) %></span>
    </div>

    <% if @registrations.any? %>
      <ul class="divide-y divide-gray-100">
        <% @registrations.each do |reg| %>
          <% participant     = reg.participant %>
          <% attendance      = @attendances_by_reg_id[reg.id] %>
          <% is_unsubscribed = attendance&.abgemeldet? %>
          <% is_present      = !@training_session.is_canceled? && attendance.present? && !is_unsubscribed %>

          <li class="px-4 sm:px-5 py-4 flex items-center justify-between gap-3
                     <%= is_unsubscribed ? 'bg-red-50/40 opacity-70' : is_present ? 'bg-green-50/40' : 'hover:bg-gray-50' %> transition">
            <div class="flex items-center gap-3 min-w-0 flex-1">
              <div class="h-11 w-11 shrink-0 rounded-full flex items-center justify-center font-bold text-sm
                          <%= is_unsubscribed ? 'bg-red-100 text-red-400' : is_present ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
                <%= participant.first_name[0] %><%= participant.last_name[0] %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-base font-bold text-gray-900 break-words leading-tight">
                  <%= participant.first_name %> <%= participant.last_name %>
                </p>
                <% if is_unsubscribed %>
                  <p class="text-xs text-red-600 font-semibold mt-0.5"><%= t("training_sessions.show.unsubscribed_by_parents") %></p>
                <% end %>
              </div>
            </div>

            <% if is_unsubscribed %>
              <span class="shrink-0 inline-flex items-center text-xs font-bold px-3 py-2 rounded-full bg-red-100 text-red-600 min-h-[36px]">
                <%= t("training_sessions.show.status_unsubscribed") %>
              </span>
            <% elsif @training_session.is_canceled? %>
              <span class="shrink-0 inline-flex items-center text-xs font-bold px-3 py-2 rounded-full bg-gray-100 text-gray-400 min-h-[36px]">
                <%= t("training_sessions.show.attendance_cancelled") %>
              </span>
            <% elsif @training_session.start_time > Time.current %>
              <span class="shrink-0 text-xs text-gray-400 font-medium px-3 py-2">
                <%= t("training_sessions.show.attendance_not_yet") %>
              </span>
            <% else %>
              <%= button_to toggle_attendance_training_session_path(@training_session, course_registration_id: reg.id),
                    method: :post,
                    "aria-label": (is_present ? t("training_sessions.show.mark_absent_aria", name: participant.first_name) : t("training_sessions.show.mark_present_aria", name: participant.first_name)),
                    class: "shrink-0 cursor-pointer inline-flex items-center justify-center gap-1.5 text-sm font-bold px-4 py-2.5 rounded-full transition min-h-[44px] min-w-[110px]
                            #{is_present ? 'bg-green-600 text-white hover:bg-green-700 active:bg-green-800 shadow-sm' : 'bg-gray-100 text-gray-700 hover:bg-gray-200 active:bg-gray-300 border border-gray-300'}" do %>
                <% if is_present %>
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  <%= t("training_sessions.show.status_present") %>
                <% else %>
                  <%= t("training_sessions.show.status_absent") %>
                <% end %>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-500 font-semibold text-sm"><%= t("training_sessions.show.no_participants") %></p>
      </div>
    <% end %>
  </div>

</div>
