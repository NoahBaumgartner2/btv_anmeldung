<%
  course     = @training_session.course
  attended   = @training_session.attendances.size
  total      = @registrations.size
  pct        = total > 0 ? (attended.to_f / total * 100).round : 0
%>

<div class="max-w-2xl mx-auto w-full px-4 mt-8 mb-16">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="mb-6">
    <%= link_to manage_course_path(course),
          class: "inline-flex items-center gap-1.5 text-sm font-semibold text-gray-400 hover:text-gray-700 transition mb-3" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= course.title %>
    <% end %>

    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold text-gray-900">
          Präsenzkontrolle
        </h1>
        <p class="text-gray-500 text-sm mt-1">
          <% if @training_session.start_time %>
            <%= @training_session.start_time.strftime("%-d. %B %Y") %>
            <% if @training_session.end_time %>
              · <%= @training_session.start_time.strftime("%H:%M") %> – <%= @training_session.end_time.strftime("%H:%M") %> Uhr
            <% else %>
              · <%= @training_session.start_time.strftime("%H:%M") %> Uhr
            <% end %>
          <% end %>
          <% if course.location.present? %>
            · <%= course.location %>
          <% end %>
        </p>
      </div>

      <%= link_to scanner_training_session_path(@training_session),
            class: "shrink-0 inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-700 text-white font-bold text-sm py-2.5 px-4 rounded-lg transition shadow-sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        QR-Scanner öffnen
      <% end %>
    </div>
  </div>

  <%# ── Anwesenheits-Fortschritt ────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-3">
        <span class="text-3xl font-extrabold text-gray-900"><%= attended %></span>
        <span class="text-gray-400 font-medium text-sm">/ <%= total %> Teilnehmende</span>
      </div>
      <span class="text-sm font-bold <%= pct == 100 ? 'text-green-600' : 'text-gray-500' %>">
        <%= pct %> %
      </span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-2">
      <div class="h-2 rounded-full transition-all duration-500 <%= pct == 100 ? 'bg-green-500' : 'bg-blue-500' %>"
           style="width: <%= pct %>%"></div>
    </div>
    <% if @training_session.is_canceled? %>
      <p class="mt-3 text-xs font-bold text-red-600 uppercase tracking-wide">Abgesagt</p>
    <% end %>
  </div>

  <%# ── Teilnehmerliste ─────────────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-bold text-gray-900">Teilnehmende</h2>
      <span class="text-xs text-gray-400 font-medium"><%= total %> angemeldet</span>
    </div>

    <% if @registrations.any? %>
      <ul class="divide-y divide-gray-50">
        <% @registrations.each do |reg| %>
          <% participant  = reg.participant %>
          <% is_present   = @training_session.attendances.exists?(course_registration_id: reg.id) %>

          <li class="px-5 py-3.5 flex items-center justify-between gap-3 <%= is_present ? 'bg-green-50/40' : 'hover:bg-gray-50' %> transition">
            <div class="flex items-center gap-3 min-w-0">
              <div class="h-9 w-9 shrink-0 rounded-full flex items-center justify-center font-bold text-sm
                          <%= is_present ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= participant.first_name[0] %><%= participant.last_name[0] %>
              </div>
              <p class="text-sm font-semibold text-gray-900 truncate">
                <%= participant.first_name %> <%= participant.last_name %>
              </p>
            </div>

            <%= button_to toggle_attendance_training_session_path(@training_session, course_registration_id: reg.id),
                  method: :post,
                  class: "shrink-0 cursor-pointer text-xs font-bold px-3.5 py-1.5 rounded-full transition
                          #{is_present ? 'bg-green-100 text-green-800 hover:bg-green-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}" do %>
              <%= is_present ? "Anwesend" : "Abwesend" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-12 text-center">
        <p class="text-gray-400 font-semibold text-sm">Keine bestätigten Teilnehmenden.</p>
      </div>
    <% end %>
  </div>

</div>
