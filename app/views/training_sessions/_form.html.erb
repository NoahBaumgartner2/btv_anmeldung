<%= form_with(model: training_session, class: "contents") do |form| %>
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6">
    <% if params[:course_id] || training_session.course_id %>
      <%= form.hidden_field :course_id, value: params[:course_id] || training_session.course_id %>
    <% end %>

<div>
      <%= form.label :start_time, "Datum des Trainings", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= form.date_field :start_time, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Abbrechen", :back, class: "bg-white py-2 px-4 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 shadow-sm" %>
    <%= form.submit "Training anlegen", class: "cursor-pointer bg-blue-600 py-2 px-4 rounded-md text-sm font-bold text-white hover:bg-blue-700 shadow-sm" %>
  </div>
<% end %>
