<%= form_with(model: training_session, class: "contents", data: { controller: "scroll-to-error" }) do |form| %>
  <% if training_session.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6" data-error-scroll-target>
      <p class="font-semibold mb-1"><%= t('training_sessions.form.errors', count: training_session.errors.count) %></p>
      <ul class="list-disc ml-5 text-sm space-y-0.5">
        <% training_session.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :course_id, value: params[:course_id] || training_session.course_id %>

  <div class="mb-6">
    <%= form.label :start_time, t('training_sessions.form.label_start'), class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.datetime_local_field :start_time,
          class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 min-h-11",
                  training_session.errors[:start_time].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
    <% if training_session.errors[:start_time].any? %>
      <p class="mt-1 text-xs text-red-600"><%= training_session.errors[:start_time].first %></p>
    <% end %>
  </div>

  <div class="mb-6">
    <%= form.label :end_time, t('training_sessions.form.label_end'), class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= form.datetime_local_field :end_time,
          class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-h-11" %>
  </div>

  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 pt-4 border-t border-gray-100">
    <%= form.submit training_session.new_record? ? t('training_sessions.form.save_new') : t('training_sessions.form.save_edit'),
          class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm min-h-11" %>
    <%= link_to t('training_sessions.form.cancel'), :back,
          class: "w-full sm:w-auto text-center rounded-lg px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition min-h-11 flex items-center justify-center" %>
  </div>
<% end %>
