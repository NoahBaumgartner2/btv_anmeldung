<div data-controller="cookie-consent"
     class="fixed bottom-0 left-0 right-0 z-50 p-4 sm:p-5 bg-white border-t border-gray-200 shadow-xl">
  <div class="container mx-auto max-w-4xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1 text-sm text-gray-600 leading-relaxed">
      <p>
        Wir verwenden technisch notwendige Cookies für den sicheren Betrieb dieser Plattform (Session, CSRF-Schutz). Weitere Cookies setzen wir nur mit deiner Einwilligung.
        <%= link_to "Datenschutzerklärung", privacy_path, class: "text-primary-600 underline hover:text-primary-800 whitespace-nowrap" %>
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-2 shrink-0">
      <button type="button"
              data-action="click->cookie-consent#acceptNecessary"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition cursor-pointer whitespace-nowrap">
        Nur notwendige akzeptieren
      </button>
      <button type="button"
              data-action="click->cookie-consent#acceptAll"
              class="px-4 py-2 text-sm font-bold text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition cursor-pointer whitespace-nowrap">
        Alle akzeptieren
      </button>
    </div>
  </div>
</div>
