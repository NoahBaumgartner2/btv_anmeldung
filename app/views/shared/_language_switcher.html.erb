<div class="flex items-center gap-0.5 bg-gray-100 rounded-lg p-0.5">
  <% [[:de, "DE"], [:fr, "FR"], [:en, "EN"]].each do |loc, label| %>
    <% active = I18n.locale == loc %>
    <%= button_to label, locale_path, method: :post,
          params: { locale: loc },
          class: "text-xs font-semibold px-2 py-1 rounded-md transition cursor-pointer " +
                 (active ? "bg-white text-primary-700 shadow-sm" : "text-gray-500 hover:text-gray-800") %>
  <% end %>
</div>
