<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="mb-8">
    <%= link_to "← E-Mail-Einstellungen", mail_setting_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2">E-Mail-Einstellungen bearbeiten</h1>
    <p class="text-gray-500 mt-1 text-sm">SMTP-Zugangsdaten für ausgehende E-Mails.</p>
  </div>

  <%= form_with model: @mail_setting, url: mail_setting_path, method: :patch do |f| %>
    <% if @mail_setting.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-5 py-4 mb-6">
        <p class="text-sm font-bold text-red-800 mb-2"><%= @mail_setting.errors.count %> Fehler:</p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
          <% @mail_setting.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── SMTP-Server ────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-5">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">SMTP-Server</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="sm:col-span-2">
          <%= f.label :smtp_host, "Host", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :smtp_host,
                placeholder: "smtp.beispiel.ch",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
        </div>
        <div>
          <%= f.label :smtp_port, "Port", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :smtp_port,
                min: 1, max: 65535,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
        </div>
      </div>

      <div>
        <%= f.label :smtp_username, "Benutzername", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :smtp_username,
              autocomplete: "off",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :smtp_password, "Passwort", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1">Leer lassen, um das gespeicherte Passwort beizubehalten.</p>
        <div class="relative">
          <%= f.password_field :smtp_password,
                autocomplete: "new-password",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 pr-10 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 js-pw-field" %>
          <button type="button"
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600 js-pw-toggle"
                  tabindex="-1">
            <svg class="h-4 w-4 js-eye-show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg class="h-4 w-4 js-eye-hide hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :smtp_authentication, "Authentifizierung", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :smtp_authentication,
                [["Plain", "plain"], ["Login", "login"], ["CRAM-MD5", "cram_md5"]],
                {},
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
        </div>
        <div class="flex items-center gap-3 pt-6">
          <%= f.check_box :smtp_enable_starttls,
                class: "w-4 h-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" %>
          <%= f.label :smtp_enable_starttls, "STARTTLS aktivieren", class: "text-sm font-medium text-gray-700" %>
        </div>
      </div>
    </div>

    <%# ── Absender ───────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-5">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">Absender</p>

      <div>
        <%= f.label :smtp_from_name, "Absender-Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :smtp_from_name,
              placeholder: "BTV Anmeldeportal",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>

      <div>
        <%= f.label :smtp_from_address, "Absender-Adresse", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :smtp_from_address,
              placeholder: "noreply@btv-anmeldung.ch",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <%# ── App-URL ───────────────────────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6 space-y-5">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide border-b border-gray-100 pb-3">App-URL (für E-Mail-Links)</p>

      <div>
        <%= f.label :app_host, "Domain", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1">Wird für Links in Bestätigungs- und Passwort-Reset-E-Mails verwendet.</p>
        <%= f.text_field :app_host,
              placeholder: "btvbern-anmeldung.ch",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <%# ── ENV-Hinweis ────────────────────────────────────────────────────── %>
    <div class="rounded-xl border border-gray-200 bg-gray-50 px-5 py-4 mb-6 text-xs text-gray-500">
      <p class="font-semibold text-gray-600 mb-1">ENV-Fallback</p>
      Falls keine Datenbank-Einstellungen gespeichert sind, werden die Umgebungsvariablen
      <code class="bg-gray-200 rounded px-1">SMTP_HOST</code>,
      <code class="bg-gray-200 rounded px-1">SMTP_PORT</code>,
      <code class="bg-gray-200 rounded px-1">SMTP_USERNAME</code>,
      <code class="bg-gray-200 rounded px-1">SMTP_PASSWORD</code>,
      <code class="bg-gray-200 rounded px-1">SMTP_FROM_ADDRESS</code>,
      <code class="bg-gray-200 rounded px-1">SMTP_FROM_NAME</code> verwendet.
    </div>

    <div class="flex flex-col sm:flex-row gap-3">
      <%= f.submit "Einstellungen speichern",
            class: "w-full sm:w-auto bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-6 rounded-xl shadow-sm text-sm transition cursor-pointer min-h-11" %>
      <%= link_to "Abbrechen", mail_setting_path,
            class: "w-full sm:w-auto text-center bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 font-bold py-2.5 px-6 rounded-xl text-sm transition min-h-11" %>
    </div>
  <% end %>

</div>

<script nonce="<%= request.content_security_policy_nonce %>">
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.js-pw-toggle');
    if (!btn) return;
    var wrapper = btn.closest('.relative');
    if (!wrapper) return;
    var input = wrapper.querySelector('.js-pw-field');
    if (!input) return;
    var show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    btn.querySelector('.js-eye-show').classList.toggle('hidden', show);
    btn.querySelector('.js-eye-hide').classList.toggle('hidden', !show);
  });
</script>
