<div class="max-w-3xl mx-auto mt-10 mb-16 px-4">

  <%# ── Header ────────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <%= link_to t('mail_settings.show.back'), dashboards_admin_path,
            class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mt-2"><%= t('mail_settings.show.title') %></h1>
      <p class="text-gray-500 mt-1 text-sm"><%= t('mail_settings.show.subtitle') %></p>
    </div>
    <%= link_to t('mail_settings.show.edit'), edit_mail_setting_path,
          class: "shrink-0 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm text-sm transition min-h-11" %>
  </div>

  <%# ── Aktueller Status ───────────────────────────────────────────────────── %>
  <% configured = @mail_setting.persisted? && @mail_setting.smtp_host.present? %>
  <div class="rounded-xl border <%= configured ? "border-green-200 bg-green-50" : "border-yellow-200 bg-yellow-50" %> px-5 py-4 mb-6 flex items-start gap-3">
    <% if configured %>
      <svg class="h-5 w-5 text-green-600 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <p class="text-sm font-bold text-green-800"><%= t('mail_settings.show.smtp_configured') %></p>
        <p class="text-xs text-green-700 mt-0.5"><%= @mail_setting.smtp_host %>:<%= @mail_setting.smtp_port %></p>
      </div>
    <% else %>
      <svg class="h-5 w-5 text-yellow-600 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <div>
        <p class="text-sm font-bold text-yellow-800"><%= t('mail_settings.show.smtp_not_configured') %></p>
        <p class="text-xs text-yellow-700 mt-0.5"><%= t('mail_settings.show.smtp_not_configured_detail') %></p>
      </div>
    <% end %>
  </div>

  <%# ── Einstellungen anzeigen ─────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('mail_settings.show.section_smtp') %></p>
    </div>
    <dl class="divide-y divide-gray-100">
      <% [
        ["Host",             @mail_setting.smtp_host.presence || "—"],
        ["Port",             @mail_setting.smtp_port&.to_s || "—"],
        ["Benutzername",     @mail_setting.smtp_username.presence || "—"],
        ["Passwort",         @mail_setting.smtp_password_encrypted.present? ? "••••••••" : "—"],
        ["Authentifizierung",@mail_setting.smtp_authentication.presence || "—"],
        ["STARTTLS",         @mail_setting.smtp_enable_starttls? ? t('mail_settings.show.label_starttls_active') : t('mail_settings.show.label_starttls_inactive')],
      ].each do |label, value| %>
        <div class="px-6 py-3.5 flex items-center justify-between text-sm">
          <dt class="font-medium text-gray-500 w-40 shrink-0"><%= label %></dt>
          <dd class="text-gray-900 font-semibold"><%= value %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('mail_settings.show.section_sender') %></p>
    </div>
    <dl class="divide-y divide-gray-100">
      <% [
        ["Name",    @mail_setting.smtp_from_name.presence || "—"],
        ["Adresse", @mail_setting.smtp_from_address.presence || "—"],
      ].each do |label, value| %>
        <div class="px-6 py-3.5 flex items-center justify-between text-sm">
          <dt class="font-medium text-gray-500 w-40 shrink-0"><%= label %></dt>
          <dd class="text-gray-900 font-semibold"><%= value %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%# ── App-URL ───────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-wide"><%= t('mail_settings.show.section_url') %></p>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-6 py-3.5 flex items-center justify-between text-sm">
        <dt class="font-medium text-gray-500 w-40 shrink-0"><%= t('mail_settings.show.label_domain') %></dt>
        <dd class="flex items-center gap-2 flex-wrap">
          <% if @mail_setting.app_host.present? %>
            <span class="text-gray-900 font-semibold"><%= @mail_setting.app_host %></span>
          <% else %>
            <span class="text-gray-900 font-semibold"><%= ENV.fetch("APP_HOST", "nicht gesetzt") %></span>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-700">ENV-Fallback aktiv</span>
          <% end %>
        </dd>
      </div>
    </dl>
  </div>

  <%# ── Test-E-Mail ────────────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <p class="text-sm font-bold text-gray-700 mb-1"><%= t('mail_settings.show.test_title') %></p>
    <p class="text-xs text-gray-500 mb-4">Überprüfe die Konfiguration, indem du eine Test-E-Mail versendest.</p>
    <%= form_with url: test_email_mail_setting_path, method: :post, class: "flex flex-col sm:flex-row gap-2" do |f| %>
      <%= f.email_field :test_to,
            placeholder: "empfaenger@beispiel.ch",
            required: true,
            class: "flex-1 rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 min-w-0" %>
      <%= f.submit t('mail_settings.show.test_btn'),
            class: "sm:shrink-0 bg-gray-800 hover:bg-gray-900 active:bg-black text-white font-bold py-2.5 px-5 rounded-xl text-sm transition cursor-pointer shadow-sm min-h-11" %>
    <% end %>
  </div>

</div>
