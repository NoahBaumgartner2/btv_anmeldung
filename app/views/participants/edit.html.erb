<% content_for :title, "Person bearbeiten" %>

<div class="max-w-2xl mx-auto w-full px-4 mt-10 mb-16">
  <div class="mb-8">
    <%= link_to "← Zurück zum Profil", participants_path,
          class: "text-sm font-semibold text-gray-500 hover:text-gray-800 transition" %>
    <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900 mt-3">Person bearbeiten</h1>
    <p class="text-gray-500 mt-1"><%= @participant.first_name %> <%= @participant.last_name %></p>
  </div>

  <%= render "form", participant: @participant %>
</div>
