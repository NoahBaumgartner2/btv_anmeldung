<% content_for :title, "Mein Profil" %>

<div class="max-w-2xl mx-auto w-full px-4 mt-8 mb-16">
  <h1 class="font-extrabold text-2xl sm:text-3xl text-gray-900 mb-2"><%= t("participants.my_profile.title") %></h1>
  <p class="text-gray-500 text-sm mb-8"><%= t("participants.my_profile.subtitle") %></p>

  <% if @trainer %>
    <%= form_with model: @trainer,
                  url: @trainer.new_record? ? trainers_path : update_profile_trainer_path(@trainer),
                  method: @trainer.new_record? ? :post : :patch,
                  class: "space-y-6" do |f| %>
      <% if @trainer.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
          <p class="font-semibold mb-1"><%= t("participants.my_profile.errors", count: @trainer.errors.count) %></p>
          <ul class="list-disc ml-5 text-sm space-y-0.5">
            <% @trainer.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Konto-Info %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4"><%= t("participants.my_profile.section_account") %></p>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold text-gray-700"><%= t("participants.my_profile.email_label") %></p>
            <p class="text-sm text-gray-900 mt-0.5"><%= current_user.email %></p>
          </div>
          <%= link_to t("participants.my_profile.account_settings"), edit_user_registration_path,
                class: "text-sm font-semibold text-primary-600 hover:text-primary-800 transition" %>
        </div>
      </div>

      <%# Persönliche Daten %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("participants.my_profile.section_personal") %></p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, t("participants.my_profile.first_name_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :first_name, placeholder: "Laura",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :last_name, t("participants.my_profile.last_name_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :last_name, placeholder: "Müller",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :date_of_birth, t("participants.my_profile.dob_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.date_field :date_of_birth,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :gender, t("participants.my_profile.gender_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.select :gender,
                  [[t("participants.my_profile.gender_prompt"), ""], [t("participants.my_profile.gender_male"), "männlich"], [t("participants.my_profile.gender_female"), "weiblich"]],
                  {},
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>

        <div>
          <%= f.label :phone, t("participants.my_profile.phone_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.telephone_field :phone, placeholder: "+41 79 123 45 67", autocomplete: "tel",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
        </div>
      </div>

      <%# Adresse %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("participants.my_profile.section_address") %></p>

        <div class="grid grid-cols-3 gap-4">
          <div class="col-span-2">
            <%= f.label :street, t("participants.my_profile.street_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :street, placeholder: "Musterstrasse",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :house_number, t("participants.my_profile.house_number_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :house_number, placeholder: "12",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div>
            <%= f.label :zip_code, t("participants.my_profile.zip_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :zip_code, placeholder: "3000",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div class="col-span-2">
            <%= f.label :city, t("participants.my_profile.city_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.text_field :city, placeholder: "Bern",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :nationality, t("participants.my_profile.nationality_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.select :nationality, [["CH", "CH"], ["FL", "FL"], [t("participants.my_profile.other_option"), t("participants.my_profile.other_option")]], {},
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
          <div>
            <%= f.label :mother_tongue, t("participants.my_profile.mother_tongue_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
            <%= f.select :mother_tongue, [["DE", "DE"], ["FR", "FR"], ["IT", "IT"], [t("participants.my_profile.other_option"), t("participants.my_profile.other_option")]], {},
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          </div>
        </div>
      </div>

      <%# J+S & AHV %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("participants.my_profile.section_js_ahv") %></p>

        <div>
          <%= f.label :ahv_number, class: "block text-sm font-semibold text-gray-700 mb-1" do %><%= t("participants.my_profile.ahv_label") %> <span class="font-normal text-gray-400"><%= t("participants.my_profile.optional") %></span><% end %>
          <p class="text-xs text-gray-400 mb-1.5"><%= t("participants.my_profile.ahv_format_hint") %></p>
          <%= f.text_field :ahv_number, placeholder: "756.1234.5678.90",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary-500" %>
        </div>

        <div>
          <p class="text-sm font-semibold text-gray-700 mb-2"><%= t("participants.my_profile.js_label") %></p>
          <label class="flex items-start gap-3 cursor-pointer">
            <%= f.check_box :js_anerkennung,
                  class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer shrink-0" %>
            <span class="text-sm text-gray-700"><%= t("participants.my_profile.js_hint") %></span>
          </label>
        </div>
      </div>

      <%# Lohnangaben %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider"><%= t("participants.my_profile.section_salary") %></p>

        <div>
          <%= f.label :iban, t("participants.my_profile.iban_label"), class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <p class="text-xs text-gray-400 mb-1.5"><%= t("participants.my_profile.iban_hint") %></p>
          <%= f.text_field :iban, placeholder: "CH56 0483 5012 3456 7800 9",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary-500" %>
          <% if @trainer.errors[:iban].any? %>
            <p class="mt-1 text-xs text-red-600"><%= @trainer.errors[:iban].first %></p>
          <% end %>
        </div>
      </div>

      <div>
        <%= f.submit t("participants.my_profile.save"),
              class: "w-full sm:w-auto rounded-lg px-6 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-bold cursor-pointer transition shadow-sm" %>
      </div>
    <% end %>

  <% elsif current_user.admin? %>
    <%# Konto-Info für Admin ohne Trainer-Profil %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4"><%= t("participants.my_profile.section_account") %></p>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-semibold text-gray-700"><%= t("participants.my_profile.email_label") %></p>
          <p class="text-sm text-gray-900 mt-0.5"><%= current_user.email %></p>
        </div>
        <%= link_to t("participants.my_profile.account_settings"), edit_user_registration_path,
              class: "text-sm font-semibold text-primary-600 hover:text-primary-800 transition" %>
      </div>
    </div>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm text-blue-800">
      <p class="font-semibold mb-1"><%= t("participants.my_profile.admin_title") %></p>
      <p><%= t("participants.my_profile.admin_body_html", link: link_to("hier", edit_user_registration_path, class: "underline font-semibold")).html_safe %></p>
    </div>
  <% end %>
</div>
