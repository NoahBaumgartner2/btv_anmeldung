<div class="max-w-5xl mx-auto w-full">

  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
    <div>
      <h1 class="font-bold text-2xl sm:text-3xl text-gray-900"><%= @participant.first_name %> <%= @participant.last_name %></h1>
      <span class="inline-block mt-2 bg-purple-100 text-purple-800 text-xs font-semibold px-2.5 py-0.5 rounded uppercase tracking-wide">
        Teilnehmer-Profil
      </span>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Zurück zur Übersicht", participants_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 active:bg-gray-100 transition min-h-11 inline-flex items-center" %>
      <%= link_to "Bearbeiten", edit_participant_path(@participant), class: "bg-orange-100 py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-orange-700 hover:bg-orange-200 active:bg-orange-300 transition min-h-11 inline-flex items-center" %>
      <%= button_to "Löschen", @participant, method: :delete, data: { turbo_confirm: "Wirklich löschen?" }, class: "cursor-pointer bg-red-600 py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white hover:bg-red-700 active:bg-red-800 transition min-h-11" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
      <h2 class="text-lg font-bold text-gray-800 border-b border-gray-100 pb-3 mb-4">Persönliche Daten</h2>
      <div class="space-y-3">
        <div>
          <p class="text-sm font-medium text-gray-500">Geburtsdatum</p>
          <p class="text-gray-900"><%= @participant.date_of_birth&.strftime("%d.%m.%Y") || "-" %></p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Geschlecht</p>
          <p class="text-gray-900"><%= @participant.gender.presence || "-" %></p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">AHV-Nummer</p>
          <p class="text-gray-900"><%= @participant.ahv_number.presence || "-" %></p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
      <h2 class="text-lg font-bold text-gray-800 border-b border-gray-100 pb-3 mb-4">Kontakt (Elternteil)</h2>
      <div class="space-y-3">
        <div>
          <p class="text-sm font-medium text-gray-500">Verknüpftes Konto (E-Mail)</p>
          <p class="text-gray-900 font-medium"><%= @participant.user.email %></p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Telefonnummer</p>
          <p class="text-gray-900"><%= @participant.phone_number.presence || "Nicht hinterlegt" %></p>
        </div>
      </div>
    </div>

  </div>

  <div class="mb-6 flex justify-between items-end">
    <h2 class="text-2xl font-bold text-gray-900">Angemeldete Kurse (<%= @participant.course_registrations.count %>)</h2>
  </div>

  <%# ── Mobile: Karten ─────────────────────────────────────────────────── %>
  <% if @participant.course_registrations.any? %>
    <div class="sm:hidden space-y-3">
      <% @participant.course_registrations.includes(:course).each do |registration| %>
        <% status_color = registration.status == 'bestätigt' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>
        <%= link_to course_path(registration.course), class: "block bg-white rounded-xl border border-gray-200 shadow-sm p-4 active:bg-gray-50 transition" do %>
          <div class="flex items-start justify-between gap-2 mb-2">
            <p class="font-bold text-gray-900 text-sm"><%= registration.course.title %></p>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium shrink-0 <%= status_color %>"><%= registration.status.capitalize %></span>
          </div>
          <div class="flex items-center gap-4 text-xs text-gray-500">
            <span><%= registration.course.start_date&.strftime("%d.%m.%Y") %></span>
            <span><%= registration.payment_cleared ? "Bezahlt" : "Ausstehend" %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ── Desktop: Tabelle ──────────────────────────────────────────────── %>
  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-lg overflow-x-auto hidden sm:block">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Kurs</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Startdatum</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Bezahlt?</th>
          <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Link</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% if @participant.course_registrations.any? %>
          <% @participant.course_registrations.includes(:course).each do |registration| %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="py-4 px-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= registration.course.title %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <%= registration.course.start_date&.strftime("%d.%m.%Y") %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <% status_color = registration.status == 'bestätigt' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>
                <span class="px-2 py-1 rounded-full text-xs font-medium <%= status_color %>">
                  <%= registration.status.capitalize %>
                </span>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <%= registration.payment_cleared ? "Bezahlt" : "Ausstehend" %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "Zum Kurs", course_path(registration.course), class: "text-primary-600 hover:text-primary-900" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="py-8 text-center text-sm text-gray-500">
              Dieser Teilnehmer ist noch für keinen Kurs angemeldet.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% unless @participant.course_registrations.any? %>
    <div class="sm:hidden bg-white rounded-xl border border-gray-200 shadow-sm py-8 text-center">
      <p class="text-sm text-gray-500">Dieser Teilnehmer ist noch für keinen Kurs angemeldet.</p>
    </div>
  <% end %>

</div>
