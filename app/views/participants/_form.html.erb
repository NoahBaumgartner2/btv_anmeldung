<%= form_with(model: participant, class: "contents") do |form| %>
  <% if participant.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
      <p class="font-semibold mb-1"><%= participant.errors.count == 1 ? "Es gibt einen Fehler:" : "Es gibt #{participant.errors.count} Fehler:" %></p>
      <ul class="list-disc ml-5 text-sm space-y-0.5">
        <% participant.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Pflichtfelder ───────────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6 mb-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Persönliche Daten</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
      <div>
        <%= form.label :first_name, "Vorname", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :first_name,
              placeholder: "z.B. Laura",
              autocomplete: "given-name",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:first_name].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:first_name].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:first_name].first %></p>
        <% end %>
      </div>

      <div>
        <%= form.label :last_name, "Nachname", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :last_name,
              placeholder: "z.B. Müller",
              autocomplete: "family-name",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:last_name].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:last_name].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:last_name].first %></p>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
      <div>
        <%= form.label :date_of_birth, "Geburtsdatum", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.date_field :date_of_birth,
              autocomplete: "bday",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:date_of_birth].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:date_of_birth].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:date_of_birth].first %></p>
        <% end %>
      </div>

      <div>
        <%= form.label :gender, "Geschlecht", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <div class="flex gap-3 mt-2">
          <% Participant::GENDERS.each do |g| %>
            <label class="flex-1 cursor-pointer">
              <%= form.radio_button :gender, g, class: "sr-only peer", id: "gender_#{g}" %>
              <span class="peer-checked:bg-primary-600 peer-checked:text-white peer-checked:border-primary-600
                           flex items-center justify-center border-2 border-gray-200 bg-gray-50
                           hover:border-primary-300 text-gray-700 font-semibold rounded-xl py-2.5
                           text-sm transition select-none capitalize">
                <%= g %>
              </span>
            </label>
          <% end %>
        </div>
        <% if participant.errors[:gender].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:gender].first %></p>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Optionale Kontaktdaten ──────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6 mb-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Kontaktdaten</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
      <div>
        <%= form.label :phone_number, "Notfall-Telefon", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.telephone_field :phone_number,
              placeholder: "+41 79 123 45 67",
              autocomplete: "tel",
              pattern: "[+\\d][\\d\\s\\-\\/]{6,}",
              title: "Mindestens 7 Zeichen, erlaubt: +, Ziffern, Leerzeichen, -",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:phone_number].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:phone_number].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:phone_number].first %></p>
        <% end %>
      </div>
    </div>

    <div>
      <%= form.label :ahv_number, "AHV-Nummer", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.text_field :ahv_number,
            placeholder: "756.XXXX.XXXX.XX",
            pattern: "756\\.\\d{4}\\.\\d{4}\\.\\d{2}",
            title: "Format: 756.XXXX.XXXX.XX",
            class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                    participant.errors[:ahv_number].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
      <% if participant.errors[:ahv_number].any? %>
        <p class="mt-1 text-xs text-red-600"><%= participant.errors[:ahv_number].first %></p>
      <% else %>
        <p class="mt-1 text-xs text-gray-400">Wird für die Meldung ans Amt für Sport benötigt.</p>
      <% end %>
    </div>
  </div>

  <%# ── Adresse & J+S Daten ────────────────────────────────────────────── %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6 mb-4">
    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Adresse &amp; J+S Daten</p>

    <div class="grid grid-cols-3 gap-5 mb-5">
      <div class="col-span-2">
        <%= form.label :street, "Strasse", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :street,
              placeholder: "Musterstrasse",
              autocomplete: "street-address",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
      <div>
        <%= form.label :house_number, "Nr.", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :house_number,
              placeholder: "12a",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
      <div>
        <%= form.label :zip_code, "PLZ", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :zip_code,
              placeholder: "3000",
              autocomplete: "postal-code",
              pattern: "\\d{4,6}",
              title: "4–6 Ziffern",
              inputmode: "numeric",
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:zip_code].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:zip_code].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:zip_code].first %></p>
        <% end %>
      </div>
      <div>
        <%= form.label :city, "Ort", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :city,
              placeholder: "Bern",
              autocomplete: "address-level2",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-5">
      <div>
        <%= form.label :country, "Land", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.select :country,
              [["Schweiz (CH)", "CH"], ["Liechtenstein (LI)", "LI"], ["Deutschland (DE)", "DE"],
               ["Frankreich (FR)", "FR"], ["Italien (IT)", "IT"], ["Österreich (AT)", "AT"], ["Andere", "Andere"]],
              { selected: participant.country.presence || "CH" },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
      </div>
      <div>
        <%= form.label :nationality, "Nationalität", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.select :nationality,
              Participant::NATIONALITIES.map { |n| [n, n] },
              { selected: participant.nationality.presence || "CH" },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
      </div>
      <div>
        <%= form.label :mother_tongue, "Muttersprache", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.select :mother_tongue,
              Participant::MOTHER_TONGUES.map { |l| [l, l] },
              { selected: participant.mother_tongue.presence || "DE" },
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
      </div>
    </div>

    <% if current_user.admin? %>
      <div>
        <%= form.label :js_person_number, "J+S Personennummer", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :js_person_number,
              placeholder: "123456789",
              pattern: "\\d{9}",
              title: "Genau 9 Ziffern",
              inputmode: "numeric",
              maxlength: 9,
              class: ["block w-full rounded-lg border px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2",
                      participant.errors[:js_person_number].any? ? "border-red-400 focus:ring-red-400" : "border-gray-300 focus:ring-primary-500"] %>
        <% if participant.errors[:js_person_number].any? %>
          <p class="mt-1 text-xs text-red-600"><%= participant.errors[:js_person_number].first %></p>
        <% else %>
          <p class="mt-1 text-xs text-gray-400">9-stellige BASPO-Nummer. Wird vom Admin eingetragen.</p>
        <% end %>
      </div>
    <% else %>
      <% if participant.js_person_number.present? %>
        <div>
          <p class="block text-sm font-semibold text-gray-700 mb-1">J+S Personennummer</p>
          <p class="px-3 py-2.5 text-sm text-gray-600 bg-gray-50 rounded-lg border border-gray-200"><%= participant.js_person_number %></p>
          <p class="mt-1 text-xs text-gray-400">Wird vom Admin verwaltet.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── Admin: Kontoverknüpfung ─────────────────────────────────────────── %>
  <% if current_user.admin? %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-6 mb-4">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-5">Admin</p>
      <%= form.label :user_id, "Zugehöriges Konto", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.collection_select :user_id, User.order(:email), :id, :email,
            { prompt: "Konto auswählen…" },
            class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-base sm:text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white" %>
    </div>
  <% end %>

  <%# ── Aktionen ─────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row items-center gap-3">
    <%= form.submit participant.new_record? ? "Person erfassen" : "Änderungen speichern",
          class: "w-full sm:w-auto rounded-lg px-5 py-2.5 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white text-sm font-bold cursor-pointer transition shadow-sm min-h-11" %>
    <%= link_to "Abbrechen", participants_path,
          class: "w-full sm:w-auto text-center rounded-lg px-5 py-2.5 bg-gray-100 hover:bg-gray-200 active:bg-gray-300 text-gray-700 text-sm font-medium transition min-h-11" %>
  </div>
<% end %>
