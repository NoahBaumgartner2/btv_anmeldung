<%= form_with(model: participant, class: "contents") do |form| %>
  <% if participant.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-6 border border-red-200">
      <h2><%= pluralize(participant.errors.count, "Fehler") %> gefunden:</h2>
      <ul class="list-disc ml-5 mt-2 text-sm">
        <% participant.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 bg-white p-6 rounded-xl shadow-sm border border-gray-200">

    <div>
      <%= form.label :first_name, "Vorname", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :first_name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :last_name, "Nachname", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :last_name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :date_of_birth, "Geburtsdatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :date_of_birth, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :gender, "Geschlecht", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :gender, ['weiblich', 'männlich', 'divers'], { prompt: "Bitte wählen" }, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white" %>
    </div>

    <div>
      <%= form.label :ahv_number, "AHV-Nummer", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :ahv_number, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "756.XXXX.XXXX.XX" %>
    </div>

    <div>
      <%= form.label :phone_number, "Notfall-Telefonnummer", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :phone_number, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div class="md:col-span-2 pt-4 border-t border-gray-100">
      <%= form.label :user_id, "Zugehöriges Eltern-Konto", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.collection_select :user_id, User.all, :id, :email, { prompt: "Konto auswählen..." }, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white" %>
      <p class="mt-1 text-xs text-gray-500">Wähle den Account aus, der diesen Teilnehmer verwalten darf.</p>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Abbrechen", participants_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 transition" %>
    <%= form.submit "Teilnehmer speichern", class: "cursor-pointer inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition" %>
  </div>
<% end %>
