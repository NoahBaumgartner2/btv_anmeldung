<div class="max-w-5xl mx-auto w-full px-4 sm:px-6 mt-10 mb-16">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
    <div>
      <h1 class="font-extrabold text-4xl text-gray-900 tracking-tight">Mein Profil</h1>
      <p class="text-gray-500 mt-2 text-lg">Verwalte hier deine angemeldeten Personen und ihre Kurs-Tickets.</p>
      <%= link_to account_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 mt-2 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Kontoeinstellungen
      <% end %>
    </div>
    <%= link_to "+ Person erfassen", new_participant_path, class: "bg-primary-600 hover:bg-primary-700 text-white font-bold py-2.5 px-5 rounded-xl shadow-sm transition whitespace-nowrap" %>
  </div>

  <% if @participants.any? %>
    <div class="space-y-10">
      <% @participants.each do |participant| %>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-200 overflow-hidden">

          <%# ── Teilnehmer-Header ───────────────────────────────────────── %>
          <div class="bg-gray-50 px-6 py-5 border-b border-gray-100 flex justify-between items-center">
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-lg shrink-0">
                <%= participant.first_name&.first&.upcase %><%= participant.last_name&.first&.upcase %>
              </div>
              <div>
                <h2 class="text-2xl font-bold text-gray-900"><%= participant.first_name %> <%= participant.last_name %></h2>
                <p class="text-sm font-medium text-gray-500">Geb. <%= participant.date_of_birth&.strftime("%d.%m.%Y") || "Nicht angegeben" %></p>
              </div>
            </div>
            <%= link_to "Bearbeiten", edit_participant_path(participant), class: "text-sm font-bold text-gray-600 hover:text-gray-900 bg-white border border-gray-300 shadow-sm px-4 py-2 rounded-lg transition" %>
          </div>

          <div class="p-6">
            <%
              today    = Date.today
              all_regs = participant.course_registrations

              # ── Semester-Kurse aufteilen ─────────────────────────────────
              semester_regs  = all_regs.reject { |r| r.course.registration_mode == "single_session" }
              active_semester = semester_regs.select { |r|
                r.status != "storniert" &&
                (r.course.end_date.nil? || r.course.end_date >= today)
              }
              past_semester = semester_regs.select { |r|
                r.status == "storniert" ||
                (r.course.end_date.present? && r.course.end_date < today)
              }

              # ── Drop-In Kurse aufteilen ──────────────────────────────────
              single_session_all = all_regs
                .select  { |r| r.course.registration_mode == "single_session" }
                .group_by(&:course_id)
                .transform_values { |regs| regs.sort_by { |r| r.training_session&.start_time || Time.at(0) } }

              active_single  = single_session_all.select { |_, regs|
                c = regs.first.course
                c.end_date.nil? || c.end_date >= today
              }
              past_single    = single_session_all.reject { |_, regs|
                c = regs.first.course
                c.end_date.nil? || c.end_date >= today
              }

              any_active = active_semester.any? || active_single.any?
              any_past   = past_semester.any?   || past_single.any?
            %>

            <%# ── Aktive Kurse ────────────────────────────────────────── %>
            <% if any_active %>
              <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-5">Angemeldete Kurse &amp; Tickets</h3>

              <%# Semester-Karten %>
              <% if active_semester.any? %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 <%= active_single.any? ? 'mb-5' : '' %>">
                  <% active_semester.each do |reg| %>
                    <% course = reg.course %>
                    <div class="bg-white border border-green-200 rounded-2xl p-5 shadow-sm relative flex flex-col h-full hover:shadow-md transition">

                      <div class="absolute top-4 right-4">
                        <% if reg.status == "bestätigt" %>
                          <span class="bg-green-100 text-green-800 text-xs font-bold px-2 py-1 rounded-md">Bestätigt</span>
                        <% else %>
                          <span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-1 rounded-md">Warteliste</span>
                        <% end %>
                      </div>

                      <h4 class="font-bold text-gray-900 pr-16 mb-1 text-lg"><%= course.title %></h4>
                      <p class="text-xs font-bold text-primary-600 mb-4 uppercase tracking-wide"><%= course.registration_type %></p>

                      <% upcoming_sessions = @upcoming_by_course[course.id] || [] %>
                      <% if reg.status == "bestätigt" && upcoming_sessions.any? %>
                        <div class="mt-4 pt-4 border-t border-gray-100">
                          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Nächste Trainings</p>
                          <ul class="space-y-2">
                            <% upcoming_sessions.each do |session| %>
                              <% is_unsubscribed = @unsubscribed_pairs.include?([reg.id, session.id]) %>
                              <% can_unsubscribe = !is_unsubscribed && session.start_time > 24.hours.from_now %>
                              <li class="flex items-center justify-between gap-2 text-sm">
                                <span class="text-gray-700 font-medium"><%= session.start_time.strftime("%-d. %b, %H:%M") %> Uhr</span>
                                <% if is_unsubscribed %>
                                  <span class="text-xs font-bold px-2 py-1 rounded-md bg-red-100 text-red-600">Abgemeldet</span>
                                <% elsif can_unsubscribe %>
                                  <%= button_to unsubscribe_from_session_course_registration_path(reg),
                                        method: :post,
                                        params: { training_session_id: session.id },
                                        data: { turbo_confirm: "#{participant.first_name} vom Training am #{session.start_time.strftime('%-d. %B')} abmelden?" },
                                        class: "text-xs font-bold px-2 py-1 rounded-md bg-red-50 text-red-600 hover:bg-red-100 transition cursor-pointer" do %>
                                    Abmelden
                                  <% end %>
                                <% else %>
                                  <span class="text-xs text-gray-400">–</span>
                                <% end %>
                              </li>
                            <% end %>
                          </ul>
                        </div>
                      <% end %>

                      <div class="mt-auto pt-5 border-t border-gray-100 flex flex-col items-center">
                        <% if reg.status == "bestätigt" && course.has_ticketing %>
                          <div class="cursor-pointer hover:scale-105 transition transform group w-full flex flex-col items-center"
                               onclick="var el=document.getElementById('qr-modal-<%= reg.id.to_json %>'); el.classList.remove('hidden'); el.classList.add('flex')">
                            <div class="bg-white p-2 rounded-xl border-2 border-dashed border-gray-300 mb-3 w-32 h-32 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full group-hover:border-purple-400">
                              <%= generate_qr_code(scan_course_registration_url(reg)) %>
                            </div>
                            <p class="text-xs text-purple-600 font-bold uppercase tracking-wider text-center">Ticket vergrössern</p>
                          </div>
                          <div id="qr-modal-<%= reg.id %>" class="hidden fixed inset-0 z-100 items-center justify-center bg-gray-900 bg-opacity-80 backdrop-blur-sm p-4" onclick="this.classList.remove('flex'); this.classList.add('hidden')">
                            <div class="bg-white p-8 rounded-3xl shadow-2xl max-w-sm w-full flex flex-col items-center" onclick="event.stopPropagation()">
                              <h3 class="text-2xl font-black text-gray-900 mb-1">Ticket – <%= participant.first_name %></h3>
                              <p class="text-gray-500 mb-8 text-center font-medium"><%= course.title %></p>
                              <div class="bg-white p-2 rounded-xl border-2 border-gray-100 mb-8 w-64 h-64 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full shadow-inner">
                                <%= generate_qr_code(scan_course_registration_url(reg)) %>
                              </div>
                              <button class="bg-gray-100 text-gray-700 font-bold py-3.5 px-6 rounded-xl hover:bg-gray-200 transition w-full text-lg"
                                      onclick="document.getElementById('qr-modal-<%= reg.id.to_json %>').classList.add('hidden')">Schließen</button>
                            </div>
                          </div>
                        <% elsif reg.status == "bestätigt" %>
                          <div class="bg-gray-50 rounded-xl p-4 text-center w-full border border-gray-100">
                            <span class="text-xs text-gray-500 font-bold uppercase">Kein Ticket benötigt</span>
                          </div>
                        <% else %>
                          <div class="bg-orange-50 rounded-xl p-4 text-center w-full border border-orange-100">
                            <span class="text-xs text-orange-600 font-bold uppercase">Warten auf Platz</span>
                          </div>
                        <% end %>
                      </div>

                      <div class="mt-3 pt-3 border-t border-gray-100">
                        <%= button_to cancel_course_registration_path(reg),
                              method: :post,
                              data: { turbo_confirm: "#{participant.first_name} vom Kurs \"#{course.title}\" abmelden? Diese Aktion kann nicht rückgängig gemacht werden." },
                              class: "w-full text-xs font-bold text-red-500 hover:text-red-700 hover:bg-red-50 py-2 rounded-lg transition cursor-pointer" do %>
                          Vom Kurs abmelden
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>

              <%# Drop-In Karten (aktiv) %>
              <% active_single.each do |course_id, regs| %>
                <% course = regs.first.course %>
                <%
                  now           = Time.current
                  upcoming_regs = regs.select { |r| r.status == "bestätigt" && r.training_session&.start_time.present? && r.training_session.start_time > now }
                  next_reg      = upcoming_regs.min_by { |r| r.training_session.start_time }
                  active_count  = upcoming_regs.size
                %>
                <div class="bg-white border border-blue-200 rounded-2xl shadow-sm hover:shadow-md transition mb-5">
                  <div class="px-5 pt-5 pb-4 flex items-start justify-between gap-3">
                    <div>
                      <h4 class="font-bold text-gray-900 text-lg leading-tight"><%= course.title %></h4>
                      <p class="text-xs font-bold text-primary-600 mt-0.5 uppercase tracking-wide">Drop-In</p>
                    </div>
                    <% if active_count > 0 %>
                      <span class="shrink-0 bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-md mt-0.5">
                        <%= active_count %> <%= active_count == 1 ? "Termin" : "Termine" %>
                      </span>
                    <% else %>
                      <span class="shrink-0 bg-gray-100 text-gray-400 text-xs font-bold px-2.5 py-1 rounded-md mt-0.5">Keine aktiven Termine</span>
                    <% end %>
                  </div>
                  <div class="border-t border-gray-100 divide-y divide-gray-50">
                    <% regs.each do |reg| %>
                      <% session = reg.training_session %>
                      <% next unless session %>
                      <% is_past      = session.start_time < now %>
                      <% is_storniert = reg.status == "storniert" %>
                      <% can_cancel   = !is_storniert && !is_past && session.start_time > 24.hours.from_now %>
                      <div class="flex items-center justify-between gap-3 px-5 py-3 <%= is_past || is_storniert ? 'opacity-50' : '' %>">
                        <div class="flex items-center gap-2.5 min-w-0">
                          <div class="shrink-0 w-2 h-2 rounded-full <%= is_past || is_storniert ? 'bg-gray-300' : 'bg-blue-400' %>"></div>
                          <span class="text-sm font-medium text-gray-800 truncate">
                            <%= session.start_time.strftime("%-d. %B %Y, %H:%M") %> Uhr
                          </span>
                        </div>
                        <div class="shrink-0">
                          <% if is_storniert %>
                            <span class="text-xs font-bold px-2 py-1 rounded-md bg-red-100 text-red-600">Abgemeldet</span>
                          <% elsif is_past %>
                            <span class="text-xs font-bold px-2 py-1 rounded-md bg-gray-100 text-gray-400">Vergangen</span>
                          <% elsif can_cancel %>
                            <%= button_to cancel_course_registration_path(reg),
                                  method: :post,
                                  data: { turbo_confirm: "Anmeldung für #{session.start_time.strftime('%-d. %B')} stornieren?" },
                                  class: "text-xs font-bold px-2 py-1 rounded-md bg-red-50 text-red-500 hover:bg-red-100 transition cursor-pointer" do %>
                              Abmelden
                            <% end %>
                          <% else %>
                            <span class="text-xs text-gray-400">–</span>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                  <% if course.has_ticketing && next_reg %>
                    <div class="border-t border-gray-100 px-5 py-4">
                      <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Ticket – nächster Termin</p>
                      <div class="flex items-center gap-4">
                        <div class="cursor-pointer hover:scale-105 transition transform group flex flex-col items-center"
                             onclick="var el=document.getElementById('qr-modal-<%= next_reg.id.to_json %>'); el.classList.remove('hidden'); el.classList.add('flex')">
                          <div class="bg-white p-1.5 rounded-xl border-2 border-dashed border-gray-300 w-20 h-20 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full group-hover:border-purple-400">
                            <%= generate_qr_code(scan_course_registration_url(next_reg)) %>
                          </div>
                        </div>
                        <div>
                          <p class="text-sm font-bold text-gray-800"><%= next_reg.training_session.start_time.strftime("%-d. %B %Y") %></p>
                          <p class="text-xs text-gray-500"><%= next_reg.training_session.start_time.strftime("%H:%M") %> – <%= next_reg.training_session.end_time&.strftime("%H:%M") %> Uhr</p>
                          <button class="mt-1.5 text-xs text-purple-600 font-bold hover:underline"
                                  onclick="var el=document.getElementById('qr-modal-<%= next_reg.id.to_json %>'); el.classList.remove('hidden'); el.classList.add('flex')">Vergrössern</button>
                        </div>
                      </div>
                    </div>
                    <div id="qr-modal-<%= next_reg.id %>" class="hidden fixed inset-0 z-100 items-center justify-center bg-gray-900 bg-opacity-80 backdrop-blur-sm p-4" onclick="this.classList.remove('flex'); this.classList.add('hidden')">
                      <div class="bg-white p-8 rounded-3xl shadow-2xl max-w-sm w-full flex flex-col items-center" onclick="event.stopPropagation()">
                        <h3 class="text-2xl font-black text-gray-900 mb-1">Ticket – <%= participant.first_name %></h3>
                        <p class="text-gray-500 mb-1 text-center font-medium"><%= course.title %></p>
                        <p class="text-sm text-gray-400 mb-8 text-center"><%= next_reg.training_session.start_time.strftime("%-d. %B %Y, %H:%M") %> Uhr</p>
                        <div class="bg-white p-2 rounded-xl border-2 border-gray-100 mb-8 w-64 h-64 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full shadow-inner">
                          <%= generate_qr_code(scan_course_registration_url(next_reg)) %>
                        </div>
                        <button class="bg-gray-100 text-gray-700 font-bold py-3.5 px-6 rounded-xl hover:bg-gray-200 transition w-full text-lg"
                                onclick="document.getElementById('qr-modal-<%= next_reg.id.to_json %>').classList.add('hidden')">Schließen</button>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>

            <% else %>
              <div class="bg-gray-50 rounded-xl p-6 text-center border border-gray-100 border-dashed">
                <p class="text-gray-500 text-sm font-medium"><%= participant.first_name %> ist aktuell für keine Kurse angemeldet.</p>
                <%= link_to "Zu den Kursen", courses_path, class: "mt-3 inline-block text-primary-600 font-bold hover:underline" %>
              </div>
            <% end %>

            <%# ── Vergangene Kurse (aufklappbar) ──────────────────────── %>
            <% if any_past %>
              <details class="mt-6 group">
                <summary class="flex items-center gap-2 cursor-pointer list-none select-none text-sm font-bold text-gray-400 hover:text-gray-600 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                  Vergangene &amp; stornierte Kurse
                  <span class="font-normal text-gray-300">(<%= past_semester.size + past_single.size %>)</span>
                </summary>

                <div class="mt-4 space-y-3">

                  <%# Vergangene Semester-Karten %>
                  <% past_semester.each do |reg| %>
                    <% course = reg.course %>
                    <% ended    = course.end_date.present? && course.end_date < today %>
                    <% storniert = reg.status == "storniert" %>
                    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4 flex items-center justify-between gap-3 opacity-70">
                      <div class="min-w-0">
                        <p class="font-bold text-gray-600 text-sm truncate"><%= course.title %></p>
                        <p class="text-xs text-gray-400 mt-0.5">
                          <% if course.end_date.present? %>
                            Beendet <%= course.end_date.strftime("%-d. %B %Y") %>
                          <% end %>
                        </p>
                      </div>
                      <% if storniert %>
                        <span class="shrink-0 bg-red-100 text-red-500 text-xs font-bold px-2 py-1 rounded-md">Storniert</span>
                      <% else %>
                        <span class="shrink-0 bg-gray-200 text-gray-500 text-xs font-bold px-2 py-1 rounded-md">Abgeschlossen</span>
                      <% end %>
                    </div>
                  <% end %>

                  <%# Vergangene Drop-In Karten %>
                  <% past_single.each do |_, regs| %>
                    <% course = regs.first.course %>
                    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4 flex items-center justify-between gap-3 opacity-70">
                      <div class="min-w-0">
                        <p class="font-bold text-gray-600 text-sm truncate"><%= course.title %></p>
                        <p class="text-xs text-gray-400 mt-0.5">
                          Drop-In · <%= regs.size %> <%= regs.size == 1 ? "Termin" : "Termine" %>
                          <% if course.end_date.present? %>
                            · Beendet <%= course.end_date.strftime("%-d. %B %Y") %>
                          <% end %>
                        </p>
                      </div>
                      <span class="shrink-0 bg-gray-200 text-gray-500 text-xs font-bold px-2 py-1 rounded-md">Abgeschlossen</span>
                    </div>
                  <% end %>

                </div>
              </details>
            <% end %>

          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="bg-white p-12 rounded-3xl shadow-sm border border-gray-200 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Noch keine Personen erfasst</h2>
      <p class="text-gray-500 mb-8 max-w-md mx-auto text-lg">Erfasse jetzt eine Person, um sie für Kurse anzumelden.</p>
      <%= link_to "+ Person erfassen", new_participant_path, class: "inline-block bg-primary-600 hover:bg-primary-700 text-white font-bold py-3.5 px-8 rounded-xl shadow-sm transition text-lg" %>
    </div>
  <% end %>

</div>
