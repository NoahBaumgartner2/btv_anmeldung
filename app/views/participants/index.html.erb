<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-3xl text-gray-800">Teilnehmer</h1>
    <%= link_to "Neuer Teilnehmer", new_participant_path, class: "rounded-lg py-2 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium transition shadow-sm" %>
  </div>

  <div class="mb-6">
    <%= form_with url: participants_path, method: :get, data: { turbo_frame: "participants_list" }, class: "flex items-center" do |form| %>
      <div class="relative w-full md:w-1/3">
        <%= form.text_field :query, value: params[:query], placeholder: "Nach Vor- oder Nachname suchen...", class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 pl-10", oninput: "this.form.requestSubmit()" %>

        <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag "participants_list" do %>
    <div class="overflow-x-auto bg-white shadow-sm ring-1 ring-gray-200 rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Geburtsdatum</th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Geschlecht</th>
            <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktionen</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @participants.each do |participant| %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="py-4 px-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= participant.first_name %> <%= participant.last_name %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <%= participant.date_of_birth&.strftime("%d.%m.%Y") %>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-sm text-gray-500">
                <span class="px-2 py-1 bg-gray-100 rounded-full text-xs font-medium text-gray-600">
                  <%= participant.gender %>
                </span>
              </td>
              <td class="py-4 px-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                <%= link_to "Anzeigen", participant, class: "text-blue-600 hover:text-blue-900 data-turbo-frame='_top'" %>
                <%= link_to "Bearbeiten", edit_participant_path(participant), class: "text-orange-500 hover:text-orange-700 data-turbo-frame='_top'" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @participants.empty? %>
      <div class="text-center py-10 bg-white shadow-sm ring-1 ring-gray-200 rounded-lg mt-4">
        <p class="text-gray-500">Keine Teilnehmer für diesen Suchbegriff gefunden.</p>
      </div>
    <% end %>
  <% end %> </div>
