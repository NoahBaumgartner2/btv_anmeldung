<div id="<%= dom_id holiday %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= holiday.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Start date:</strong>
    <%= holiday.start_date %>
  </div>
  <div>
