<% content_for :title, t('holidays.index.title') %>

<div class="max-w-4xl mx-auto mt-6 sm:mt-10 w-full mb-16">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 sm:mb-8 gap-3 sm:gap-4">
    <div>
      <h1 class="font-bold text-xl sm:text-3xl text-gray-900"><%= t('holidays.index.title') %></h1>
      <p class="text-gray-500 mt-1 text-sm"><%= t('holidays.index.subtitle') %></p>
    </div>
    <%= link_to t('holidays.index.new_holiday'), new_holiday_path,
          class: "shrink-0 w-full sm:w-auto text-center bg-red-600 py-2.5 px-4 shadow-sm text-sm font-bold rounded-lg text-white hover:bg-red-700 active:bg-red-800 transition min-h-11" %>
  </div>

  <div class="bg-white shadow-sm ring-1 ring-gray-200 rounded-xl overflow-hidden">
    <% if @holidays.any? %>

      <%# Mobile: Cards %>
      <div class="sm:hidden divide-y divide-gray-100">
        <% @holidays.each do |holiday| %>
          <%
            today = Date.today
            days = holiday.start_date && holiday.end_date ? (holiday.end_date - holiday.start_date).to_i + 1 : nil
            if holiday.end_date && holiday.end_date < today
              status_label = t('holidays.index.status.past')
              status_class = "bg-gray-100 text-gray-500"
            elsif holiday.start_date && holiday.start_date <= today && holiday.end_date && holiday.end_date >= today
              status_label = t('holidays.index.status.current')
              status_class = "bg-green-100 text-green-700"
            else
              status_label = t('holidays.index.status.upcoming')
              status_class = "bg-primary-100 text-primary-700"
            end
          %>
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-1">
              <p class="text-sm font-semibold text-gray-900"><%= holiday.title %></p>
              <span class="shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= status_class %>">
                <%= status_label %>
              </span>
            </div>
            <p class="text-sm text-gray-600 mb-3">
              <%= holiday.start_date&.strftime("%-d. %b %Y") %> &ndash; <%= holiday.end_date&.strftime("%-d. %b %Y") %>
              <% if days %>
                <span class="text-xs text-gray-400">(<%= t('holidays.index.days', count: days) %>)</span>
              <% end %>
            </p>
            <div class="flex gap-3">
              <%= link_to t('holidays.index.edit'), edit_holiday_path(holiday),
                    class: "flex-1 text-center text-primary-600 font-medium bg-primary-50 active:bg-primary-100 py-2.5 rounded-lg text-sm min-h-11 leading-6 transition" %>
              <%= button_to t('holidays.index.delete'), holiday_path(holiday), method: :delete,
                    data: { turbo_confirm: t('holidays.index.delete_confirm', title: holiday.title) },
                    form: { class: "flex-1" },
                    class: "w-full text-center text-red-500 font-medium bg-red-50 active:bg-red-100 py-2.5 rounded-lg text-sm min-h-11 cursor-pointer transition" %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Desktop: Tabelle %>
      <table class="hidden sm:table min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t('holidays.index.col_name') %></th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t('holidays.index.col_period') %></th>
            <th scope="col" class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t('holidays.index.col_status') %></th>
            <th scope="col" class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider"><%= t('holidays.index.col_actions') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @holidays.each do |holiday| %>
            <%
              today = Date.today
              days = holiday.start_date && holiday.end_date ? (holiday.end_date - holiday.start_date).to_i + 1 : nil
              if holiday.end_date && holiday.end_date < today
                status_label = t('holidays.index.status.past')
                status_class = "bg-gray-100 text-gray-500"
              elsif holiday.start_date && holiday.start_date <= today && holiday.end_date && holiday.end_date >= today
                status_label = t('holidays.index.status.current')
                status_class = "bg-green-100 text-green-700"
              else
                status_label = t('holidays.index.status.upcoming')
                status_class = "bg-primary-100 text-primary-700"
              end
            %>
            <tr class="hover:bg-gray-50 transition duration-150">
              <td class="py-4 px-4">
                <span class="text-sm font-semibold text-gray-900"><%= holiday.title %></span>
              </td>
              <td class="py-4 px-4 text-sm text-gray-600">
                <span class="font-medium">
                  <%= holiday.start_date&.strftime("%-d. %b %Y") %> &ndash; <%= holiday.end_date&.strftime("%-d. %b %Y") %>
                </span>
                <% if days %>
                  <span class="ml-2 text-xs text-gray-400">(<%= t('holidays.index.days', count: days) %>)</span>
                <% end %>
              </td>
              <td class="py-4 px-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= status_class %>">
                  <%= status_label %>
                </span>
              </td>
              <td class="py-4 px-4 text-right text-sm font-medium whitespace-nowrap">
                <%= link_to t('holidays.index.edit'), edit_holiday_path(holiday),
                      class: "text-primary-600 hover:text-primary-800 font-medium mr-3" %>
                <%= button_to t('holidays.index.delete'), holiday_path(holiday), method: :delete,
                      data: { turbo_confirm: t('holidays.index.delete_confirm', title: holiday.title) },
                      form: { class: "inline" },
                      class: "text-red-500 hover:text-red-700 font-medium cursor-pointer bg-transparent border-0 p-0" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

    <% else %>
      <div class="py-14 text-center">
        <p class="font-medium text-gray-700 mb-1"><%= t('holidays.index.empty.title') %></p>
        <p class="text-sm text-gray-400"><%= t('holidays.index.empty.body') %></p>
      </div>
    <% end %>
  </div>

</div>
