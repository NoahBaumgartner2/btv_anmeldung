<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>⚠️ Anwesenheit nicht erfasst</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;padding:32px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
          <tr>
            <td style="padding:32px 32px 8px 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;margin-bottom:24px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0;font-size:15px;font-weight:600;color:#991b1b;">
                      ⚠️ Anwesenheit wurde für eine Trainingseinheit nicht erfasst.
                    </p>
                  </td>
                </tr>
              </table>
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border-radius:8px;margin-bottom:24px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">Kurs</p>
                    <p style="margin:0 0 12px 0;font-size:16px;font-weight:600;color:#111827;"><%= @course.name %></p>
                    <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">Datum &amp; Zeit</p>
                    <p style="margin:0 0 12px 0;font-size:16px;color:#111827;">
                      <%= I18n.l(@training_session.start_time, format: :long) %> – <%= I18n.l(@training_session.end_time, format: :short) %>
                    </p>
                    <p style="margin:0 0 6px 0;font-size:14px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">Zugewiesene Trainer</p>
                    <% if @trainer_emails.any? %>
                      <% @trainer_emails.each do |email| %>
                        <p style="margin:0 0 4px 0;font-size:14px;color:#374151;">• <%= email %></p>
                      <% end %>
                    <% else %>
                      <p style="margin:0;font-size:14px;color:#9ca3af;font-style:italic;">Keine Trainer zugewiesen</p>
                    <% end %>
                  </td>
                </tr>
              </table>
              <table cellpadding="0" cellspacing="0" style="margin-bottom:32px;">
                <tr>
                  <td style="background:#2563eb;border-radius:8px;padding:12px 24px;">
                    <a href="<%= @training_session_url %>" style="color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;">Trainingseinheit ansehen</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 32px;background:#f9fafb;border-top:1px solid #e5e7eb;text-align:center;">
              <p style="margin:0;font-size:12px;color:#9ca3af;">
                Diese E-Mail wurde automatisch vom BTV Anmeldungssystem versendet.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
