<div class="max-w-5xl mx-auto mt-8 mb-16 px-4">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <%= link_to "← Mailing-Zentrale", newsletters_path,
            class: "text-sm font-semibold text-gray-400 hover:text-gray-700 transition mb-2 inline-block" %>
      <h1 class="text-3xl font-extrabold text-gray-900">Empfängerliste</h1>
      <p class="text-gray-500 text-sm mt-1">
        <span class="font-semibold text-green-700"><%= @subscribed_count %> angemeldet</span>
        · <span class="text-gray-400"><%= @unsubscribed_count %> abgemeldet</span>
        · <span class="text-gray-400"><%= @total_count %> total</span>
      </p>
    </div>
    <%= link_to "CSV exportieren", export_newsletter_subscribers_path,
          class: "shrink-0 bg-white border border-gray-300 text-gray-700 font-bold text-sm py-2.5 px-4 rounded-lg hover:bg-gray-50 transition" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

    <%# ── Manuell hinzufügen ────────────────────────────────────────────── %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
      <h2 class="font-bold text-gray-900 mb-4">Einzeln hinzufügen</h2>
      <%= form_with model: NewsletterSubscriber.new, url: newsletter_subscribers_path do |f| %>
        <% if @subscriber&.errors&.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700 mb-3">
            <%= @subscriber.errors.full_messages.first %>
          </div>
        <% end %>
        <div class="space-y-3">
          <div>
            <%= f.label :email, "E-Mail *", class: "block text-xs font-bold text-gray-600 mb-1" %>
            <%= f.email_field :email, placeholder: "max@beispiel.ch",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <div>
            <%= f.label :name, "Name (optional)", class: "block text-xs font-bold text-gray-600 mb-1" %>
            <%= f.text_field :name, placeholder: "Max Muster",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 focus:outline-none" %>
          </div>
          <%= f.hidden_field :status, value: "subscribed" %>
          <%= f.submit "Hinzufügen",
                class: "cursor-pointer w-full bg-primary-600 hover:bg-primary-700 text-white font-bold text-sm py-2.5 rounded-lg transition" %>
        </div>
      <% end %>
    </div>

    <%# ── CSV Import ──────────────────────────────────────────────────────── %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-5">
      <h2 class="font-bold text-gray-900 mb-1">CSV importieren</h2>
      <p class="text-xs text-gray-500 mb-4">
        Spalten: <code class="bg-gray-100 px-1 rounded">email</code>, <code class="bg-gray-100 px-1 rounded">name</code> (optional), <code class="bg-gray-100 px-1 rounded">status</code> (optional).<br>
        Bestehende Adressen werden aktualisiert.
      </p>
      <%= form_with url: import_newsletter_subscribers_path, method: :post, multipart: true do |f| %>
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-600 mb-1">CSV-Datei</label>
          <input type="file" name="csv_file" accept=".csv,text/csv"
                 class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
        </div>
        <button type="submit"
                class="cursor-pointer w-full bg-green-600 hover:bg-green-700 text-white font-bold text-sm py-2.5 rounded-lg transition">
          Importieren
        </button>
      <% end %>
    </div>

    <%# ── Stats ──────────────────────────────────────────────────────────── %>
    <div class="bg-gradient-to-br from-primary-600 to-primary-700 rounded-2xl shadow-sm p-5 text-white flex flex-col justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-primary-200 mb-1">Übersicht</p>
        <p class="text-4xl font-extrabold leading-none"><%= @subscribed_count %></p>
        <p class="text-primary-200 text-sm mt-1">aktive Empfänger</p>
      </div>
      <div class="mt-6 space-y-2">
        <div class="flex justify-between text-sm">
          <span class="text-primary-200">Angemeldet</span>
          <span class="font-bold"><%= @subscribed_count %></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-primary-200">Abgemeldet</span>
          <span class="font-bold"><%= @unsubscribed_count %></span>
        </div>
        <div class="pt-2 border-t border-primary-500 flex justify-between text-sm">
          <span class="text-primary-200">Total</span>
          <span class="font-bold"><%= @total_count %></span>
        </div>
      </div>
    </div>

  </div>

  <%# ── Suche + Tabelle ─────────────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <%= form_with url: newsletter_subscribers_path, method: :get, data: { turbo_frame: "_top" } do |f| %>
        <div class="flex gap-3">
          <%= f.search_field :q, value: params[:q],
                placeholder: "Nach E-Mail oder Name suchen…",
                autofocus: params[:q].present?,
                class: "flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 focus:outline-none" %>
          <button type="submit"
                  class="cursor-pointer bg-primary-600 hover:bg-primary-700 text-white font-bold text-sm px-4 py-2 rounded-lg transition">
            Suchen
          </button>
          <% if params[:q].present? %>
            <%= link_to "Zurücksetzen", newsletter_subscribers_path,
                  class: "bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold text-sm px-4 py-2 rounded-lg transition" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if params[:q].present? %>
      <% if @results.any? %>
        <div class="px-5 py-2 bg-gray-50 border-b border-gray-100">
          <p class="text-xs text-gray-500">
            <% count = @results.size %>
            <%= count == 100 ? "Erste 100 Treffer" : "#{count} #{"Treffer".pluralize(count)}" %>
            für <span class="font-semibold">"<%= params[:q] %>"</span>
          </p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
              <tr>
                <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">E-Mail</th>
                <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Name</th>
                <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Quelle</th>
                <th class="py-3 px-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Hinzugefügt</th>
                <th class="py-3 px-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Aktionen</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% @results.each do |sub| %>
                <tr class="hover:bg-gray-50 transition">
                  <td class="py-3 px-4 text-sm font-semibold text-gray-900"><%= sub.email %></td>
                  <td class="py-3 px-4 text-sm text-gray-500"><%= sub.name.presence || "—" %></td>
                  <td class="py-3 px-4">
                    <% if sub.subscribed? %>
                      <span class="inline-flex items-center gap-1.5 text-xs font-bold bg-green-100 text-green-800 px-2.5 py-1 rounded-full">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-500 inline-block"></span>
                        Angemeldet
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1.5 text-xs font-bold bg-gray-100 text-gray-500 px-2.5 py-1 rounded-full">
                        <span class="h-1.5 w-1.5 rounded-full bg-gray-400 inline-block"></span>
                        Abgemeldet
                      </span>
                    <% end %>
                  </td>
                  <td class="py-3 px-4 text-xs text-gray-400">
                    <%= sub.source == "csv_import" ? "CSV" : "Manuell" %>
                  </td>
                  <td class="py-3 px-4 text-xs text-gray-400">
                    <%= sub.created_at.strftime("%-d. %b %Y") %>
                  </td>
                  <td class="py-3 px-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <%= button_to sub.subscribed? ? "Abmelden" : "Anmelden",
                            newsletter_subscriber_path(sub),
                            method: :patch,
                            class: "text-xs font-bold px-3 py-1.5 rounded-lg transition cursor-pointer #{sub.subscribed? ? 'bg-gray-100 hover:bg-gray-200 text-gray-600' : 'bg-green-100 hover:bg-green-200 text-green-700'}" %>
                      <%= button_to "Löschen",
                            newsletter_subscriber_path(sub),
                            method: :delete,
                            data: { turbo_confirm: "#{sub.email} wirklich löschen?" },
                            class: "text-xs font-bold px-3 py-1.5 rounded-lg bg-red-50 hover:bg-red-100 text-red-600 transition cursor-pointer" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="py-12 text-center">
          <p class="text-gray-400 font-semibold">Keine Treffer für "<%= params[:q] %>"</p>
        </div>
      <% end %>
    <% elsif @total_count > 0 %>
      <div class="py-12 text-center">
        <p class="text-gray-500 font-semibold"><%= @total_count %> Empfänger vorhanden</p>
        <p class="text-gray-400 text-sm mt-1">Suche nach E-Mail oder Name, um Einträge anzuzeigen.</p>
      </div>
    <% else %>
      <div class="py-16 text-center">
        <p class="text-gray-400 font-semibold">Noch keine Empfänger erfasst.</p>
        <p class="text-gray-400 text-sm mt-1">Füge einzelne Adressen hinzu oder importiere eine CSV-Datei.</p>
      </div>
    <% end %>
  </div>

</div>
